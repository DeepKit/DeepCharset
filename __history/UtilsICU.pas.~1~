unit UtilsICU;

interface

uses
  System.SysUtils, System.Classes, System.Types, Winapi.Windows, System.Generics.Collections;

// --- ICU 基础类型定义 ---
// 注意: 这些是简化的定义，可能需要根据具体的ICU版本和编译器设置进行调整。
type
  UErrorCode = Integer; // 通常是带符号的32位整数
  UCharsetDetector = Pointer; // 字符集探测器 (ucsdet) 的不透明指针
  UCharsetMatch = Pointer; // 字符集匹配信息 (ucsdet) 的不透明指针
  UConverter = Pointer; // 编码转换器 (ucnv) 的不透明指针

const
  // --- ICU DLL 文件名 (根据用户文件列表更新为版本 77) ---
  icuucDll = 'icuuc77.dll'; // ICU Common DLL
  icuinDll = 'icuin77.dll'; // ICU I18n DLL
  icudtDll = 'icudt77.dll'; // ICU Data DLL

  // --- 常见的 UErrorCode 值 ---
  U_ZERO_ERROR = 0; // 成功
  U_BUFFER_OVERFLOW_ERROR = 15; // 缓冲区溢出错误
  U_FILE_ACCESS_ERROR = 4; // 文件访问错误 (示例值，需核对头文件)
  // 可根据需要添加其他相关错误码...

  // --- 缓冲区大小常量 ---
  DETECT_BUFFER_SIZE = 4096; // 用于检测时读取的字节数

// --- ICU API 函数声明 (函数名后缀更新为 _77) ---

// -- 错误检查 --
function u_errorName(code: UErrorCode): PAnsiChar; cdecl; external icuucDll name 'u_errorName';

// -- 字符集检测 (ucsdet) --
// 注意: 需确保函数名与 ICU DLL 中导出的名称匹配。如果不确定，请使用 Dependency Walker 等工具检查。
function ucsdet_open(out pErrorCode: UErrorCode): UCharsetDetector; cdecl; external icuinDll name 'ucsdet_open_77';
procedure ucsdet_close(csd: UCharsetDetector); cdecl; external icuinDll name 'ucsdet_close_77';
procedure ucsdet_setText(csd: UCharsetDetector; text: PAnsiChar; length: Integer; out pErrorCode: UErrorCode); cdecl; external icuinDll name 'ucsdet_setText_77';
function ucsdet_detect(csd: UCharsetDetector; out pErrorCode: UErrorCode): UCharsetMatch; cdecl; external icuinDll name 'ucsdet_detect_77';
function ucsdet_detectAll(csd: UCharsetDetector; out matchesFound: Integer; out pErrorCode: UErrorCode): PPChar; cdecl; external icuinDll name 'ucsdet_detectAll_77'; // 注意: 此函数签名可能需要根据实际导出进行调整
function ucsdet_getName(match: UCharsetMatch; out pErrorCode: UErrorCode): PAnsiChar; cdecl; external icuinDll name 'ucsdet_getName_77';
function ucsdet_getConfidence(match: UCharsetMatch; out pErrorCode: UErrorCode): Integer; cdecl; external icuinDll name 'ucsdet_getConfidence_77';
function ucsdet_getLanguage(match: UCharsetMatch; out pErrorCode: UErrorCode): PAnsiChar; cdecl; external icuinDll name 'ucsdet_getLanguage_77';

// -- 编码转换 (ucnv) --
function ucnv_open(converterName: PAnsiChar; out pErrorCode: UErrorCode): UConverter; cdecl; external icuucDll name 'ucnv_open_77';
procedure ucnv_close(converter: UConverter); cdecl; external icuucDll name 'ucnv_close_77';
function ucnv_convertEx(targetConverter, sourceConverter: UConverter;
  target: PChar; targetLimit: PChar;
  source: PChar; sourceLimit: PChar;
  pivotStart: PChar; pivotSource: PChar; pivotTarget: PChar; pivotLimit: PChar;
  reset: Boolean; useFallback: Boolean; out pErrorCode: UErrorCode): Integer;
  cdecl; external icuucDll name 'ucnv_convertEx_77'; // 使用 PChar 假设内部使用 Unicode。如果需要，请调整。

// 更常用的简单转换函数
function ucnv_fromUChars(cnv: UConverter; dest: PAnsiChar; destCapacity: Integer;
  src: PWideChar; srcLength: Integer; out pErrorCode: UErrorCode): Integer;
  cdecl; external icuucDll name 'ucnv_fromUChars_77';

function ucnv_toUChars(cnv: UConverter; dest: PWideChar; destCapacity: Integer;
  src: PAnsiChar; srcLength: Integer; out pErrorCode: UErrorCode): Integer;
  cdecl; external icuucDll name 'ucnv_toUChars_77';


// 日志记录的辅助函数类型 (由 Controller 传递)
// Corrected: Changed to TProc<string> to match ControllerEncoding
type
  TLogProcedure = TProc<string>;

// --- ICU 辅助类 ---
type
  TIcuHelper = class
  private
    FLog: TLogProcedure; // Corrected: Changed type to TProc<string>
    FLastError: string;
    function CheckError(const Context: string; ErrorCode: UErrorCode): Boolean; // 检查并记录 ICU 错误
    function InternalDetectEncoding(const Buffer: TBytes): string; // 内部编码检测逻辑
    function GetBestDetectedEncoding(csd: UCharsetDetector): string; // 获取最佳检测结果
  public
    constructor Create(LogProc: TLogProcedure); // 构造函数，接收日志回调
    function DetectFileEncoding(const FilePath: string; out DetectedEncoding: string): Boolean; // 检测文件编码
    // 将源字节流 (假设为 UTF-8) 转换为目标编码 TargetEncodingName
    function ConvertEncoding(var Source: TBytes; const TargetEncodingName: string; AddBOM: Boolean = False): Boolean; overload;
    // 将源字节流 (指定编码 FromEncodingName) 转换为目标编码 TargetEncodingName
    function ConvertEncoding(var Source: TBytes; const FromEncodingName, TargetEncodingName: string; AddBOM: Boolean = False): Boolean; overload;
    property LastError: string read FLastError; // 获取最后发生的错误信息
  end;

implementation

uses System.IOUtils; // 用于 TFile

// --- 错误代码检查辅助函数 ---
function UErrorCodeSuccess(code: UErrorCode): Boolean;
begin
  // 相当于 U_SUCCESS 宏
  Result := code <= U_ZERO_ERROR;
end;

function UErrorCodeFailed(code: UErrorCode): Boolean;
begin
  // 相当于 U_FAILURE 宏
  Result := code > U_ZERO_ERROR;
end;


// --- TIcuHelper 实现 ---

constructor TIcuHelper.Create(LogProc: TLogProcedure);
begin
  inherited Create;
  FLog := LogProc;
  FLastError := '';
  // 可选：如果需要，在此处初始化 ICU (例如调用 u_init), 但基础用法通常不需要。
end;

function TIcuHelper.CheckError(const Context: string; ErrorCode: UErrorCode): Boolean;
var
  ErrorNameAnsi: PAnsiChar;
  ErrorName: string;
begin
  Result := UErrorCodeSuccess(ErrorCode);
  if not Result then
  begin
    ErrorNameAnsi := u_errorName(ErrorCode);
    if ErrorNameAnsi <> nil then
      ErrorName := string(ErrorNameAnsi) // PAnsiChar 转 Delphi string
    else
      ErrorName := '未知的错误码';
    FLastError := Format('%s 失败。ICU 错误: %s (%d)', [Context, ErrorName, ErrorCode]);
    // 调用传入的日志回调记录错误
    if Assigned(FLog) then
      FLog(FLastError);
  end
  else
  begin
    FLastError := ''; // 成功时清除最后错误信息
  end;
end;

// 简单辅助函数获取最佳匹配 (最高置信度)
// 注意: 这是基础实现，实际可能需要遍历 ucsdet_detectAll 的结果
function TIcuHelper.GetBestDetectedEncoding(csd: UCharsetDetector): string;
var
  Match: UCharsetMatch;
  ErrorCode: UErrorCode;
  EncodingNameAnsi: PAnsiChar;
  Confidence: Integer;
begin
  Result := '';
  ErrorCode := U_ZERO_ERROR;
  Match := ucsdet_detect(csd, ErrorCode); // 获取单个最佳匹配结果

  if CheckError('ucsdet_detect', ErrorCode) and (Match <> nil) then
  begin
    EncodingNameAnsi := ucsdet_getName(Match, ErrorCode);
    if CheckError('ucsdet_getName', ErrorCode) and (EncodingNameAnsi <> nil) then
    begin
      Confidence := ucsdet_getConfidence(Match, ErrorCode);
      if CheckError('ucsdet_getConfidence', ErrorCode) then
      begin
        if Assigned(FLog) then
          FLog(Format('  [ICU检测] 最佳猜测: %s (置信度: %d)', [string(EncodingNameAnsi), Confidence]));
        // 基本的置信度阈值 - 可根据需要调整
        if Confidence >= 50 then // 示例阈值
          Result := string(EncodingNameAnsi)
        else
         if Assigned(FLog) then FLog('  [ICU检测] 置信度过低，忽略检测结果。');
      end;
    end;
    // 注意: UCharsetMatch 对象由 ICU 通过探测器内部管理，我们不需要手动释放它。
  end;
end;


function TIcuHelper.InternalDetectEncoding(const Buffer: TBytes): string;
var
  Detector: UCharsetDetector;
  ErrorCode: UErrorCode;
  BufferPtr: PAnsiChar;
  BytesToDetect: Integer;
begin
  Result := '';
  FLastError := '';
  ErrorCode := U_ZERO_ERROR;

  Detector := ucsdet_open(ErrorCode);
  if not CheckError('ucsdet_open', ErrorCode) or (Detector = nil) then
    Exit; // 创建探测器失败

  try
    BytesToDetect := Length(Buffer);
    if BytesToDetect = 0 then
    begin
      if Assigned(FLog) then FLog('  [ICU检测] 缓冲区为空。');
      Exit;
    end;

    BufferPtr := PAnsiChar(Pointer(Buffer)); // 获取字节数组指针

    ucsdet_setText(Detector, BufferPtr, BytesToDetect, ErrorCode);
    if not CheckError('ucsdet_setText', ErrorCode) then
      Exit; // 设置待检测文本失败

    // 获取最佳检测到的编码名称
    Result := GetBestDetectedEncoding(Detector);

  finally
    if Detector <> nil then
      ucsdet_close(Detector); // 释放探测器
  end;
end;


function TIcuHelper.DetectFileEncoding(const FilePath: string; out DetectedEncoding: string): Boolean;
var
  FS: TFileStream;
  Buffer: TBytes;
  BytesRead: Integer;
begin
  Result := False;
  DetectedEncoding := '';
  FLastError := '';

  if not TFile.Exists(FilePath) then
  begin
    FLastError := Format('文件未找到: %s', [FilePath]);
    if Assigned(FLog) then FLog(FLastError);
    Exit;
  end;

  try
    FS := TFileStream.Create(FilePath, fmOpenRead or fmShareDenyWrite);
    try
      SetLength(Buffer, DETECT_BUFFER_SIZE);
      BytesRead := FS.Read(Buffer, 0, DETECT_BUFFER_SIZE);
      SetLength(Buffer, BytesRead); // 调整缓冲区为实际读取大小

      if BytesRead > 0 then
      begin
        DetectedEncoding := InternalDetectEncoding(Buffer);
        Result := DetectedEncoding <> '';
        if not Result and (FLastError = '') then // 内部检测成功但未找到可靠结果
          FLastError := 'ICU 未能可靠地确定编码。';
        // 记录最终检测到的编码或失败原因
        if Result then
        begin
          if Assigned(FLog) then FLog(Format('[ICU检测] 文件 [%s] 检测到编码: %s', [ExtractFileName(FilePath), DetectedEncoding]));
        end
        else
        begin
          if Assigned(FLog) then FLog(Format('[ICU检测] 文件 [%s] 编码检测失败: %s', [ExtractFileName(FilePath), FLastError]));
        end;
      end
      else
      begin
         FLastError := Format('文件为空或无法读取: %s', [FilePath]);
         if Assigned(FLog) then FLog(FLastError);
      end;

    finally
      FS.Free;
    end;
  except
    on E: Exception do
    begin
      FLastError := Format('读取文件 %s 进行检测时出错: %s', [FilePath, E.Message]);
      if Assigned(FLog) then FLog(FLastError);
      Result := False;
    end;
  end;
end;

// --- 转换实现 ---

// 重载 1: 假设源编码为 UTF-8
function TIcuHelper.ConvertEncoding(var Source: TBytes; const TargetEncodingName: string; AddBOM: Boolean = False): Boolean;
begin
  // 为简化，委托给更通用的版本，假设源是 UTF-8
  Result := ConvertEncoding(Source, 'UTF-8', TargetEncodingName, AddBOM);
end;

// 重载 2: 指定源编码和目标编码
// 使用 ucnv_toUChars 和 ucnv_fromUChars 以提高可靠性
function TIcuHelper.ConvertEncoding(var Source: TBytes; const FromEncodingName, TargetEncodingName: string; AddBOM: Boolean = False): Boolean;
var
  SrcConverter, DstConverter: UConverter;
  ErrorCode: UErrorCode;
  SourcePtr: PAnsiChar;
  SourceLen: Integer;
  UCharsBuffer: TArray<WideChar>; // 中间 Unicode 缓冲区 (UTF-16)
  UCharsCapacity, UCharsLen: Integer;
  TargetBuffer: TArray<Byte>; // 最终字节缓冲区
  TargetCapacity, TargetLen: Integer;
  RetryCount: Integer;
  BOMBytes: TBytes;
begin
  Result := False;
  FLastError := '';
  SrcConverter := nil;
  DstConverter := nil;
  UCharsLen := -1; // 初始化 UCharsLen 为 -1，表示初始失败状态

  SourceLen := Length(Source);
  if SourceLen = 0 then
  begin
    if Assigned(FLog) then FLog('源缓冲区为空，无需转换。');
    Result := True; // 空输入转换为空输出，视为成功
    Exit;
  end;

  ErrorCode := U_ZERO_ERROR;
  SrcConverter := ucnv_open(PAnsiChar(AnsiString(FromEncodingName)), ErrorCode);
  if not CheckError(Format('ucnv_open (源: %s)', [FromEncodingName]), ErrorCode) or (SrcConverter = nil) then Exit;
  try // 源转换器的 TRY 块
    // 步骤 1: 将源字节流 (FromEncodingName) 转换为 UChars (WideChar / UTF-16)
    UCharsCapacity := SourceLen + 1; // 初始估计容量，可能需要扩展
    SetLength(UCharsBuffer, UCharsCapacity);
    SourcePtr := PAnsiChar(Pointer(Source)); // 获取源字节指针
    RetryCount := 0;
    repeat
      ErrorCode := U_ZERO_ERROR;
      // 调用 ICU 函数进行转换到 UChars
      UCharsLen := ucnv_toUChars(SrcConverter, @UCharsBuffer[0], UCharsCapacity, SourcePtr, SourceLen, ErrorCode);
      if UErrorCodeSuccess(ErrorCode) then
      begin
        SetLength(UCharsBuffer, UCharsLen); // 调整 UChars 缓冲区为实际长度
        if Assigned(FLog) then FLog(Format('成功将 %s 转换为 %d UChars (WideChars)。', [FromEncodingName, UCharsLen]));
        Break; // 步骤 1 成功
      end
      else if ErrorCode = U_BUFFER_OVERFLOW_ERROR then
      begin // 缓冲区溢出处理
        Inc(RetryCount);
        if RetryCount > 3 then
        begin
          CheckError(Format('ucnv_toUChars (转换 %s 时超出重试次数)', [FromEncodingName]), ErrorCode);
          UCharsLen := -1; // 明确标记失败
          Break; // 放弃
        end;
        // 容量加倍并重试
        UCharsCapacity := UCharsCapacity * 2 + 10;
        SetLength(UCharsBuffer, UCharsCapacity);
        if Assigned(FLog) then FLog(Format('ucnv_toUChars 缓冲区溢出 (%s)，使用容量 %d 重试', [FromEncodingName, UCharsCapacity]));
      end
      else
      begin // 步骤 1 发生其他错误
        CheckError(Format('ucnv_toUChars (%s)', [FromEncodingName]), ErrorCode);
        UCharsLen := -1; // 明确标记失败
        Break;
      end;
    until False;

    // 步骤 2: 将 UChars (WideChar / UTF-16) 转换为目标字节流 (TargetEncodingName)
    if UCharsLen >= 0 then // 仅当步骤 1 成功时继续
    begin // 'if UCharsLen >= 0' 的 BEGIN 块
      ErrorCode := U_ZERO_ERROR;
      DstConverter := ucnv_open(PAnsiChar(AnsiString(TargetEncodingName)), ErrorCode);
      if not CheckError(Format('ucnv_open (目标: %s)', [TargetEncodingName]), ErrorCode) or (DstConverter = nil) then
      begin // 'if not CheckError...' 的 BEGIN 块
        // 如果目标转换器打开失败，仍需在 finally 中关闭源转换器
        Exit; // 退出函数，Result 保持 False
      end; // 'if not CheckError...' 的 END 块
      try // 目标转换器的 TRY 块
        // 估计目标缓冲区大小
        TargetCapacity := UCharsLen * 4 + 10; // 넉넉한 추정치 (넉넉하게 추정, 예: UTF-8은 문자당 최대 4바이트 사용 가능)
        SetLength(TargetBuffer, TargetCapacity);
        RetryCount := 0;
        repeat
          ErrorCode := U_ZERO_ERROR;
          // 调用 ICU 函数从 UChars 进行转换
          TargetLen := ucnv_fromUChars(DstConverter, PAnsiChar(@TargetBuffer[0]), TargetCapacity, @UCharsBuffer[0], UCharsLen, ErrorCode);
          if UErrorCodeSuccess(ErrorCode) then
          begin // 'if UErrorCodeSuccess (步骤 2)' 的 BEGIN 块
            SetLength(TargetBuffer, TargetLen); // 调整目标缓冲区大小
            if Assigned(FLog) then FLog(Format('成功将 %d UChars 转换为 %s (%d 字节)。', [UCharsLen, TargetEncodingName, TargetLen]));
            // 处理 BOM
            if AddBOM then
            begin // 'if AddBOM' 的 BEGIN 块
              try
                // 尝试使用 Delphi 的 TEncoding 获取目标编码的 BOM
                // 注意：如果 Delphi 不识别 ICU 的编码名称，这里可能会失败
                BOMBytes := TEncoding.GetEncoding(TargetEncodingName).GetPreamble;
              except
                // 处理 Delphi 无法识别编码名称的异常
                BOMBytes := [];
                if Assigned(FLog) then FLog(Format('警告：无法通过 TEncoding 获取目标编码 \'%s\' 的 BOM。', [TargetEncodingName]));
              end;
              if Length(BOMBytes) > 0 then
              begin // 'if Length(BOMBytes) > 0' 的 BEGIN 块
                 if Assigned(FLog) then FLog(Format('为 %s 添加 %d 字节的 BOM', [TargetEncodingName, Length(BOMBytes)]));
                 Source := BOMBytes + TargetBuffer; // 将带 BOM 的结果写回 Source (Var 参数)
              end // 'if Length(BOMBytes) > 0' 的 END 块
              else
              begin // 'else (无 BOM)' 的 BEGIN 块
                 Source := TargetBuffer; // 将结果写回 Source (Var 参数)
              end; // 'else (无 BOM)' 的 END 块
            end // 'if AddBOM' 的 END 块
            else
            begin // 'else (AddBOM 为 False)' 的 BEGIN 块
              Source := TargetBuffer; // 将结果写回 Source (Var 参数)
            end; // 'else (AddBOM 为 False)' 的 END 块
            Result := True; // 最终成功!
            Break; // 步骤 2 成功
          end // 'if UErrorCodeSuccess (步骤 2)' 的 END 块
          else if ErrorCode = U_BUFFER_OVERFLOW_ERROR then
          begin // 'else if U_BUFFER_OVERFLOW_ERROR' 的 BEGIN 块
            Inc(RetryCount);
            if RetryCount > 3 then
            begin
              CheckError(Format('ucnv_fromUChars (转换到 %s 时超出重试次数)', [TargetEncodingName]), ErrorCode);
              Break; // 放弃
            end;
            // 容量加倍并重试
            TargetCapacity := TargetCapacity * 2 + 10;
            SetLength(TargetBuffer, TargetCapacity);
            if Assigned(FLog) then FLog(Format('ucnv_fromUChars 缓冲区溢出 (%s)，使用容量 %d 重试', [TargetEncodingName, TargetCapacity]));
          end // 'else if U_BUFFER_OVERFLOW_ERROR' 的 END 块
          else
          begin // 'else (步骤 2 发生其他错误)' 的 BEGIN 块
            CheckError(Format('ucnv_fromUChars (%s)', [TargetEncodingName]), ErrorCode);
            Break; // 转换失败
          end; // 'else (步骤 2 发生其他错误)' 的 END 块
        until False; // 步骤 2 的 repeat 循环结束
      finally // 目标转换器的 FINALLY 块
        if DstConverter <> nil then ucnv_close(DstConverter);
      end; // 目标转换器的 TRY 块结束
    end; // 'if UCharsLen >= 0' 的 END 块
    // 如果步骤 1 失败, Result 保持 False
  finally // 源转换器的 FINALLY 块
    if SrcConverter <> nil then ucnv_close(SrcConverter);
  end; // 源转换器的 TRY 块结束
end; // 函数 ConvertEncoding 结束

end. // 单元结束 