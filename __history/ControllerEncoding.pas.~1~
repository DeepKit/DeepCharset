unit ControllerEncoding;

interface

uses
  System.SysUtils, System.Classes, System.IOUtils, ModelEncoding, UtilsUTF8, 
  Winapi.Windows, UtilsIconv, UtilsTypes, Vcl.StdCtrls;

type
  // TLogMethodRef 定义已移至 UtilsTypes.pas

  // 编码控制器类
  TEncodingController = class
  private
    // iconv库封装器
    FIconvHelper: TIconvHelper;
    FLogMemo: TMemo;
    
    // 内部编码转换辅助函数
    function CheckFileAccessibility(const FileName: string; var UseTemp: Boolean): Boolean;
    procedure CreateBackupFile(const SourceFile: string; var BackupFile: string);
    procedure TryCopyTempToOriginal(const TempFile, OriginalFile: string);
    procedure LogConversionSuccess(const SourceFile: string);
    procedure RestoreFromBackup(const OriginalFile, BackupFile: string);
    procedure Log(const Msg: string);
    
    // 使用iconv进行编码转换
    function ConvertWithIconv(const SourceFile, TargetFile: string;
      const SourceEncoding, TargetEncoding: string; AddBOM: Boolean): Boolean;
    
  public
    constructor Create(ALogMemo: TMemo);
    destructor Destroy; override;
    
    // 判断文件是否在不支持列表中
    function IsUnsupportedFile(const FileName: string): Boolean;
    
    // 检查文件是否有BOM标记
    function HasBOM(const FileName: string): Boolean;
    
    // 检测文件编码 - 使用iconv
    function DetectFileEncoding(const FileName: string): string;
    
    // 转换单个文件编码
    function ConvertFileEncoding(const SourceFile, TargetEncoding: string): Boolean;
      
    // 批量转换文件夹中的文件
    function ConvertFilesToEncoding(const FileList: TStrings; const TargetEncoding: string): Boolean;
      
    // 获取iconv帮助器实例
    function GetIconvHelper: TIconvHelper;
  end;

implementation

constructor TEncodingController.Create(ALogMemo: TMemo);
begin
  inherited Create;
  FIconvHelper := TIconvHelper.Create;
  FLogMemo := ALogMemo;
end;

destructor TEncodingController.Destroy;
begin
  // 释放iconv帮助器
  FIconvHelper.Free;
  
  inherited;
end;

function TEncodingController.IsUnsupportedFile(const FileName: string): Boolean;
const
  UNSUPPORTED_FILES: array[0..4] of string = (
    'desktop.ini', 'thumbs.db', '.ds_store', '.gitignore', '.git'
  );
var
  BaseName: string;
  i: Integer;
begin
  BaseName := ExtractFileName(FileName);
  Result := False;
  
  for i := Low(UNSUPPORTED_FILES) to High(UNSUPPORTED_FILES) do
  begin
    if SameText(BaseName, UNSUPPORTED_FILES[i]) then
    begin
      Result := True;
      Break;
    end;
  end;
end;

function TEncodingController.HasBOM(const FileName: string): Boolean;
var
  Stream: TFileStream;
  Preamble: TBytes;
  DetectedBytes: TBytes;
  i: Integer;
begin
  Result := False;
  
  if not FileExists(FileName) then
    Exit;
    
  try
    Stream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
    try
      Preamble := TEncoding.UTF8.GetPreamble;
      
      if Length(Preamble) = 0 then
        Exit(False);
        
      SetLength(DetectedBytes, Length(Preamble));
      
      if Stream.Size < Length(Preamble) then
        Exit(False);
        
      Stream.ReadBuffer(DetectedBytes[0], Length(Preamble));
      
      // 比较BOM标记
      for i := 0 to High(Preamble) do
      begin
        if Preamble[i] <> DetectedBytes[i] then
          Exit(False);
      end;
      
      Result := True;
    finally
      Stream.Free;
    end;
  except
    // 如果读取失败，假设没有BOM
    Result := False;
  end;
end;

function TEncodingController.DetectFileEncoding(const FileName: string): string;
begin
  // 使用iconv库检测文件编码
  try
    if not FileExists(FileName) then
    begin
      Result := '';
      Exit;
    end;
    
    // 调用iconv的编码检测方法
    Result := FIconvHelper.DetectFileEncoding(FileName);
  except
    Result := '';
  end;
end;

function TEncodingController.ConvertWithIconv(const SourceFile, TargetFile: string;
  const SourceEncoding, TargetEncoding: string; AddBOM: Boolean): Boolean;
var
  SourceContent, TargetContent: TBytes;
  BOM: TBytes;
  BOMStream: TFileStream;
begin
  Result := False;
  
  try
    if not FileExists(SourceFile) then
      Exit;
      
    // 读取源文件内容
    SourceContent := TFile.ReadAllBytes(SourceFile);
    
    // 使用iconv进行编码转换
    if FIconvHelper.ConvertEncoding(SourceContent, SourceEncoding, TargetEncoding, TargetContent) then
    begin
      // 写入目标文件，考虑BOM
      if AddBOM then
      begin
        if TargetEncoding = 'UTF-8' then
          BOM := TEncoding.UTF8.GetPreamble
        else if (TargetEncoding = 'UTF-16LE') or (TargetEncoding = 'UTF-16') then
          BOM := TEncoding.Unicode.GetPreamble
        else if TargetEncoding = 'UTF-16BE' then
          BOM := TEncoding.BigEndianUnicode.GetPreamble
        else
          SetLength(BOM, 0);
          
        if Length(BOM) > 0 then
        begin
          // 先创建文件并写入BOM
          BOMStream := TFileStream.Create(TargetFile, fmCreate);
          try
            BOMStream.WriteBuffer(BOM[0], Length(BOM));
            BOMStream.WriteBuffer(TargetContent[0], Length(TargetContent));
          finally
            BOMStream.Free;
          end;
        end else
          TFile.WriteAllBytes(TargetFile, TargetContent);
      end else
        TFile.WriteAllBytes(TargetFile, TargetContent);
        
      Result := True;
    end;
  except
    Result := False;
  end;
end;

function TEncodingController.ConvertFileEncoding(const SourceFile, TargetEncoding: string): Boolean;
var
  TempFile, BackupFile: string;
  UseTemp: Boolean;
begin
  Result := False;
  BackupFile := '';
  
  // 文件不存在或在不支持列表中
  if not FileExists(SourceFile) or IsUnsupportedFile(SourceFile) then
    Exit;
    
  // 检查输入参数
  if TargetEncoding = '' then
    Exit;
    
  // 检查文件可访问性
  UseTemp := False;
  if not CheckFileAccessibility(SourceFile, UseTemp) then
    Exit;
    
  try
    // 创建临时文件进行转换
    if UseTemp then
    begin
      TempFile := ChangeFileExt(SourceFile, '.tmp');
      CreateBackupFile(SourceFile, BackupFile);
      
      // 使用iconv直接转换文件
      if ConvertWithIconv(SourceFile, TempFile, DetectFileEncoding(SourceFile), TargetEncoding, False) then
      begin
        try
          TryCopyTempToOriginal(TempFile, SourceFile);
          LogConversionSuccess(SourceFile);
          Result := True;
        except
          if (BackupFile <> '') and FileExists(BackupFile) then
            RestoreFromBackup(SourceFile, BackupFile);
        end;
      end;
    end
    else
    begin
      // 不需要临时文件的情况，直接转换
      if ConvertWithIconv(SourceFile, SourceFile, DetectFileEncoding(SourceFile), TargetEncoding, False) then
      begin
        LogConversionSuccess(SourceFile);
        Result := True;
      end;
    end;
  except
    on E: Exception do
    begin
      Log('转换失败: ' + SourceFile + ' - ' + E.Message);
      if (BackupFile <> '') and FileExists(BackupFile) then
        RestoreFromBackup(SourceFile, BackupFile);
    end;
  end;
end;

function TEncodingController.ConvertFilesToEncoding(const FileList: TStrings; const TargetEncoding: string): Boolean;
var
  FilePath: string;
  Total, Count: Integer;
begin
  Result := False;
  
  if not Assigned(FileList) or (FileList.Count = 0) then
    Exit;
    
  Total := FileList.Count;
  Count := 0;
  
  Log('开始批量转换文件，共' + IntToStr(Total) + '个文件');
  
  for FilePath in FileList do
  begin
    Inc(Count);
    Log('处理文件 ' + IntToStr(Count) + '/' + IntToStr(Total) + ': ' + ExtractFileName(FilePath));
    
    if ConvertFileEncoding(FilePath, TargetEncoding) then
      Log('✓ 成功转换: ' + ExtractFileName(FilePath))
    else
      Log('✗ 转换失败: ' + ExtractFileName(FilePath));
  end;
  
  Log('批量转换完成');
  Result := True;
end;

function TEncodingController.GetIconvHelper: TIconvHelper;
begin
  Result := FIconvHelper;
end;

procedure TEncodingController.CreateBackupFile(const SourceFile: string; var BackupFile: string);
begin
  try
    BackupFile := ChangeFileExt(SourceFile, '.bak');
    if FileExists(BackupFile) then
      DeleteFile(PChar(BackupFile));
    TFile.Copy(SourceFile, BackupFile);
  except
    BackupFile := '';
    Log('警告: 无法创建备份文件: ' + SourceFile);
  end;
end;

procedure TEncodingController.TryCopyTempToOriginal(const TempFile, OriginalFile: string);
var
  RetryCount: Integer;
begin
  RetryCount := 0;
  while RetryCount < 3 do
  begin
    try
      if FileExists(TempFile) then
      begin
        if FileExists(OriginalFile) then
          DeleteFile(PChar(OriginalFile));
        TFile.Copy(TempFile, OriginalFile, True);
        DeleteFile(PChar(TempFile));
        Break;
      end;
    except
      Inc(RetryCount);
      Sleep(100);
      if RetryCount >= 3 then
        raise;
    end;
  end;
end;

procedure TEncodingController.LogConversionSuccess(const SourceFile: string);
begin
  Log('✓ 成功转换: ' + ExtractFileName(SourceFile));
end;

procedure TEncodingController.RestoreFromBackup(const OriginalFile, BackupFile: string);
begin
  try
    if FileExists(BackupFile) then
    begin
      if FileExists(OriginalFile) then
        DeleteFile(PChar(OriginalFile));
      TFile.Copy(BackupFile, OriginalFile, True);
      DeleteFile(PChar(BackupFile));
      Log('已从备份还原: ' + OriginalFile);
    end;
  except
    Log('无法从备份还原: ' + OriginalFile);
  end;
end;

function TEncodingController.CheckFileAccessibility(const FileName: string; var UseTemp: Boolean): Boolean;
var
  FileHandle: THandle;
begin
  Result := False;
  UseTemp := False;
  
  try
    // 尝试以独占方式打开文件
    FileHandle := CreateFile(PChar(FileName), GENERIC_READ or GENERIC_WRITE,
      0, nil, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, 0);
      
    if FileHandle <> INVALID_HANDLE_VALUE then
    begin
      CloseHandle(FileHandle);
      Result := True;
    end
    else
    begin
      // 如果独占访问失败，尝试共享访问
      FileHandle := CreateFile(PChar(FileName), GENERIC_READ,
        FILE_SHARE_READ or FILE_SHARE_WRITE, nil, OPEN_EXISTING,
        FILE_ATTRIBUTE_NORMAL, 0);
        
      if FileHandle <> INVALID_HANDLE_VALUE then
      begin
        CloseHandle(FileHandle);
        UseTemp := True;  // 需要使用临时文件
        Result := True;
      end;
    end;
  except
    Result := False;
  end;
end;

procedure TEncodingController.Log(const Msg: string);
begin
  if Assigned(FLogMemo) then
    FLogMemo.Lines.Add(Format('[%s] %s', [FormatDateTime('yyyy-mm-dd hh:nn:ss', Now), Msg]));
end;

end. 