end;

procedure TForm1.btnConvertClick(Sender: TObject);
var
  i: Integer;
  FilePath: string;
  SelectedFiles: TStringList;
begin
  SelectedFiles := TStringList.Create;
  try
    // 收集选中的文件
    for i := 1 to StringGrid1.RowCount - 1 do
    begin
      if StringGrid1.Cells[0, i] = 'X' then
      begin
        FilePath := IncludeTrailingPathDelimiter(FSelectedFolder) + StringGrid1.Cells[1, i];
        SelectedFiles.Add(FilePath);
      end;
    end;

    // 检查是否有选中的文件
    if SelectedFiles.Count = 0 then
    begin
      ShowLocalizedMessage('MsgNoFilesSelected');
      Exit;
    end;

    // 检查是否选择了目标编码
    if not Assigned(TreeViewEncodings.Selected) or not Assigned(TreeViewEncodings.Selected.Data) then
    begin
      ShowLocalizedMessage('MsgSelectTargetEncoding');
      Exit;
    end;

    // 开始转换
    Screen.Cursor := crHourGlass;
    try
      StartLogBuffering;
      try
        for i := 0 to SelectedFiles.Count - 1 do
        begin
          if FEncodingController.ConvertFileEncoding(SelectedFiles[i], TEncodingInfo(TreeViewEncodings.Selected.Data)) then
            UpdateSingleFileInGrid(SelectedFiles[i]);
        end;
      finally
        EndLogBuffering;
      end;
    finally
      Screen.Cursor := crDefault;
    end;

    ShowLocalizedMessageFmt('MsgConversionComplete', [SelectedFiles.Count]);
  finally
    SelectedFiles.Free;
  end;
end;

procedure TForm1.btnRefreshClick(Sender: TObject);
begin
  if System.SysUtils.DirectoryExists(DirectoryListBox1.Directory) then
  begin
    UpdateFileGrid(DirectoryListBox1.Directory);
    Log('已刷新目录: ' + DirectoryListBox1.Directory);
  end;
end;

procedure TForm1.btnSingleFileClick(Sender: TObject);
var
  OpenDialog: TOpenDialog;
  TargetEncoding: TEncodingInfo;
begin
  // 检查是否选择了目标编码
  if not Assigned(TreeViewEncodings.Selected) or not Assigned(TreeViewEncodings.Selected.Data) then
  begin
    ShowLocalizedMessage('MsgSelectTargetEncoding');
    Exit;
  end;

  OpenDialog := TOpenDialog.Create(nil);
  try
    OpenDialog.Title := GetLocalizedMessage('DialogSelectFile');
    OpenDialog.Filter := GetLocalizedMessage('DialogFileFilter');
    
    if OpenDialog.Execute then
    begin
      Screen.Cursor := crHourGlass;
      try
        TargetEncoding := TEncodingInfo(TreeViewEncodings.Selected.Data);
        
        StartLogBuffering;
        try
          if FEncodingController.ConvertFileEncoding(OpenDialog.FileName, TargetEncoding) then
          begin
            ShowLocalizedMessage('MsgConversionSuccess');
            // 如果文件在当前目录中，更新其在网格中的显示
            if ExtractFilePath(OpenDialog.FileName) = FSelectedFolder then
              UpdateSingleFileInGrid(OpenDialog.FileName);
          end;
        finally
          EndLogBuffering;
        end;
      finally
        Screen.Cursor := crDefault;
      end;
    end;
  finally
    OpenDialog.Free;
  end;
end;


