unit ViewSynEdit;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes,
  Vcl.Graphics, Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, System.IOUtils,
  Vcl.ExtCtrls, Vcl.ComCtrls, Vcl.Buttons, Vcl.Menus, System.UITypes, Vcl.Clipbrd;

type
  TSynEditForm = class(TForm)
    PanelTop: TPanel;
    LabelFileName: TLabel;
    LabelEncoding: TLabel;
    LabelFileSize: TLabel;
    SynEdit: TRichEdit;
    PanelButtons: TPanel;
    btnClose: TButton;
    btnCopy: TButton;
    btnWordWrap: TButton;
    StatusBar: TStatusBar;
    PopupMenu: TPopupMenu;
    MenuItemCopy: TMenuItem;
    MenuItemSelectAll: TMenuItem;
    N1: TMenuItem;
    MenuItemWordWrap: TMenuItem;
    procedure FormKeyDown(Sender: TObject; var Key: Word; Shift: TShiftState);
    procedure btnCloseClick(Sender: TObject);
    procedure btnCopyClick(Sender: TObject);
    procedure btnWordWrapClick(Sender: TObject);
    procedure MenuItemCopyClick(Sender: TObject);
    procedure MenuItemSelectAllClick(Sender: TObject);
    procedure MenuItemWordWrapClick(Sender: TObject);
    procedure FormResize(Sender: TObject);
  private
    FFileName: string;
    FEncodingName: string;
    FHasBOM: Boolean;
    FLineCount: Integer;
    FCharCount: Integer;

    procedure UpdateStatusBar;
    procedure UpdateEncodingInfo(const EncodingName: string; HasBOM: Boolean);
    function IsBinaryFile(const FileName: string): Boolean;
    function DetectFileEncoding(const FileName: string): TEncoding;
  public
    procedure LoadFile(const FileName: string);
    procedure LoadFileWithEncoding(const FileName: string; Encoding: TEncoding;
      const DetectedEncoding: string; HasBOM: Boolean);
    procedure SetFileInfo(const FileName, EncodingName: string; HasBOM: Boolean);
  end;

var
  SynEditForm: TSynEditForm;

implementation

{$R *.dfm}

function TSynEditForm.IsBinaryFile(const FileName: string): Boolean;
var
  FileStream: TFileStream;
  Buffer: array[0..1023] of Byte;
  BytesRead: Integer;
  I: Integer;
begin
  Result := False;
  if not FileExists(FileName) then
    Exit;

  try
    FileStream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyWrite);
    try
      BytesRead := FileStream.Read(Buffer, SizeOf(Buffer));

      // 检查前1024字节中是否包含二进制字符
      for I := 0 to BytesRead - 1 do
      begin
        // 如果包含控制字符（除了常见的文本控制字符）
        if (Buffer[I] < 32) and not (Buffer[I] in [9, 10, 13]) then
        begin
          Result := True;
          Break;
        end;
      end;
    finally
      FileStream.Free;
    end;
  except
    Result := True; // 如果读取失败，假设是二进制文件
  end;
end;

function TSynEditForm.DetectFileEncoding(const FileName: string): TEncoding;
var
  FileStream: TFileStream;
  BOM: TBytes;
begin
  Result := TEncoding.UTF8; // 默认使用UTF-8
  FHasBOM := False;

  if not FileExists(FileName) then
    Exit;

  try
    FileStream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyWrite);
    try
      if FileStream.Size >= 3 then
      begin
        SetLength(BOM, 3);
        FileStream.Read(BOM[0], 3);

        // 检查UTF-8 BOM
        if (BOM[0] = $EF) and (BOM[1] = $BB) and (BOM[2] = $BF) then
        begin
          Result := TEncoding.UTF8;
          FHasBOM := True;
          Exit;
        end;

        // 检查UTF-16 LE BOM
        if (BOM[0] = $FF) and (BOM[1] = $FE) then
        begin
          Result := TEncoding.Unicode;
          FHasBOM := True;
          Exit;
        end;

        // 检查UTF-16 BE BOM
        if (BOM[0] = $FE) and (BOM[1] = $FF) then
        begin
          Result := TEncoding.BigEndianUnicode;
          FHasBOM := True;
          Exit;
        end;
      end;
    finally
      FileStream.Free;
    end;
  except
    // 忽略错误
  end;
end;

procedure TSynEditForm.FormKeyDown(Sender: TObject; var Key: Word; Shift: TShiftState);
begin
  // ESC关闭窗口
  if Key = VK_ESCAPE then
    Close;

  // Ctrl+A 全选
  if (Key = Ord('A')) and (ssCtrl in Shift) then
  begin
    SynEdit.SelectAll;
    Key := 0;
  end;

  // Ctrl+C 复制
  if (Key = Ord('C')) and (ssCtrl in Shift) then
  begin
    if SynEdit.SelLength > 0 then
      Clipboard.AsText := SynEdit.SelText;
    Key := 0;
  end;
end;

procedure TSynEditForm.FormResize(Sender: TObject);
begin
  // 窗体大小调整时的处理（设计时控件会自动调整）
end;

procedure TSynEditForm.LoadFile(const FileName: string);
var
  FileStream: TFileStream;
  Buffer: TBytes;
  Content: string;
  Encoding: TEncoding;
begin
  if not FileExists(FileName) then
    raise Exception.CreateFmt('文件不存在: %s', [FileName]);

  // 检查是否为二进制文件
  if IsBinaryFile(FileName) then
  begin
    MessageDlg('此文件是二进制文件，无法显示文本内容。', mtWarning, [mbOK], 0);
    Exit;
  end;

  try
    FFileName := FileName;

    // 检测文件编码
    Encoding := DetectFileEncoding(FileName);

    // 读取文件内容
    FileStream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyWrite);
    try
      SetLength(Buffer, FileStream.Size);
      if FileStream.Size > 0 then
        FileStream.ReadBuffer(Buffer[0], FileStream.Size);

      // 使用检测到的编码解码
      Content := Encoding.GetString(Buffer);

      // 如果有BOM，移除BOM字符
      if FHasBOM and (Length(Content) > 0) and (Content[1] = #$FEFF) then
        Content := Copy(Content, 2, Length(Content) - 1);

      // 设置到RichEdit
      SynEdit.Text := Content;
    finally
      FileStream.Free;
    end;

    // 更新文件信息
    SetFileInfo(FileName, Encoding.EncodingName, FHasBOM);

    // 更新行数和字符数
    FLineCount := SynEdit.Lines.Count;
    FCharCount := Length(SynEdit.Text);
    UpdateStatusBar;
  except
    on E: Exception do
      raise Exception.CreateFmt('无法加载文件 %s: %s', [FileName, E.Message]);
  end;
end;

procedure TSynEditForm.LoadFileWithEncoding(const FileName: string; Encoding: TEncoding;
  const DetectedEncoding: string; HasBOM: Boolean);
var
  FileStream: TFileStream;
  Buffer: TBytes;
  Content: string;
begin
  if not FileExists(FileName) then
    raise Exception.CreateFmt('文件不存在: %s', [FileName]);

  // 检查是否为二进制文件
  if IsBinaryFile(FileName) then
  begin
    MessageDlg('此文件是二进制文件，无法显示文本内容。', mtWarning, [mbOK], 0);
    Exit;
  end;

  try
    FFileName := FileName;
    FEncodingName := DetectedEncoding;
    FHasBOM := HasBOM;

    // 使用指定的编码读取文件
    FileStream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyWrite);
    try
      SetLength(Buffer, FileStream.Size);
      if FileStream.Size > 0 then
        FileStream.ReadBuffer(Buffer[0], FileStream.Size);

      // 使用传入的编码解码
      if Encoding <> nil then
        Content := Encoding.GetString(Buffer)
      else
        Content := TEncoding.UTF8.GetString(Buffer);

      // 如果有BOM，移除BOM字符
      if HasBOM and (Length(Content) > 0) and (Content[1] = #$FEFF) then
        Content := Copy(Content, 2, Length(Content) - 1);

      // 设置到RichEdit
      SynEdit.Text := Content;
    finally
      FileStream.Free;
    end;

    // 设置文件信息
    SetFileInfo(FileName, DetectedEncoding, HasBOM);

    // 更新行数和字符数
    FLineCount := SynEdit.Lines.Count;
    FCharCount := Length(SynEdit.Text);
    UpdateStatusBar;
  except
    on E: Exception do
      raise Exception.CreateFmt('无法加载文件 %s: %s', [FileName, E.Message]);
  end;
end;

procedure TSynEditForm.MenuItemCopyClick(Sender: TObject);
begin
  btnCopyClick(Sender);
end;

procedure TSynEditForm.MenuItemSelectAllClick(Sender: TObject);
begin
  SynEdit.SelectAll;
end;

procedure TSynEditForm.MenuItemWordWrapClick(Sender: TObject);
begin
  btnWordWrapClick(Sender);
  MenuItemWordWrap.Checked := SynEdit.WordWrap;
end;

procedure TSynEditForm.SetFileInfo(const FileName, EncodingName: string; HasBOM: Boolean);
var
  FileSize: Int64;
begin
  try
    FileSize := TFile.GetSize(FileName);

    // 更新窗体标题
    Caption := Format('文件查看器 - %s', [ExtractFileName(FileName)]);

    // 更新文件信息标签
    LabelFileName.Caption := Format('文件名: %s', [ExtractFileName(FileName)]);
    LabelFileSize.Caption := Format('文件大小: %.2f KB (%d 字节)', [FileSize / 1024, FileSize]);

    // 更新编码信息
    UpdateEncodingInfo(EncodingName, HasBOM);
  except
    // 忽略错误
    Caption := Format('文件查看器 - %s', [ExtractFileName(FileName)]);
    LabelFileName.Caption := Format('文件名: %s', [ExtractFileName(FileName)]);
    LabelFileSize.Caption := '文件大小: 未知';
    UpdateEncodingInfo(EncodingName, HasBOM);
  end;
end;

procedure TSynEditForm.UpdateEncodingInfo(const EncodingName: string; HasBOM: Boolean);
begin
  FEncodingName := EncodingName;
  FHasBOM := HasBOM;

  if HasBOM then
    LabelEncoding.Caption := Format('编码: %s (带BOM)', [EncodingName])
  else
    LabelEncoding.Caption := Format('编码: %s', [EncodingName]);
end;

procedure TSynEditForm.UpdateStatusBar;
begin
  // 更新状态栏信息
  StatusBar.Panels[0].Text := Format('行数: %d', [FLineCount]);
  StatusBar.Panels[1].Text := Format('字符数: %d', [FCharCount]);

  // 更新光标位置
  if SynEdit.SelStart >= 0 then
  begin
    var Line, Col: Integer;
    Line := SendMessage(SynEdit.Handle, EM_LINEFROMCHAR, SynEdit.SelStart, 0) + 1;
    Col := SynEdit.SelStart - SendMessage(SynEdit.Handle, EM_LINEINDEX, Line - 1, 0) + 1;
    StatusBar.Panels[2].Text := Format('行: %d, 列: %d', [Line, Col]);
  end
  else
    StatusBar.Panels[2].Text := '';
end;

procedure TSynEditForm.btnCloseClick(Sender: TObject);
begin
  Close;
end;

procedure TSynEditForm.btnCopyClick(Sender: TObject);
begin
  if SynEdit.SelLength > 0 then
    Clipboard.AsText := SynEdit.SelText
  else
    Clipboard.AsText := SynEdit.Text;
end;

procedure TSynEditForm.btnWordWrapClick(Sender: TObject);
begin
  SynEdit.WordWrap := not SynEdit.WordWrap;

  if SynEdit.WordWrap then
  begin
    SynEdit.ScrollBars := ssVertical;
    btnWordWrap.Caption := '关闭换行';
  end
  else
  begin
    SynEdit.ScrollBars := ssBoth;
    btnWordWrap.Caption := '自动换行';
  end;

  // 更新菜单项状态
  if Assigned(MenuItemWordWrap) then
    MenuItemWordWrap.Checked := SynEdit.WordWrap;
end;

end.
