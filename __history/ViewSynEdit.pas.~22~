unit ViewSynEdit;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes,
  Vcl.Graphics, Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ExtCtrls, Vcl.StdCtrls,
  System.IOUtils, System.Generics.Collections, System.Math, System.StrUtils,
  SynEdit, SynEditHighlighter, SynHighlighterPas, SynHighlighterCpp, SynHighlighterCss, SynHighlighterJava,
  SynHighlighterJScript, SynHighlighterHTML, SynHighlighterXML, SynHighlighterSQL,
  SynHighlighterPython, SynHighlighterPHP, SynHighlighterIni, SynHighlighterPerl,
  SynHighlighterVB, SynHighlighterAsm,  SynHighlighterRuby,
   SynHighlighterJSON, SynHighlighterBat, SynEditCodeFolding;

type
  TSynEditForm = class(TForm)
    SynEdit: TSynEdit;
    Panel1: TPanel;
    lblFileName: TLabel;
    lblEncoding: TLabel;
    lblBOM: TLabel;
    SynPasSyn1: TSynPasSyn;
    SynCppSyn1: TSynCppSyn;
    SynCSSyn1: TSynCssSyn;
    SynJavaSyn1: TSynJavaSyn;
    SynJScriptSyn1: TSynJScriptSyn;
    SynHTMLSyn1: TSynHTMLSyn;
    SynXMLSyn1: TSynXMLSyn;
    SynSQLSyn1: TSynSQLSyn;
    SynPythonSyn1: TSynPythonSyn;
    SynPHPSyn1: TSynPHPSyn;
    SynIniSyn1: TSynIniSyn;
    SynPerlSyn1: TSynPerlSyn;
    SynVBSyn1: TSynVBSyn;
    SynAsmSyn1: TSynAsmSyn;
    SynRubySyn1: TSynRubySyn;
    SynJSONSyn1: TSynJSONSyn;
    SynBatSyn1: TSynBatSyn;
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure FormKeyDown(Sender: TObject; var Key: Word; Shift: TShiftState);
  private
    FHighlighter: TSynCustomHighlighter;
    procedure CreateHighlighter(const HighlighterClass: TSynCustomHighlighterClass);
    procedure ApplyHighlighter(const FileName: string);
    procedure LogMessage(const Msg: string);
  public
    procedure LoadFile(const FileName: string; Encoding: TEncoding = nil);
    procedure SetFileInfo(const FileName, DetectedEncoding: string; HasBOM: Boolean);
  end;

var
  SynEditForm: TSynEditForm;

implementation

{$R *.dfm}

procedure TSynEditForm.FormCreate(Sender: TObject);
var
  LogCallback: TProc<string>;
begin
  // 设置窗体属性
  Position := poDefaultPosOnly; // 使窗体位置由代码控制
  FormStyle := fsStayOnTop;     // 保持在其他窗体之上
  KeyPreview := True;           // 允许窗体接收所有键盘事件
  
  // 设置SynEdit的属性
  SynEdit.Font.Name := 'Consolas';
  SynEdit.Font.Size := 10;
  SynEdit.ScrollBars := ssBoth;
  SynEdit.WordWrap := False;
  SynEdit.ReadOnly := True;
  SynEdit.Gutter.ShowLineNumbers := True;
  SynEdit.UseCodeFolding := True;
  
  // 初始化高亮器组件
  SynPasSyn1 := TSynPasSyn.Create(Self);
  SynCppSyn1 := TSynCppSyn.Create(Self);
  SynCSSyn1 := TSynCssSyn.Create(Self);
  SynJavaSyn1 := TSynJavaSyn.Create(Self);
  SynJScriptSyn1 := TSynJScriptSyn.Create(Self);
  SynHTMLSyn1 := TSynHTMLSyn.Create(Self);
  SynXMLSyn1 := TSynXMLSyn.Create(Self);
  SynSQLSyn1 := TSynSQLSyn.Create(Self);
  SynPythonSyn1 := TSynPythonSyn.Create(Self);
  SynPHPSyn1 := TSynPHPSyn.Create(Self);
  SynIniSyn1 := TSynIniSyn.Create(Self);
  SynPerlSyn1 := TSynPerlSyn.Create(Self);
  SynVBSyn1 := TSynVBSyn.Create(Self);
  SynAsmSyn1 := TSynAsmSyn.Create(Self);
  SynRubySyn1 := TSynRubySyn.Create(Self);
  SynJSONSyn1 := TSynJSONSyn.Create(Self);
  SynBatSyn1 := TSynBatSyn.Create(Self);
end;

procedure TSynEditForm.FormDestroy(Sender: TObject);
begin
  FHighlighter.Free;
end;

procedure TSynEditForm.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  // 设置关闭时的行为
  Action := caHide; // 隐藏而非释放，因为我们使用全局变量SynEditForm
end;

procedure TSynEditForm.FormKeyDown(Sender: TObject; var Key: Word; Shift: TShiftState);
begin
  // Esc键关闭窗体
  if Key = VK_ESCAPE then
  begin
    Close;
    Key := 0;
  end
  // Ctrl++/Ctrl+= 增大字体
  else if ((Key = 187) or (Key = 107) or (Key = VK_ADD)) and (ssCtrl in Shift) then
  begin
    SynEdit.Font.Size := SynEdit.Font.Size + 1;
    Key := 0;
  end
  // Ctrl+- 减小字体
  else if ((Key = 189) or (Key = 109) or (Key = VK_SUBTRACT)) and (ssCtrl in Shift) then
  begin
    if SynEdit.Font.Size > 8 then
    begin
      SynEdit.Font.Size := SynEdit.Font.Size - 1;
    end;
    Key := 0;
  end
  // Ctrl+0 恢复默认字体大小
  else if ((Key = Ord('0')) or (Key = VK_NUMPAD0)) and (ssCtrl in Shift) then
  begin
    SynEdit.Font.Size := 10; // 恢复默认大小
    Key := 0;
  end;
end;

procedure TSynEditForm.CreateHighlighter(const HighlighterClass: TSynCustomHighlighterClass);
begin
  // 先释放旧的高亮器
  if Assigned(FHighlighter) then
  begin
    SynEdit.Highlighter := nil; // 先清除SynEdit的引用
    FreeAndNil(FHighlighter);
  end;
  
  // 创建新的高亮器
  if Assigned(HighlighterClass) then
  begin
    try
      FHighlighter := HighlighterClass.Create(nil);
      SynEdit.Highlighter := FHighlighter;
    except
      on E: Exception do
      begin
        LogMessage('创建高亮器失败: ' + E.Message);
        FHighlighter := nil;
      end;
    end;
  end
  else
  begin
    SynEdit.Highlighter := nil;
    FHighlighter := nil;
  end;
  
  // 确保立即重绘
  SynEdit.Invalidate;
end;

procedure TSynEditForm.ApplyHighlighter(const FileName: string);
var
  Ext: string;
begin
  Ext := LowerCase(ExtractFileExt(FileName));
  
  // 根据文件扩展名应用适当的语法高亮器
  if (Ext = '.pas') or (Ext = '.dpr') or (Ext = '.dpk') then
  begin
    CreateHighlighter(TSynPasSyn);
  end
  else if (Ext = '.cpp') or (Ext = '.h') or (Ext = '.hpp') or (Ext = '.c') then
  begin
    CreateHighlighter(TSynCppSyn);
  end
  else if (Ext = '.css') then
  begin
    CreateHighlighter(TSynCssSyn);
  end
  else if (Ext = '.java') then
  begin
    CreateHighlighter(TSynJavaSyn);
  end
  else if (Ext = '.js') then
  begin
    CreateHighlighter(TSynJScriptSyn);
  end
  else if (Ext = '.html') or (Ext = '.htm') then
  begin
    CreateHighlighter(TSynHTMLSyn);
  end
  else if (Ext = '.xml') or (Ext = '.xsd') or (Ext = '.xsl') or (Ext = '.xslt') then
  begin
    CreateHighlighter(TSynXMLSyn);
  end
  else if (Ext = '.sql') then
  begin
    CreateHighlighter(TSynSQLSyn);
  end
  else if (Ext = '.py') then
  begin
    CreateHighlighter(TSynPythonSyn);
  end
  else if (Ext = '.php') then
  begin
    CreateHighlighter(TSynPHPSyn);
  end
  else if (Ext = '.ini') or (Ext = '.inf') then
  begin
    CreateHighlighter(TSynIniSyn);
  end
  else if (Ext = '.pl') or (Ext = '.pm') then
  begin
    CreateHighlighter(TSynPerlSyn);
  end
  else if (Ext = '.vb') then
  begin
    CreateHighlighter(TSynVBSyn);
  end
  else if (Ext = '.asm') then
  begin
    CreateHighlighter(TSynAsmSyn);
  end
  else if (Ext = '.rb') then
  begin
    CreateHighlighter(TSynRubySyn);
  end
  else if (Ext = '.lua') then
  begin
    CreateHighlighter(TSynLuaSyn);
  end
  else if (Ext = '.json') then
  begin
    CreateHighlighter(TSynJSONSyn);
  end
  else if (Ext = '.bat') or (Ext = '.cmd') then
  begin
    CreateHighlighter(TSynBatSyn);
  end
  else
  begin
    CreateHighlighter(nil); // 未知文件类型，不使用高亮
  end;
end;

procedure TSynEditForm.LogMessage(const Msg: string);
begin
  // 使用更安全的方式记录日志，避免调用OutputDebugString可能引起的问题
  {$IFDEF DEBUG}
  // 仅在调试模式下输出到控制台
  WriteLn('[SynEdit] ' + Msg);
  {$ENDIF}
end;

procedure TSynEditForm.LoadFile(const FileName: string; Encoding: TEncoding = nil);
begin
  try
    // 直接使用SynEdit的Lines加载文件，简单可靠
    if Assigned(Encoding) then
      SynEdit.Lines.LoadFromFile(FileName, Encoding)
    else
      SynEdit.Lines.LoadFromFile(FileName);
    
    // 设置窗体标题
    Caption := ExtractFileName(FileName);
    
    // 首先清除现有高亮器
    SynEdit.Highlighter := nil;
    
    // 应用语法高亮
    ApplyHighlighter(FileName);
    
  except
    on E: Exception do
    begin
      SynEdit.Text := '无法打开文件: ' + E.Message;
    end;
  end;
end;

procedure TSynEditForm.SetFileInfo(const FileName, DetectedEncoding: string; HasBOM: Boolean);
var
  BOMStr: string;
begin
  // 更新文件信息标签
  lblFileName.Caption := 'File: ' + ExtractFileName(FileName);
  lblEncoding.Caption := 'Encoding: ' + DetectedEncoding;
  
  if HasBOM then
    BOMStr := 'Yes'
  else
    BOMStr := 'No';
    
  lblBOM.Caption := 'BOM: ' + BOMStr;
end;

end.
