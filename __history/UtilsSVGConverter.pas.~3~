unit UtilsSVGConverter;

interface

uses
  System.SysUtils, System.Classes, Vcl.Graphics, Vcl.Imaging.pngimage,
  Vcl.Imaging.jpeg, Vcl.Imaging.GIFImg, System.Types, System.IOUtils,
  System.UITypes, Winapi.Windows, Vcl.Forms, Vcl.Controls, Vcl.Dialogs,
  // Skia相关单元
  Skia, Skia.Vcl;

type
  // 定义支持的图像格式枚举
  TSVGOutputFormat = (sofICO, sofPNG, sofJPG, sofBMP, sofGIF, sofTIFF, sofWebP);

  // SVG转换类
  TSVGConverter = class
  private
    FSVGFilePath: string;
    FOutputPath: string;
    FWidth: Integer;
    FHeight: Integer;
    FFormat: TSVGOutputFormat;
    FOnProgress: TProc<string>;
    FOnError: TProc<string>;
    FOnSuccess: TProc<string>;
    
    // 获取格式扩展名
    function GetFormatExtension: string;
    // 获取格式名称
    function GetFormatName: string;
    // 转换为ICO格式
    function ConvertToICO: Boolean;
    // 转换为通用图像格式
    function ConvertToImageFormat: Boolean;
  public
    constructor Create;
    destructor Destroy; override;
    
    // 执行转换
    function Convert: Boolean;
    
    // 获取支持的格式名称数组
    class function GetSupportedFormats: TArray<string>;
    
    // 属性
    property SVGFilePath: string read FSVGFilePath write FSVGFilePath;
    property OutputPath: string read FOutputPath write FOutputPath;
    property Width: Integer read FWidth write FWidth;
    property Height: Integer read FHeight write FHeight;
    property Format: TSVGOutputFormat read FFormat write FFormat;
    
    // 事件回调
    property OnProgress: TProc<string> read FOnProgress write FOnProgress;
    property OnError: TProc<string> read FOnError write FOnError;
    property OnSuccess: TProc<string> read FOnSuccess write FOnSuccess;
  end;

  // 辅助函数 - 将SVG文件加载到组件中
  procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);

  // 辅助函数 - 生成合适的输出路径
  function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;

// 声明ICO文件相关的数据结构
type
  {$ALIGN 2}
  TIconDir = packed record
    idReserved: Word;    // 保留，必须为0
    idType: Word;        // 资源类型，1表示图标
    idCount: Word;       // 图像数量
  end;

  TIconDirEntry = packed record
    bWidth: Byte;          // 图像宽度
    bHeight: Byte;         // 图像高度
    bColorCount: Byte;     // 调色板颜色数量，如果是真彩色，则为0
    bReserved: Byte;       // 保留字段，必须为0
    wPlanes: Word;         // 颜色平面数
    wBitCount: Word;       // 每个像素的位数
    dwBytesInRes: DWORD;   // 图像数据的字节数
    dwImageOffset: DWORD;  // 图像数据在文件中的偏移量
  end;
  {$ALIGN ON}

implementation

{ TSVGConverter }

constructor TSVGConverter.Create;
begin
  inherited Create;
  FWidth := 256;
  FHeight := 256;
  FFormat := sofPNG;
end;

destructor TSVGConverter.Destroy;
begin
  inherited;
end;

function TSVGConverter.GetFormatExtension: string;
begin
  case FFormat of
    sofICO: Result := '.ico';
    sofPNG: Result := '.png';
    sofJPG: Result := '.jpg';
    sofBMP: Result := '.bmp';
    sofGIF: Result := '.gif';
    sofTIFF: Result := '.tiff';
    sofWebP: Result := '.webp';
    else Result := '.png';
  end;
end;

function TSVGConverter.GetFormatName: string;
begin
  case FFormat of
    sofICO: Result := 'ICO';
    sofPNG: Result := 'PNG';
    sofJPG: Result := 'JPG';
    sofBMP: Result := 'BMP';
    sofGIF: Result := 'GIF';
    sofTIFF: Result := 'TIFF';
    sofWebP: Result := 'WebP';
    else Result := 'PNG';
  end;
end;

function TSVGConverter.ConvertToICO: Boolean;
var
  Stream: TMemoryStream;
  IconCount: Word;
  IconDir: array of TIconDirEntry;
  IconDirHeader: TIconDir;
  I, DataOffset: Integer;
  SVG: TSkSvg;
  SVGBrush: TSkSvgBrush;
  Bitmap: TBitmap;
  Size: TSize;
  IconImageSize: Integer;
  PNG: TPngImage;
  IconSizes: TArray<TSize>;
begin
  Result := False;
  
  // 定义ICO文件中的图标尺寸
  SetLength(IconSizes, 4);
  IconSizes[0] := TSize.Create(16, 16);
  IconSizes[1] := TSize.Create(32, 32);
  IconSizes[2] := TSize.Create(48, 48);
  IconSizes[3] := TSize.Create(64, 64);
  
  Stream := TMemoryStream.Create;
  try
    IconCount := Length(IconSizes);
    
    // 设置图标目录头
    FillChar(IconDirHeader, SizeOf(IconDirHeader), 0);
    IconDirHeader.idReserved := 0;
    IconDirHeader.idType := 1;
    IconDirHeader.idCount := IconCount;
    Stream.Write(IconDirHeader, SizeOf(IconDirHeader));
    
    // 设置图标目录项
    SetLength(IconDir, IconCount);
    DataOffset := SizeOf(IconDirHeader) + IconCount * SizeOf(TIconDirEntry);
    
    // 加载SVG
    if Assigned(FOnProgress) then
      FOnProgress('正在加载SVG文件...');
    
    // 创建SVG组件并加载内容  
    SVG := TSkSvg.Create(nil);
    try
      SVGBrush := TSkSvgBrush.Create;
      try
        // 加载SVG内容
        SVGBrush.Source := TFile.ReadAllText(FSVGFilePath);
        
        // 处理每个图标尺寸
        for I := 0 to IconCount - 1 do
        begin
          Size := IconSizes[I];
          
          if Assigned(FOnProgress) then
            FOnProgress(Format('正在处理 %dx%d 图标...', [Size.Width, Size.Height]));
          
          // 创建位图并设置大小
          Bitmap := TBitmap.Create;
          try
            Bitmap.PixelFormat := pf32bit;
            Bitmap.Width := Size.Width;
            Bitmap.Height := Size.Height;
            Bitmap.Canvas.Brush.Color := clWhite;
            Bitmap.Canvas.FillRect(Rect(0, 0, Size.Width, Size.Height));
            
            // 绘制SVG到位图
            SVGBrush.Render(Bitmap.Canvas, RectF(0, 0, Size.Width, Size.Height));
            
            // 转为PNG格式
            PNG := TPngImage.Create;
            try
              PNG.Assign(Bitmap);
              
              // 保存PNG数据到内存流
              IconImageSize := Stream.Position;
              PNG.SaveToStream(Stream);
              IconImageSize := Stream.Position - IconImageSize;
              
              // 填写图标目录项
              IconDir[I].bWidth := Byte(Size.Width);
              IconDir[I].bHeight := Byte(Size.Height);
              IconDir[I].bColorCount := 0;
              IconDir[I].bReserved := 0;
              IconDir[I].wPlanes := 1;
              IconDir[I].wBitCount := 32;
              IconDir[I].dwBytesInRes := IconImageSize;
              IconDir[I].dwImageOffset := DataOffset;
              
              // 更新下一个图标的数据偏移量
              DataOffset := DataOffset + IconImageSize;
            finally
              PNG.Free;
            end;
          finally
            Bitmap.Free;
          end;
        end;
        
        // 写入图标目录项
        Stream.Position := SizeOf(IconDirHeader);
        for I := 0 to IconCount - 1 do
          Stream.Write(IconDir[I], SizeOf(TIconDirEntry));
        
        // 保存到文件
        Stream.SaveToFile(FOutputPath);
        Result := True;
        
        if Assigned(FOnSuccess) then
          FOnSuccess('ICO文件创建成功: ' + FOutputPath);
      finally
        SVGBrush.Free;
      end;
    finally
      SVG.Free;
    end;
  finally
    Stream.Free;
  end;
end;

function TSVGConverter.ConvertToImageFormat: Boolean;
var
  SVG: TSkSvg;
  SVGBrush: TSkSvgBrush;
  Bitmap, TempBitmap: TBitmap;
  PngImage: TPngImage;
  JpgImage: TJPEGImage;
  GifImage: TGIFImage;
  FormatName: string;
begin
  Result := False;
  
  // 加载SVG
  if Assigned(FOnProgress) then
    FOnProgress('正在加载SVG文件...');
  
  SVG := TSkSvg.Create(nil);
  try
    SVGBrush := TSkSvgBrush.Create;
    try
      // 加载SVG内容
      SVGBrush.Source := TFile.ReadAllText(FSVGFilePath);
      
      // 创建位图
      if Assigned(FOnProgress) then
        FOnProgress('正在渲染SVG图像...');
      
      Bitmap := TBitmap.Create;
      try
        // 设置位图属性
        Bitmap.PixelFormat := pf32bit;
        Bitmap.Width := FWidth;
        Bitmap.Height := FHeight;
        Bitmap.Canvas.Brush.Color := clWhite;
        Bitmap.Canvas.FillRect(Rect(0, 0, FWidth, FHeight));
        
        // 渲染SVG到位图
        SVGBrush.Render(Bitmap.Canvas, RectF(0, 0, FWidth, FHeight));
        
        FormatName := GetFormatName;
        
        // 根据目标格式保存
        case FFormat of
          sofPNG:
            begin
              PngImage := TPngImage.Create;
              try
                PngImage.Assign(Bitmap);
                PngImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                PngImage.Free;
              end;
            end;
            
          sofJPG:
            begin
              JpgImage := TJPEGImage.Create;
              try
                JpgImage.Assign(Bitmap);
                JpgImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                JpgImage.Free;
              end;
            end;
            
          sofBMP:
            begin
              Bitmap.SaveToFile(FOutputPath);
              Result := True;
            end;
            
          sofGIF:
            begin
              GifImage := TGIFImage.Create;
              try
                GifImage.Assign(Bitmap);
                GifImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                GifImage.Free;
              end;
            end;
            
          sofTIFF, sofWebP:
            begin
              // 这些格式可能需要特殊处理或附加库
              if Assigned(FOnError) then
                FOnError(Format('格式 %s 需要附加支持库', [FormatName]));
                
              // 临时实现：保存为PNG
              PngImage := TPngImage.Create;
              try
                PngImage.Assign(Bitmap);
                PngImage.SaveToFile(ChangeFileExt(FOutputPath, '.png'));
                Result := True;
                
                if Assigned(FOnSuccess) then
                  FOnSuccess('注意：' + FormatName + '格式不直接支持，已保存为PNG: ' + 
                             ChangeFileExt(FOutputPath, '.png'));
              finally
                PngImage.Free;
              end;
            end;
        end;
        
        if Result and Assigned(FOnSuccess) and (FFormat <> sofTIFF) and (FFormat <> sofWebP) then
          FOnSuccess(FormatName + '文件创建成功: ' + FOutputPath);
      finally
        Bitmap.Free;
      end;
    finally
      SVGBrush.Free;
    end;
  finally
    SVG.Free;
  end;
end;

function TSVGConverter.Convert: Boolean;
var
  FormatName: string;
begin
  Result := False;
  
  // 获取格式名称
  FormatName := GetFormatName;
  
  // 检查文件存在
  if not FileExists(FSVGFilePath) then
  begin
    if Assigned(FOnError) then
      FOnError('SVG文件不存在: ' + FSVGFilePath);
    Exit;
  end;
  
  // 设置输出路径
  if FOutputPath = '' then
    FOutputPath := ChangeFileExt(FSVGFilePath, GetFormatExtension);
  
  // 确保输出目录存在
  try
    ForceDirectories(ExtractFilePath(FOutputPath));
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('创建输出目录失败: ' + E.Message);
      Exit;
    end;
  end;
  
  // 通知正在转换
  if Assigned(FOnProgress) then
    FOnProgress('正在转换SVG为' + FormatName + '格式...');
  
  try
    // 根据格式调用不同的转换方法
    if FFormat = sofICO then
      Result := ConvertToICO
    else
      Result := ConvertToImageFormat;
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('转换失败: ' + E.Message);
      Result := False;
    end;
  end;
end;

class function TSVGConverter.GetSupportedFormats: TArray<string>;
begin
  SetLength(Result, 7);
  Result[0] := 'ICO';
  Result[1] := 'PNG';
  Result[2] := 'JPG';
  Result[3] := 'BMP';
  Result[4] := 'GIF';
  Result[5] := 'TIFF';
  Result[6] := 'WebP';
end;

// 辅助函数 - 将SVG文件加载到组件中
procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);
begin
  if not Assigned(SVGControl) then
    Exit;
    
  if FileExists(SVGFilePath) then
  begin
    // 设置SVG源
    try
      SVGControl.Svg.Source := TFile.ReadAllText(SVGFilePath);
    except
      on E: Exception do
        // 可以在这里处理加载错误
    end;
  end;
end;

// 辅助函数 - 生成合适的输出路径
function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;
var
  Ext: string;
begin
  case Format of
    sofICO: Ext := '.ico';
    sofPNG: Ext := '.png';
    sofJPG: Ext := '.jpg';
    sofBMP: Ext := '.bmp';
    sofGIF: Ext := '.gif';
    sofTIFF: Ext := '.tiff';
    sofWebP: Ext := '.webp';
    else Ext := '.png';
  end;
  
  Result := ChangeFileExt(SVGFilePath, Ext);
end;

end.