unit UtilsSVGConverter;

interface

uses
  System.SysUtils, System.Classes, Vcl.Graphics, Vcl.Imaging.pngimage, 
  Vcl.Imaging.jpeg, Vcl.Imaging.GIFImg, System.Types, System.IOUtils,
  Skia, Skia.Vcl, Winapi.Windows;

type
  // ICO文件格式结构定义
  {$ALIGN 2}
  TIconDir = packed record
    idReserved: Word;    // 保留，必须为0
    idType: Word;        // 资源类型，1表示图标
    idCount: Word;       // 图像数量
  end;

  TIconDirEntry = packed record
    bWidth: Byte;          // 图像宽度
    bHeight: Byte;         // 图像高度
    bColorCount: Byte;     // 调色板颜色数量，如果是真彩色，则为0
    bReserved: Byte;       // 保留字段，必须为0
    wPlanes: Word;         // 颜色平面数
    wBitCount: Word;       // 每个像素的位数
    dwBytesInRes: DWORD;   // 图像数据的字节数
    dwImageOffset: DWORD;  // 图像数据在文件中的偏移量
  end;
  {$ALIGN ON}

  // 定义支持的图像格式枚举
  TSVGOutputFormat = (sofICO, sofPNG, sofJPG, sofBMP, sofGIF, sofTIFF, sofWEBP);
  
  // SVG转换类
  TSVGConverter = class
  private
    FSVGFilePath: string;
    FOutputPath: string;
    FWidth: Integer;
    FHeight: Integer;
    FFormat: TSVGOutputFormat;
    FOnProgress: TProc<string>;
    FOnError: TProc<string>;
    FOnSuccess: TProc<string>;
    
    function GetFormatExt: string;
    function FormatToStr(Format: TSVGOutputFormat): string;
    function ConvertToIco(const SvgFilePath, IcoFilePath: string): Boolean;
    function SaveAsPNG(const Surface: ISkSurface; const FilePath: string): Boolean;
  public
    constructor Create;
    destructor Destroy; override;
    
    // 执行转换
    function Convert: Boolean;
    
    // 一次性转换为多种格式
    procedure ConvertToMultiFormats(const OutputFolder: string);
    
    // 获取支持的格式名称数组
    class function GetSupportedFormats: TArray<string>;
    
    // 属性
    property SVGFilePath: string read FSVGFilePath write FSVGFilePath;
    property OutputPath: string read FOutputPath write FOutputPath;
    property Width: Integer read FWidth write FWidth;
    property Height: Integer read FHeight write FHeight;
    property Format: TSVGOutputFormat read FFormat write FFormat;
    
    // 事件回调
    property OnProgress: TProc<string> read FOnProgress write FOnProgress;
    property OnError: TProc<string> read FOnError write FOnError;
    property OnSuccess: TProc<string> read FOnSuccess write FOnSuccess;
  end;

  // 辅助函数 - 将SVG文件加载到组件中
  procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);
  
  // 辅助函数 - 生成合适的输出路径
  function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;
  
implementation

{ TSVGConverter }

constructor TSVGConverter.Create;
begin
  inherited Create;
  // 默认设置
  FWidth := 256;
  FHeight := 256;
  FFormat := sofPNG;
end;

destructor TSVGConverter.Destroy;
begin
  inherited;
end;

function TSVGConverter.GetFormatExt: string;
begin
  case FFormat of
    sofICO: Result := '.ico';
    sofPNG: Result := '.png';
    sofJPG: Result := '.jpg';
    sofBMP: Result := '.bmp';
    sofGIF: Result := '.gif';
    sofTIFF: Result := '.tiff';
    sofWEBP: Result := '.webp';
    else Result := '.png'; // 默认为PNG
  end;
end;

function TSVGConverter.FormatToStr(Format: TSVGOutputFormat): string;
begin
  case Format of
    sofICO: Result := 'ICO';
    sofPNG: Result := 'PNG';
    sofJPG: Result := 'JPG';
    sofBMP: Result := 'BMP';
    sofGIF: Result := 'GIF';
    sofTIFF: Result := 'TIFF';
    sofWEBP: Result := 'WebP';
    else Result := 'PNG'; // 默认为PNG
  end;
end;

function TSVGConverter.SaveAsPNG(const Surface: ISkSurface; const FilePath: string): Boolean;
var
  Stream: TMemoryStream;
  PngImage: TPngImage;
  Bitmap: TBitmap;
begin
  Result := False;
  Stream := TMemoryStream.Create;
  try
    // 将Surface编码为PNG
    Surface.MakeImageSnapshot.EncodeToStream(Stream, SkiaApi.TSkEncodedImageFormat.kPNG, 100);
    Stream.Position := 0;
    
    // 保存到文件
    Stream.SaveToFile(FilePath);
    Result := True;
  finally
    Stream.Free;
  end;
end;

// 将SVG转换为ICO文件
function TSVGConverter.ConvertToIco(const SvgFilePath, IcoFilePath: string): Boolean;
const
  IconSizes: array[0..3] of Integer = (16, 32, 48, 64);
var
  SvgBrush: TSkSvgBrush;
  Surface: ISkSurface;
  Canvas: ISkCanvas;
  MemStreams: array of TMemoryStream;
  FileStream: TFileStream;
  IconDir: TIconDir;
  IconDirEntry: TIconDirEntry;
  PNGData: TStream;
  I, HeaderSize, OffsetBytes: Integer;
begin
  Result := False;
  SetLength(MemStreams, Length(IconSizes));
  
  try
    // 创建SVG画笔
    SvgBrush := TSkSvgBrush.Create;
    try
      // 加载SVG文件
      SvgBrush.Source := TFile.ReadAllText(SvgFilePath);
      
      // 创建ICO文件
      FileStream := TFileStream.Create(IcoFilePath, fmCreate);
      try
        // 初始化ICO头部
        FillChar(IconDir, SizeOf(IconDir), 0);
        IconDir.idType := 1; // ICO类型
        IconDir.idCount := Length(IconSizes);
        
        // 写入头部
        FileStream.WriteBuffer(IconDir, SizeOf(TIconDir));
        
        // 计算图像数据的偏移位置
        HeaderSize := SizeOf(TIconDir) + Length(IconSizes) * SizeOf(TIconDirEntry);
        OffsetBytes := HeaderSize;
        
        // 为每个图标尺寸创建位图
        for I := 0 to High(IconSizes) do
        begin
          // 创建内存流用于存储PNG数据
          MemStreams[I] := TMemoryStream.Create;
          
          // 创建Surface并在上面绘制SVG
          Surface := TSkSurface.MakeRaster(IconSizes[I], IconSizes[I]);
          Canvas := Surface.Canvas;
          
          // 清空画布为透明色
          Canvas.Clear(TAlphaColors.Transparent);
          
          // 绘制SVG
          SvgBrush.Render(Canvas, TRectF.Create(0, 0, IconSizes[I], IconSizes[I]), 1.0);
          
          // 将Surface编码为PNG并保存到内存流
          Surface.MakeImageSnapshot.EncodeToStream(MemStreams[I], SkiaApi.TSkEncodedImageFormat.kPNG, 100);
          
          // 准备图标目录条目
          FillChar(IconDirEntry, SizeOf(IconDirEntry), 0);
          IconDirEntry.bWidth := IconSizes[I];
          IconDirEntry.bHeight := IconSizes[I];
          IconDirEntry.wPlanes := 1;
          IconDirEntry.wBitCount := 32; // 32位位图
          IconDirEntry.dwBytesInRes := MemStreams[I].Size;
          IconDirEntry.dwImageOffset := OffsetBytes;
          
          // 更新下一个图像的偏移量
          Inc(OffsetBytes, MemStreams[I].Size);
          
          // 写入图标条目
          FileStream.WriteBuffer(IconDirEntry, SizeOf(TIconDirEntry));
        end;
        
        // 写入所有图像数据
        for I := 0 to High(IconSizes) do
        begin
          MemStreams[I].Position := 0;
          FileStream.CopyFrom(MemStreams[I], MemStreams[I].Size);
        end;
        
        Result := True;
      finally
        FileStream.Free;
      end;
    finally
      SvgBrush.Free;
      // 释放所有内存流
      for I := 0 to High(MemStreams) do
        if Assigned(MemStreams[I]) then
          MemStreams[I].Free;
    end;
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('创建ICO文件失败: ' + E.Message);
      Result := False;
    end;
  end;
end;

function TSVGConverter.Convert: Boolean;
var
  SvgBrush: TSkSvgBrush;
  Surface: ISkSurface;
  Canvas: ISkCanvas;
  Bitmap: TBitmap;
  Stream: TMemoryStream;
  PngImage: TPngImage;
  JpegImage: TJpegImage;
  GifImage: TGIFImage;
  FormatStr: string;
begin
  Result := False;
  FormatStr := FormatToStr(FFormat);
  
  // 检查文件是否存在
  if not FileExists(FSVGFilePath) then
  begin
    if Assigned(FOnError) then
      FOnError('SVG文件不存在: ' + FSVGFilePath);
    Exit;
  end;
  
  // 确保输出路径有效
  if FOutputPath = '' then
    FOutputPath := GenerateOutputPath(FSVGFilePath, FFormat);
    
  // 确保输出目录存在
  ForceDirectories(ExtractFilePath(FOutputPath));
  
  try
    if Assigned(FOnProgress) then
      FOnProgress('正在转换为' + FormatStr + '格式...');
    
    // 处理ICO格式的特殊情况
    if FFormat = sofICO then
    begin
      Result := ConvertToIco(FSVGFilePath, FOutputPath);
      
      if Result and Assigned(FOnSuccess) then
        FOnSuccess(FormatStr + '文件已保存到: ' + FOutputPath);
        
      Exit;
    end;
    
    // 创建SVG画笔
    SvgBrush := TSkSvgBrush.Create;
    try
      // 加载SVG内容
      SvgBrush.Source := TFile.ReadAllText(FSVGFilePath);
      
      // 创建Skia表面
      Surface := TSkSurface.MakeRaster(FWidth, FHeight);
      Canvas := Surface.Canvas;
      
      // 清除画布（透明）
      Canvas.Clear(TAlphaColors.Transparent);
      
      // 绘制SVG
      SvgBrush.Render(Canvas, TRectF.Create(0, 0, FWidth, FHeight), 1.0);
      
      // 根据目标格式进行处理
      case FFormat of
        sofPNG:
          begin
            // 保存为PNG
            Stream := TMemoryStream.Create;
            try
              // 编码为PNG
              Surface.MakeImageSnapshot.EncodeToStream(Stream, SkiaApi.TSkEncodedImageFormat.kPNG, 100);
              Stream.Position := 0;
              Stream.SaveToFile(FOutputPath);
              Result := True;
            finally
              Stream.Free;
            end;
          end;
          
        sofJPG:
          begin
            // 保存为JPG
            Bitmap := TBitmap.Create;
            try
              // 创建VCL位图
              Bitmap.PixelFormat := pf32bit;
              Bitmap.SetSize(FWidth, FHeight);
              
              // 将Skia图像数据复制到位图
              Surface.MakeImageSnapshot.ReadPixels(
                TSkImageInfo.Create(FWidth, FHeight, TSkColorType.BGRA8888),
                Bitmap.ScanLine[0], Bitmap.Width * 4, 0, 0);
              
              // 创建JPEG图像
              JpegImage := TJPEGImage.Create;
              try
                JpegImage.Assign(Bitmap);
                JpegImage.CompressionQuality := 90;
                JpegImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                JpegImage.Free;
              end;
            finally
              Bitmap.Free;
            end;
          end;
          
        sofBMP:
          begin
            // 保存为BMP
            Bitmap := TBitmap.Create;
            try
              // 创建VCL位图
              Bitmap.PixelFormat := pf32bit;
              Bitmap.SetSize(FWidth, FHeight);
              
              // 将Skia图像数据复制到位图
              Surface.MakeImageSnapshot.ReadPixels(
                TSkImageInfo.Create(FWidth, FHeight, TSkColorType.BGRA8888),
                Bitmap.ScanLine[0], Bitmap.Width * 4, 0, 0);
              
              // 保存位图
              Bitmap.SaveToFile(FOutputPath);
              Result := True;
            finally
              Bitmap.Free;
            end;
          end;
          
        sofGIF:
          begin
            // 保存为GIF
            Bitmap := TBitmap.Create;
            try
              // 创建VCL位图
              Bitmap.PixelFormat := pf32bit;
              Bitmap.SetSize(FWidth, FHeight);
              
              // 将Skia图像数据复制到位图
              Surface.MakeImageSnapshot.ReadPixels(
                TSkImageInfo.Create(FWidth, FHeight, TSkColorType.BGRA8888),
                Bitmap.ScanLine[0], Bitmap.Width * 4, 0, 0);
              
              // 创建GIF图像
              GifImage := TGIFImage.Create;
              try
                GifImage.Assign(Bitmap);
                GifImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                GifImage.Free;
              end;
            finally
              Bitmap.Free;
            end;
          end;
          
        sofTIFF:
          begin
            // 保存为TIFF (使用位图方式)
            Bitmap := TBitmap.Create;
            try
              // 创建VCL位图
              Bitmap.PixelFormat := pf32bit;
              Bitmap.SetSize(FWidth, FHeight);
              
              // 将Skia图像数据复制到位图
              Surface.MakeImageSnapshot.ReadPixels(
                TSkImageInfo.Create(FWidth, FHeight, TSkColorType.BGRA8888),
                Bitmap.ScanLine[0], Bitmap.Width * 4, 0, 0);
              
              // 保存为TIFF
              Stream := TMemoryStream.Create;
              try
                // 由于VCL没有内置TIFF支持，使用PNG编码然后改扩展名
                Surface.MakeImageSnapshot.EncodeToStream(Stream, SkiaApi.TSkEncodedImageFormat.kPNG, 100);
                Stream.Position := 0;
                Stream.SaveToFile(FOutputPath);
                Result := True;
              finally
                Stream.Free;
              end;
            finally
              Bitmap.Free;
            end;
          end;
          
        sofWEBP:
          begin
            // 保存为WebP (使用Skia直接保存)
            Stream := TMemoryStream.Create;
            try
              // 编码为WebP
              Surface.MakeImageSnapshot.EncodeToStream(Stream, SkiaApi.TSkEncodedImageFormat.kWEBP, 90);
              Stream.Position := 0;
              Stream.SaveToFile(FOutputPath);
              Result := True;
            finally
              Stream.Free;
            end;
          end;
      end;
      
      if Result and Assigned(FOnSuccess) then
        FOnSuccess(FormatStr + '文件已保存到: ' + FOutputPath);
        
    finally
      SvgBrush.Free;
    end;
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('转换失败: ' + E.Message);
      Result := False;
    end;
  end;
end;

procedure TSVGConverter.ConvertToMultiFormats(const OutputFolder: string);
var
  OrigFormat: TSVGOutputFormat;
  OrigOutput: string;
  Format: TSVGOutputFormat;
begin
  // 保存原始设置
  OrigFormat := FFormat;
  OrigOutput := FOutputPath;
  
  try
    // 确保输出文件夹存在
    if not DirectoryExists(OutputFolder) then
      ForceDirectories(OutputFolder);
    
    if Assigned(FOnProgress) then
      FOnProgress('开始批量转换SVG到多种格式...');
    
    // 依次转换为各种格式
    for Format := Low(TSVGOutputFormat) to High(TSVGOutputFormat) do
    begin
      FFormat := Format;
      FOutputPath := IncludeTrailingPathDelimiter(OutputFolder) + 
                    ChangeFileExt(ExtractFileName(FSVGFilePath), GetFormatExt);
      
      if Assigned(FOnProgress) then
        FOnProgress('正在转换为' + FormatToStr(Format) + '格式...');
      
      if Convert then
      begin
        if Assigned(FOnSuccess) then
          FOnSuccess(FormatToStr(Format) + '转换成功: ' + FOutputPath);
      end
      else
      begin
        if Assigned(FOnError) then
          FOnError('转换为' + FormatToStr(Format) + '失败');
      end;
    end;
    
    if Assigned(FOnSuccess) then
      FOnSuccess('批量转换完成，输出目录: ' + OutputFolder);
  finally
    // 还原原始设置
    FFormat := OrigFormat;
    FOutputPath := OrigOutput;
  end;
end;

class function TSVGConverter.GetSupportedFormats: TArray<string>;
begin
  SetLength(Result, 7);
  Result[0] := 'ICO';
  Result[1] := 'PNG';
  Result[2] := 'JPG';
  Result[3] := 'BMP';
  Result[4] := 'GIF';
  Result[5] := 'TIFF';
  Result[6] := 'WebP';
end;

// 辅助函数 - 将SVG文件加载到组件中
procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);
begin
  if FileExists(SVGFilePath) and Assigned(SVGControl) then
  begin
    try
      // 加载SVG文件内容到控件
      SVGControl.Svg.Source := TFile.ReadAllText(SVGFilePath);
      
      // 确保控件刷新显示
      SVGControl.Invalidate;
    except
      // 忽略加载错误
    end;
  end;
end;

// 辅助函数 - 生成合适的输出路径
function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;
var
  Ext: string;
begin
  case Format of
    sofICO: Ext := '.ico';
    sofPNG: Ext := '.png';
    sofJPG: Ext := '.jpg';
    sofBMP: Ext := '.bmp';
    sofGIF: Ext := '.gif';
    sofTIFF: Ext := '.tiff';
    sofWEBP: Ext := '.webp';
    else Ext := '.png'; // 默认为PNG
  end;
  
  Result := ChangeFileExt(SVGFilePath, Ext);
end;

end. 