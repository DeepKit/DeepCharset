unit UtilsSVGConverter;

interface

uses
  System.SysUtils, System.Classes, Vcl.Graphics, Vcl.Imaging.pngimage,
  Vcl.Imaging.jpeg, Vcl.Imaging.GIFImg, System.Types, System.IOUtils,
  System.UITypes, Winapi.Windows, Vcl.Forms, Vcl.Controls, Vcl.Dialogs,
  Vcl.ExtCtrls;

type
  // 定义支持的图像格式枚举
  TSVGOutputFormat = (sofICO, sofPNG, sofJPG, sofBMP, sofGIF, sofTIFF, sofWebP);

  // 定义回调方法类型
  TProgressCallback = reference to procedure(const AMessage: string);
  TErrorCallback = reference to procedure(const AMessage: string);
  TSuccessCallback = reference to procedure(const AMessage: string);

  // SVG转换类
  TSVGConverter = class
  private
    FSVGFilePath: string;
    FOutputPath: string;
    FWidth: Integer;
    FHeight: Integer;
    FFormat: TSVGOutputFormat;
    FOnProgress: TProgressCallback;
    FOnError: TErrorCallback;
    FOnSuccess: TSuccessCallback;
    
    // 获取格式扩展名
    function GetFormatExtension: string;
    // 获取格式名称
    function GetFormatName: string;
    // 转换为ICO格式
    function ConvertToICO: Boolean;
    // 转换为通用图像格式
    function ConvertToImageFormat: Boolean;
  public
    constructor Create;
    destructor Destroy; override;
    
    // 执行转换
    function Convert: Boolean;
    
    // 获取支持的格式名称数组
    class function GetSupportedFormats: TArray<string>;
    
    // 属性
    property SVGFilePath: string read FSVGFilePath write FSVGFilePath;
    property OutputPath: string read FOutputPath write FOutputPath;
    property Width: Integer read FWidth write FWidth;
    property Height: Integer read FHeight write FHeight;
    property OutputFormat: TSVGOutputFormat read FFormat write FFormat;
    
    // 事件回调
    property OnProgress: TProgressCallback read FOnProgress write FOnProgress;
    property OnError: TErrorCallback read FOnError write FOnError;
    property OnSuccess: TSuccessCallback read FOnSuccess write FOnSuccess;
  end;

// 辅助函数 - 生成合适的输出路径
function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;

// 辅助函数 - 将字符串转换为输出格式枚举
function ParseOutputFormat(const FormatStr: string): TSVGOutputFormat;

procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);

implementation

uses
  System.Skia, Vcl.Skia;  // 在implementation部分引入Skia

{ TSVGConverter }

constructor TSVGConverter.Create;
begin
  inherited Create;
  FWidth := 256;
  FHeight := 256;
  OutputFormat := sofPNG;
end;

destructor TSVGConverter.Destroy;
begin
  inherited;
end;

function TSVGConverter.GetFormatExtension: string;
begin
  case OutputFormat of
    sofICO: Result := '.ico';
    sofPNG: Result := '.png';
    sofJPG: Result := '.jpg';
    sofBMP: Result := '.bmp';
    sofGIF: Result := '.gif';
    sofTIFF: Result := '.tiff';
    sofWebP: Result := '.webp';
    else Result := '.png';
  end;
end;

function TSVGConverter.GetFormatName: string;
begin
  case OutputFormat of
    sofICO: Result := 'ICO';
    sofPNG: Result := 'PNG';
    sofJPG: Result := 'JPG';
    sofBMP: Result := 'BMP';
    sofGIF: Result := 'GIF';
    sofTIFF: Result := 'TIFF';
    sofWebP: Result := 'WebP';
    else Result := 'PNG';
  end;
end;

function TSVGConverter.ConvertToICO: Boolean;
var
  SVG: TSkSvg;
  Form: TForm;
  Image: TImage;
  PngImg: TPngImage;
begin
  Result := False;
  
  if not FileExists(FSVGFilePath) then
  begin
    if Assigned(FOnError) then
      FOnError('SVG文件不存在: ' + FSVGFilePath);
    Exit;
  end;
  
  // 创建临时表单和控件
  Form := TForm.Create(nil);
  try
    Form.Width := FWidth;
    Form.Height := FHeight;
    Form.Visible := False;
    
    // 在表单上创建Image控件
    Image := TImage.Create(Form);
    Image.Parent := Form;
    Image.Align := alClient;
    Image.Stretch := True;
    
    // 在表单上创建SVG控件
    SVG := TSkSvg.Create(Form);
    try
      SVG.Parent := Form;
      SVG.Align := alClient;
      
      // 加载SVG
      try
        SVG.Svg.Source := TFile.ReadAllText(FSVGFilePath);
      except
        on E: Exception do
        begin
          if Assigned(FOnError) then
            FOnError('SVG加载失败: ' + E.Message);
          Exit;
        end;
      end;
      
      // 更新控件使SVG呈现
      Form.Realign;
      Application.ProcessMessages;
      
      // 将SVG渲染到Image
      Image.Picture.Bitmap.SetSize(FWidth, FHeight);
      Form.PaintTo(Image.Picture.Bitmap.Canvas.Handle, 0, 0);
      
      // 保存为PNG
      PngImg := TPngImage.Create;
      try
        PngImg.Assign(Image.Picture.Bitmap);
        PngImg.SaveToFile(FOutputPath);
        Result := True;
        
        if Assigned(FOnSuccess) then
          FOnSuccess('ICO文件创建成功: ' + FOutputPath);
      finally
        PngImg.Free;
      end;
    finally
      SVG.Free;
    end;
  finally
    Form.Free;
  end;
end;

function TSVGConverter.ConvertToImageFormat: Boolean;
var
  SVG: TSkSvg;
  Form: TForm;
  Image: TImage;
  PngImg: TPngImage;
  JpgImg: TJPEGImage;
begin
  Result := False;
  
  if not FileExists(FSVGFilePath) then
  begin
    if Assigned(FOnError) then
      FOnError('SVG文件不存在: ' + FSVGFilePath);
    Exit;
  end;
  
  // 创建临时表单和控件
  Form := TForm.Create(nil);
  try
    Form.Width := FWidth;
    Form.Height := FHeight;
    Form.Visible := False;
    
    // 在表单上创建Image控件
    Image := TImage.Create(Form);
    Image.Parent := Form;
    Image.Align := alClient;
    Image.Stretch := True;
    
    // 在表单上创建SVG控件
    SVG := TSkSvg.Create(Form);
    try
      SVG.Parent := Form;
      SVG.Align := alClient;
      
      // 加载SVG
      try
        SVG.Svg.Source := TFile.ReadAllText(FSVGFilePath);
      except
        on E: Exception do
        begin
          if Assigned(FOnError) then
            FOnError('SVG加载失败: ' + E.Message);
          Exit;
        end;
      end;
      
      // 更新控件使SVG呈现
      Form.Realign;
      Application.ProcessMessages;
      
      // 将SVG渲染到Image
      Image.Picture.Bitmap.SetSize(FWidth, FHeight);
      Form.PaintTo(Image.Picture.Bitmap.Canvas.Handle, 0, 0);
      
      // 根据不同格式保存
      case OutputFormat of
        sofPNG:
          begin
            PngImg := TPngImage.Create;
            try
              PngImg.Assign(Image.Picture.Bitmap);
              PngImg.SaveToFile(FOutputPath);
              Result := True;
            finally
              PngImg.Free;
            end;
          end;
          
        sofJPG:
          begin
            JpgImg := TJPEGImage.Create;
            try
              JpgImg.Assign(Image.Picture.Bitmap);
              JpgImg.SaveToFile(FOutputPath);
              Result := True;
            finally
              JpgImg.Free;
            end;
          end;
          
        sofBMP:
          begin
            Image.Picture.Bitmap.SaveToFile(FOutputPath);
            Result := True;
          end;
          
        else
          begin
            // 其他格式默认保存为PNG
            PngImg := TPngImage.Create;
            try
              PngImg.Assign(Image.Picture.Bitmap);
              PngImg.SaveToFile(FOutputPath);
              Result := True;
              
              if Assigned(FOnProgress) then
                FOnProgress('注意：' + GetFormatName + '格式直接保存为PNG');
            finally
              PngImg.Free;
            end;
          end;
      end;
      
      if Result and Assigned(FOnSuccess) then
        FOnSuccess(GetFormatName + '文件创建成功: ' + FOutputPath);
    finally
      SVG.Free;
    end;
  finally
    Form.Free;
  end;
end;

function TSVGConverter.Convert: Boolean;
var
  FormatName: string;
begin
  Result := False;
  
  // 获取格式名称
  FormatName := GetFormatName;
  
  // 检查文件存在
  if not FileExists(FSVGFilePath) then
  begin
    if Assigned(FOnError) then
      FOnError('SVG文件不存在: ' + FSVGFilePath);
    Exit;
  end;
  
  // 设置输出路径
  if FOutputPath = '' then
    FOutputPath := ChangeFileExt(FSVGFilePath, GetFormatExtension);
  
  // 确保输出目录存在
  try
    ForceDirectories(ExtractFilePath(FOutputPath));
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('创建输出目录失败: ' + E.Message);
      Exit;
    end;
  end;
  
  // 通知正在转换
  if Assigned(FOnProgress) then
    FOnProgress('正在转换SVG为' + FormatName + '格式...');
  
  try
    // 根据格式调用不同的转换方法
    if OutputFormat = sofICO then
      Result := ConvertToICO
    else
      Result := ConvertToImageFormat;
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('转换失败: ' + E.Message);
      Result := False;
    end;
  end;
end;

class function TSVGConverter.GetSupportedFormats: TArray<string>;
begin
  SetLength(Result, 7);
  Result[0] := 'ICO';
  Result[1] := 'PNG';
  Result[2] := 'JPG';
  Result[3] := 'BMP';
  Result[4] := 'GIF';
  Result[5] := 'TIFF';
  Result[6] := 'WebP';
end;

function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;
var
  Ext: string;
begin
  case Format of
    sofICO: Ext := '.ico';
    sofPNG: Ext := '.png';
    sofJPG: Ext := '.jpg';
    sofBMP: Ext := '.bmp';
    sofGIF: Ext := '.gif';
    sofTIFF: Ext := '.tiff';
    sofWebP: Ext := '.webp';
    else Ext := '.png';
  end;
  
  Result := ChangeFileExt(SVGFilePath, Ext);
end;

function ParseOutputFormat(const FormatStr: string): TSVGOutputFormat;
begin
  if SameText(FormatStr, 'ICO') then
    Result := sofICO
  else if SameText(FormatStr, 'PNG') then
    Result := sofPNG
  else if SameText(FormatStr, 'JPG') or SameText(FormatStr, 'JPEG') then
    Result := sofJPG
  else if SameText(FormatStr, 'BMP') then
    Result := sofBMP
  else if SameText(FormatStr, 'GIF') then
    Result := sofGIF
  else if SameText(FormatStr, 'TIFF') then
    Result := sofTIFF
  else if SameText(FormatStr, 'WEBP') then
    Result := sofWebP
  else
    Result := sofPNG; // 默认为PNG格式
end;

procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);
begin
  if not Assigned(SVGControl) then Exit;
  if not FileExists(SVGFilePath) then Exit;
  
  try
    SVGControl.Svg.Source := TFile.ReadAllText(SVGFilePath);
  except
    on E: Exception do
      // Error handling can be added here
  end;
end;

end.