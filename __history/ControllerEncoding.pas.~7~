// 转换单个文件编码（使用编码名称）
function TEncodingController.ConvertSingleFile(const SourceFile, TargetEncodingName: string; AddBOM: Boolean = False; const TargetFile: string = ''): TConversionResult;
var
  SourceEncodingName: string;
  BOMHandlingSuccess: Boolean;
  BackupFile: string;
  ConversionResult: TConversionResult;
begin
  Result := crFailed;
  BackupFile := '';

  // 检查文件是否存在
  if not FileExists(SourceFile) then
  begin
    if Assigned(FLogCallback) then
      FLogCallback('文件不存在: ' + SourceFile);
    Exit;
  end;

  // 检查文件是否是不支持的文件类型
  if IsUnsupportedFile(SourceFile) then
  begin
    if Assigned(FLogCallback) then
      FLogCallback('跳过不支持的文件: ' + SourceFile);
    Exit;
  end;

  // 检测源文件编码
  if not DetectFileEncoding(SourceFile, SourceEncodingName) then
  begin
    if Assigned(FLogCallback) then
      FLogCallback('无法检测文件编码: ' + SourceFile);
    Exit;
  end;

  if Assigned(FLogCallback) then
    FLogCallback('检测到文件编码: ' + SourceFile + ' -> ' + SourceEncodingName);

  // 如果源编码和目标编码相同，且BOM设置也相同，则不需要转换
  if SameText(SourceEncodingName, TargetEncodingName) then
  begin
    var HasBOMNow := HasBOM(SourceFile, nil);

    // 特殊处理UTF-8和UTF-8 with BOM之间的转换
    if SameText(SourceEncodingName, 'UTF-8 with BOM') and SameText(TargetEncodingName, 'UTF-8') and not AddBOM then
    begin
      // 需要移除BOM
      if Assigned(FLogCallback) then
        FLogCallback('需要移除UTF-8 BOM: ' + SourceFile);

      // 移除BOM
      BOMHandlingSuccess := RemoveBOM.RemoveUTF8BOM(SourceFile);

      if BOMHandlingSuccess then
      begin
        if Assigned(FLogCallback) then
          FLogCallback('- 成功转换: ' + SourceFile + ' (从 ' + SourceEncodingName + ' 到 ' + TargetEncodingName + ')');
        Result := crSuccess;
      end
      else
      begin
        if Assigned(FLogCallback) then
          FLogCallback('移除BOM失败: ' + SourceFile);
        Result := crFailed;
      end;

      Exit;
    end
    else if SameText(SourceEncodingName, 'UTF-8') and SameText(TargetEncodingName, 'UTF-8 with BOM') then
    begin
      // 需要添加BOM
      if Assigned(FLogCallback) then
        FLogCallback('需要添加UTF-8 BOM: ' + SourceFile);

      // 添加BOM
      BOMHandlingSuccess := RemoveBOM.AddUTF8BOM(SourceFile);

      if BOMHandlingSuccess then
      begin
        if Assigned(FLogCallback) then
          FLogCallback('- 成功转换: ' + SourceFile + ' (从 ' + SourceEncodingName + ' 到 ' + TargetEncodingName + ')');
        Result := crSuccess;
      end
      else
      begin
        if Assigned(FLogCallback) then
          FLogCallback('添加BOM失败: ' + SourceFile);
        Result := crFailed;
      end;

      Exit;
    end
    else if (HasBOMNow and AddBOM) or (not HasBOMNow and not AddBOM) then
    begin
      if Assigned(FLogCallback) then
        FLogCallback('文件已经是目标编码，无需转换: ' + SourceFile);
      Result := crNoActionNeeded;
      Exit;
    end;
  end;

  // 调用原有的转换方法
  ConversionResult := DoConvertSingleFileByName(SourceFile, TargetEncodingName, AddBOM, TargetFile);

  // 特殊处理：如果目标是UTF-8且不需要BOM，确保没有BOM
  if (ConversionResult = crSuccess) and SameText(TargetEncodingName, 'UTF-8') and not AddBOM then
  begin
    var TargetFilePath := TargetFile;
    if TargetFilePath = '' then
      TargetFilePath := SourceFile;

    // 检查转换后的文件是否有BOM
    if HasBOM(TargetFilePath, nil) then
    begin
      if Assigned(FLogCallback) then
        FLogCallback('检测到转换后的文件仍有BOM，尝试移除...');

      // 移除BOM
      BOMHandlingSuccess := RemoveBOM.RemoveUTF8BOM(TargetFilePath);

      if BOMHandlingSuccess then
      begin
        if Assigned(FLogCallback) then
          FLogCallback('成功移除BOM');
      end
      else
      begin
        if Assigned(FLogCallback) then
          FLogCallback('警告：移除BOM失败');
      end;
    end;
  end;

  Result := ConversionResult;
end;

// NEW Public Method Implementation: ConvertFilesByName
procedure TEncodingController.ConvertFilesByName(const SelectedFiles: TArray<string>;
  const TargetEncodingName: string; AddBOM: Boolean;
  UpdateCallback: TProc<string>);
var
  i: Integer;
  FileToConvert: string;
  ConversionResult: TConversionResult;
begin
  if Assigned(FLogCallback) then
    FLogCallback(Format('开始批量转换 %d 个文件到 %s', [Length(SelectedFiles), TargetEncodingName]));

  for i := 0 to High(SelectedFiles) do
  begin
    FileToConvert := SelectedFiles[i];
    // 使用新的ConvertSingleFile方法进行转换
    ConversionResult := ConvertSingleFile(FileToConvert, TargetEncodingName, AddBOM, '');

    // 如果转换成功并且回调函数已分配，调用回调
    if (ConversionResult = crSuccess) and Assigned(UpdateCallback) then
    begin
      if Assigned(FLogCallback) then
        FLogCallback(Format('文件转换成功，调用回调: %s', [FileToConvert]));
      UpdateCallback(FileToConvert);
    end;
    // Potential improvement: Use parallel tasks for conversion if safe
  end;

  if Assigned(FLogCallback) then
    FLogCallback('批量转换完成。');
end;

