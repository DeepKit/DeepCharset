function TEncodingController.ConvertFileEncodingAdvanced(const SourceFile, TargetFile: string;
  const TargetEncodingName: string; AddBOM: Boolean;
  UnmappableAction: TUnmappableCharAction = ucaReplace;
  LineEndingAction: TLineEndingAction = leaKeep;
  const Replacement: string = '?'): TDetailedConversionResult;
begin
  // 直接调用改进的编码转换函数
  Result := ConvertFileEncodingImproved(SourceFile, TargetFile, TargetEncodingName, AddBOM,
                                      UnmappableAction, LineEndingAction, Replacement);
end;

function TEncodingController.ConvertFilesEncodingAdvanced(const SelectedFiles: TArray<string>;
  const TargetEncodingName: string; AddBOM: Boolean;
  UnmappableAction: TUnmappableCharAction = ucaReplace;
  LineEndingAction: TLineEndingAction = leaKeep;
  const Replacement: string = '?';
  UpdateCallback: TProc<string> = nil): Integer;
var
  I: Integer;
  SuccessCount: Integer;
  TempLogCallback: TProc<string>;
  TargetFile: string;
  ConversionResult: TDetailedConversionResult;
begin
  SuccessCount := 0;

  // 保存原始日志回调
  TempLogCallback := FLogCallback;

  try
    // 如果提供了更新回调，则使用它
    if Assigned(UpdateCallback) then
      FLogCallback := UpdateCallback;

    // 处理每个文件
    for I := 0 to Length(SelectedFiles) - 1 do
    begin
      // 生成目标文件名
      TargetFile := SelectedFiles[I];

      // 转换文件
      ConversionResult := ConvertFileEncodingImproved(SelectedFiles[I], TargetFile, TargetEncodingName,
                                                   AddBOM, UnmappableAction, LineEndingAction, Replacement);

      // 统计成功数
      if ConversionResult.Success then
        Inc(SuccessCount);
    end;
  finally
    // 恢复原始日志回调
    FLogCallback := TempLogCallback;
  end;

  Result := SuccessCount;
end;

