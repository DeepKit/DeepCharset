function TEncodingController.NormalizeLineEndings(const Text: string; Action: TLineEndingAction; var ReplaceCount: Integer): string;
const
  CRLF = #13#10; // Windows
  LF = #10;      // Unix
  CR = #13;      // Mac
var
  I, Len: Integer;
  NormalizedText: string;
  InCR: Boolean;
begin
  if Action = leaKeep then
    Exit(Text);

  NormalizedText := '';
  Len := Length(Text);
  InCR := False;
  ReplaceCount := 0;

  for I := 1 to Len do
  begin
    case Text[I] of
      #13: // CR
      begin
        InCR := True;

        case Action of
          leaWindows: ; // 不做任何处理，等待下一个字符
          leaUnix:
          begin
            NormalizedText := NormalizedText + LF;
            Inc(ReplaceCount);
          end;
          leaMac:
            NormalizedText := NormalizedText + CR;
          else
            NormalizedText := NormalizedText + Text[I];
        end;
      end;

      #10: // LF
      begin
        if InCR then
        begin
          // 处理CRLF
          InCR := False;

          case Action of
            leaWindows:
              NormalizedText := NormalizedText + CRLF;
            leaUnix:
              ; // 已经在CR中处理过
            leaMac:
              ; // 已经在CR中处理过
            else
              NormalizedText := NormalizedText + Text[I];
          end;
        end
        else
        begin
          // 单独的LF
          case Action of
            leaWindows:
            begin
              NormalizedText := NormalizedText + CRLF;
              Inc(ReplaceCount);
            end;
            leaUnix:
              NormalizedText := NormalizedText + LF;
            leaMac:
            begin
              NormalizedText := NormalizedText + CR;
              Inc(ReplaceCount);
            end;
            else
              NormalizedText := NormalizedText + Text[I];
          end;
        end;
      end;

      else
      begin
        // 其他字符
        if InCR then
        begin
          // 处理单独的CR
          InCR := False;

          case Action of
            leaWindows:
            begin
              NormalizedText := NormalizedText + CRLF;
              Inc(ReplaceCount);
            end;
            leaUnix:
              ; // 已经在CR中处理过
            leaMac:
              ; // 已经在CR中处理过
            else
              ;
          end;
        end;

        NormalizedText := NormalizedText + Text[I];
      end;
    end;
  end;

  // 处理文本结尾的CR
  if InCR then
  begin
    case Action of
      leaWindows:
      begin
        NormalizedText := NormalizedText + CRLF;
        Inc(ReplaceCount);
      end;
      leaUnix:
        ; // 已经在CR中处理过
      leaMac:
        ; // 已经在CR中处理过
      else
        ;
    end;
  end;

  Result := NormalizedText;
end;

function TEncodingController.IsEncodingAvailable(CodePage: Integer): Boolean;
begin
  try
    var Encoding := TEncoding.GetEncoding(CodePage);
    Encoding.Free;
    Result := True;
  except
    Result := False;
  end;
end;

function TEncodingController.ConvertFileEncodingImproved(const SourceFile, TargetFile: string;
  const TargetEncodingName: string; AddBOM: Boolean;
  UnmappableAction: TUnmappableCharAction = ucaReplace;
  LineEndingAction: TLineEndingAction = leaKeep;
  const Replacement: string = '?'): TDetailedConversionResult;
var
  SourceStream, TargetStream: TFileStream;
  SourceBuffer, TargetBuffer: TBytes;
  SourceEncoding, TargetEncoding: TEncoding;
  SourceText, ProcessedText: string;
  StartTime: Cardinal;
  I: Integer;
  HasUnmappableChars: Boolean;
  BOMSize: Integer;
  HasBOM: Boolean;
  StopWatch: TStopwatch;
begin
  // 初始化结果
  Result.Success := False;
  Result.SourceEncoding := '';
  Result.TargetEncoding := TargetEncodingName;
  Result.ErrorMessage := '';
  Result.UnmappableCharsCount := 0;
  Result.LineEndingReplaceCount := 0;
  SetLength(Result.UnmappableCharsLog, 0);

  StopWatch := TStopwatch.StartNew;

  try
    // 检查源文件是否存在
    if not FileExists(SourceFile) then
    begin
      Result.ErrorMessage := '源文件不存在: ' + SourceFile;
      if Assigned(FLogCallback) then
        FLogCallback(Result.ErrorMessage);
      Exit;
    end;

    // 检查目标文件路径
    var TargetDir := ExtractFileDir(TargetFile);
    if (TargetDir <> '') and not DirectoryExists(TargetDir) then
    begin
      try
        ForceDirectories(TargetDir);
      except
        on E: Exception do
        begin
          Result.ErrorMessage := '创建目标目录失败: ' + E.Message;
          if Assigned(FLogCallback) then
            FLogCallback(Result.ErrorMessage);
          Exit;
        end;
      end;
    end;

    // 获取目标编码
    try
      if SameText(TargetEncodingName, 'UTF-8') or SameText(TargetEncodingName, 'UTF8') then
        TargetEncoding := TEncoding.UTF8
      else if SameText(TargetEncodingName, 'UTF-16') or SameText(TargetEncodingName, 'UTF16') or
              SameText(TargetEncodingName, 'UTF-16LE') or SameText(TargetEncodingName, 'UTF16LE') then
        TargetEncoding := TEncoding.Unicode
      else if SameText(TargetEncodingName, 'UTF-16BE') or SameText(TargetEncodingName, 'UTF16BE') then
        TargetEncoding := TEncoding.BigEndianUnicode
      else if SameText(TargetEncodingName, 'ASCII') then
        TargetEncoding := TEncoding.ASCII
      else if SameText(TargetEncodingName, 'ANSI') then
        TargetEncoding := TEncoding.Default
      else
      begin
        // 尝试根据编码名称获取代码页
        var CodePage := 0;
        if SameText(TargetEncodingName, 'GBK') or SameText(TargetEncodingName, 'GB2312') then
          CodePage := 936 // 简体中文
        else if SameText(TargetEncodingName, 'BIG5') then
          CodePage := 950 // 繁体中文
        else if SameText(TargetEncodingName, 'Shift-JIS') or SameText(TargetEncodingName, 'SJIS') then
          CodePage := 932 // 日文
        else if SameText(TargetEncodingName, 'EUC-KR') or SameText(TargetEncodingName, 'EUCKR') then
          CodePage := 949 // 韩文
        else if SameText(TargetEncodingName, 'EUC-JP') or SameText(TargetEncodingName, 'EUCJP') then
          CodePage := 20932 // 日文 EUC
        else if SameText(TargetEncodingName, 'ISO-8859-1') then
          CodePage := 28591 // 西欧语言
        else if SameText(TargetEncodingName, 'ISO-8859-2') then
          CodePage := 28592 // 中欧语言
        else if SameText(TargetEncodingName, 'ISO-8859-5') then
          CodePage := 28595 // 西里尔语言
        else if SameText(TargetEncodingName, 'ISO-8859-6') then
          CodePage := 28596 // 阿拉伯语
        else if SameText(TargetEncodingName, 'ISO-8859-7') then
          CodePage := 28597 // 希腊语
        else if SameText(TargetEncodingName, 'ISO-8859-8') then
          CodePage := 28598 // 希伯来语
        else if SameText(TargetEncodingName, 'ISO-8859-9') then
          CodePage := 28599 // 土耳其语
        else if SameText(TargetEncodingName, 'Windows-1250') then
          CodePage := 1250 // 中欧
        else if SameText(TargetEncodingName, 'Windows-1251') then
          CodePage := 1251 // 西里尔
        else if SameText(TargetEncodingName, 'Windows-1252') then
          CodePage := 1252 // 西欧
        else if SameText(TargetEncodingName, 'Windows-1253') then
          CodePage := 1253 // 希腊
        else if SameText(TargetEncodingName, 'Windows-1254') then
          CodePage := 1254 // 土耳其
        else if SameText(TargetEncodingName, 'Windows-1255') then
          CodePage := 1255 // 希伯来
        else if SameText(TargetEncodingName, 'Windows-1256') then
          CodePage := 1256 // 阿拉伯
        else if SameText(TargetEncodingName, 'Windows-1257') then
          CodePage := 1257 // 波罗的海
        else if SameText(TargetEncodingName, 'Windows-1258') then
          CodePage := 1258 // 越南
        else if SameText(TargetEncodingName, 'KOI8-R') then
          CodePage := 20866 // 俄语
        else if SameText(TargetEncodingName, 'KOI8-U') then
          CodePage := 21866 // 乌克兰语
        else if SameText(TargetEncodingName, 'GB18030') then
          CodePage := 54936 // 中文综合
        else
        begin
          // 尝试直接解析为代码页
          try
            CodePage := StrToInt(TargetEncodingName);
          except
            CodePage := 0;
          end;
        end;

        if CodePage > 0 then
        begin
          try
            TargetEncoding := TEncoding.GetEncoding(CodePage);
          except
            on E: Exception do
            begin
              Result.ErrorMessage := '无效的目标编码: ' + TargetEncodingName + ' - ' + E.Message;
              if Assigned(FLogCallback) then
                FLogCallback(Result.ErrorMessage);
              Exit;
            end;
          end;
        end
        else
        begin
          Result.ErrorMessage := '无法识别的目标编码: ' + TargetEncodingName;
          if Assigned(FLogCallback) then
            FLogCallback(Result.ErrorMessage);
          Exit;
        end;
      end;
    except
      on E: Exception do
      begin
        Result.ErrorMessage := '获取目标编码失败: ' + E.Message;
        if Assigned(FLogCallback) then
          FLogCallback(Result.ErrorMessage);
        Exit;
      end;
    end;

    // 打开源文件
    try
      SourceStream := TFileStream.Create(SourceFile, fmOpenRead or fmShareDenyWrite);
    except
      on E: Exception do
      begin
        Result.ErrorMessage := '打开源文件失败: ' + E.Message;
        if Assigned(FLogCallback) then
          FLogCallback(Result.ErrorMessage);
        Exit;
      end;
    end;

    try
      // 读取源文件内容
      SetLength(SourceBuffer, SourceStream.Size);
      if SourceStream.Size > 0 then
        SourceStream.ReadBuffer(SourceBuffer[0], SourceStream.Size);

      // 检测源文件编码
      var SourceEncodingName: string;
      if not DetectFileEncodingImproved(SourceFile, SourceEncodingName) then
      begin
        Result.ErrorMessage := '无法检测源文件编码';
        if Assigned(FLogCallback) then
          FLogCallback(Result.ErrorMessage);
        Exit;
      end;

      Result.SourceEncoding := SourceEncodingName;

      // 获取源编码
      if SameText(SourceEncodingName, 'UTF-8') or SameText(SourceEncodingName, 'UTF-8 with BOM') then
        SourceEncoding := TEncoding.UTF8
      else if SameText(SourceEncodingName, 'UTF-16LE') then
        SourceEncoding := TEncoding.Unicode
      else if SameText(SourceEncodingName, 'UTF-16BE') then
        SourceEncoding := TEncoding.BigEndianUnicode
      else if SameText(SourceEncodingName, 'ASCII') then
        SourceEncoding := TEncoding.ASCII
      else if SameText(SourceEncodingName, 'ANSI') then
        SourceEncoding := TEncoding.Default
      else
      begin
        // 尝试根据编码名称获取代码页
        var CodePage := 0;
        if SameText(SourceEncodingName, 'GBK') or SameText(SourceEncodingName, 'GB2312') then
          CodePage := 936 // 简体中文
        else if SameText(SourceEncodingName, 'BIG5') then
          CodePage := 950 // 繁体中文
        else if SameText(SourceEncodingName, 'Shift-JIS') or SameText(SourceEncodingName, 'SJIS') then
          CodePage := 932 // 日文
        else if SameText(SourceEncodingName, 'EUC-KR') or SameText(SourceEncodingName, 'EUCKR') then
          CodePage := 949 // 韩文
        else if SameText(SourceEncodingName, 'EUC-JP') or SameText(SourceEncodingName, 'EUCJP') then
          CodePage := 20932 // 日文 EUC
        else
        begin
          // 如果无法识别，默认使用ANSI
          SourceEncoding := TEncoding.Default;
          if Assigned(FLogCallback) then
            FLogCallback('无法识别的源编码: ' + SourceEncodingName + ', 使用ANSI编码');
        end;

        if CodePage > 0 then
        begin
          try
            SourceEncoding := TEncoding.GetEncoding(CodePage);
          except
            SourceEncoding := TEncoding.Default;
            if Assigned(FLogCallback) then
              FLogCallback('无法创建源编码: ' + SourceEncodingName + ', 使用ANSI编码');
          end;
        end;
      end;

      // 跳过BOM
      BOMSize := 0;
      HasBOM := False;

      // UTF-8 BOM: EF BB BF
      if (SourceEncoding = TEncoding.UTF8) and (Length(SourceBuffer) >= 3) and
         (SourceBuffer[0] = $EF) and (SourceBuffer[1] = $BB) and (SourceBuffer[2] = $BF) then
      begin
        BOMSize := 3;
        HasBOM := True;
      end
      // UTF-16LE BOM: FF FE
      else if (SourceEncoding = TEncoding.Unicode) and (Length(SourceBuffer) >= 2) and
              (SourceBuffer[0] = $FF) and (SourceBuffer[1] = $FE) then
      begin
        // 检查是否是UTF-32LE BOM: FF FE 00 00
        if (Length(SourceBuffer) >= 4) and (SourceBuffer[2] = 0) and (SourceBuffer[3] = 0) then
          BOMSize := 4
        else
          BOMSize := 2;
        HasBOM := True;
      end
      // UTF-16BE BOM: FE FF
      else if (SourceEncoding = TEncoding.BigEndianUnicode) and (Length(SourceBuffer) >= 2) and
              (SourceBuffer[0] = $FE) and (SourceBuffer[1] = $FF) then
      begin
        BOMSize := 2;
        HasBOM := True;
      end
      // UTF-32BE BOM: 00 00 FE FF
      else if (Length(SourceBuffer) >= 4) and (SourceBuffer[0] = 0) and (SourceBuffer[1] = 0) and
              (SourceBuffer[2] = $FE) and (SourceBuffer[3] = $FF) then
      begin
        BOMSize := 4;
        HasBOM := True;
      end;

      // 跳过BOM并解码文本
      if HasBOM and (BOMSize > 0) then
      begin
        SetLength(SourceText, 0);
        SourceText := SourceEncoding.GetString(SourceBuffer, BOMSize, Length(SourceBuffer) - BOMSize);
      end
      else
      begin
        SetLength(SourceText, 0);
        SourceText := SourceEncoding.GetString(SourceBuffer);
      end;

      if HasBOM and Assigned(FLogCallback) then
        FLogCallback('源文件包含BOM，大小: ' + BOMSize.ToString + ' 字节');

      // 处理不可映射字符
      ProcessedText := '';
      HasUnmappableChars := False;

      // 检查是否有不可映射字符
      try
        TargetBuffer := TargetEncoding.GetBytes(SourceText);
        ProcessedText := SourceText; // 如果没有异常，直接使用原文本
      except
        on E: Exception do
        begin
          // 如果有不可映射字符，需要手动处理
          HasUnmappableChars := True;
          if Assigned(FLogCallback) then
            FLogCallback('警告: 检测到不可映射字符。应用 ' + Ord(UnmappableAction).ToString + ' 策略。');
        end;
      end;

      // 如果有不可映射字符，手动处理每个字符
      if HasUnmappableChars then
      begin
        ProcessedText := '';
        for I := 1 to Length(SourceText) do
        begin
          var Ch := SourceText[I];
          var CanEncode := True;

          try
            TargetEncoding.GetBytes(Ch);
          except
            CanEncode := False;
          end;

          if CanEncode then
            ProcessedText := ProcessedText + Ch
          else
            ProcessedText := ProcessedText + HandleUnmappableChar(Ch, UnmappableAction, Replacement, Result, I);
        end;
      end;

      // 处理行尾符号
      if LineEndingAction <> leaKeep then
      begin
        var LineEndingReplaceCount := 0;
        ProcessedText := NormalizeLineEndings(ProcessedText, LineEndingAction, LineEndingReplaceCount);
        Result.LineEndingReplaceCount := LineEndingReplaceCount;

        if (LineEndingReplaceCount > 0) and Assigned(FLogCallback) then
          FLogCallback('行尾符号替换数: ' + LineEndingReplaceCount.ToString);
      end;

      // 转换为目标编码
      if AddBOM then
        TargetBuffer := TargetEncoding.GetPreamble + TargetEncoding.GetBytes(ProcessedText)
      else
        TargetBuffer := TargetEncoding.GetBytes(ProcessedText);

      // 输出不可映射字符的统计信息
      if (Result.UnmappableCharsCount > 0) and Assigned(FLogCallback) then
      begin
        FLogCallback('发现不可映射字符: ' + Result.UnmappableCharsCount.ToString);
        FLogCallback('前10个不可映射字符:');
        for I := 0 to Min(9, Result.UnmappableCharsCount - 1) do
          with Result.UnmappableCharsLog[I] do
            FLogCallback(Format('  U+%4.4X 在位置 %d 替换为 "%s"', [CodePoint, Position, ReplacedWith]));
      end;

      // 创建目标文件
      try
        TargetStream := TFileStream.Create(TargetFile, fmCreate);
      except
        on E: Exception do
        begin
          Result.ErrorMessage := '创建目标文件失败: ' + E.Message;
          if Assigned(FLogCallback) then
            FLogCallback(Result.ErrorMessage);
          Exit;
        end;
      end;

      try
        // 写入目标文件
        if Length(TargetBuffer) > 0 then
          TargetStream.WriteBuffer(TargetBuffer[0], Length(TargetBuffer));

        Result.Success := True;
        if Assigned(FLogCallback) then
          FLogCallback(Format('文件转换成功: %s -> %s (%s -> %s)',
                            [SourceFile, TargetFile, Result.SourceEncoding, Result.TargetEncoding]));
      finally
        TargetStream.Free;
      end;
    finally
      SourceStream.Free;
      StopWatch.Stop;
      Result.ElapsedTime := StopWatch.ElapsedMilliseconds;
      if Assigned(FLogCallback) then
        FLogCallback('转换耗时: ' + Result.ElapsedTime.ToString + ' ms');
    end;
  except
    on E: Exception do
    begin
      Result.ErrorMessage := '转换过程中出错: ' + E.Message;
      if Assigned(FLogCallback) then
        FLogCallback(Result.ErrorMessage);
    end;
  end;
end;

function TEncodingController.ConvertFile(const FilePath: string; TargetEncoding: TEncoding): Boolean;
var
  SourceStream, DestStream: TFileStream;
  TempPath: string;
  SourceBytes, DestBytes: TBytes;
  SourceEncoding: TEncoding;
  BOMLength: Integer;
begin
  Result := False;
  if not FileExists(FilePath) then Exit;

  TempPath := FilePath + '.tmp';

  try
    // 打开源文件
    SourceStream := TFileStream.Create(FilePath, fmOpenRead or fmShareDenyWrite);
    try
      // 读取文件内容
      SetLength(SourceBytes, SourceStream.Size);
      SourceStream.ReadBuffer(SourceBytes[0], SourceStream.Size);

      // 检测源文件编码
      SourceEncoding := nil;
      BOMLength := TEncoding.GetBufferEncoding(SourceBytes, SourceEncoding);
      if SourceEncoding = nil then
        SourceEncoding := TEncoding.Default;

      // 转换编码
      DestBytes := TEncoding.Convert(SourceEncoding, TargetEncoding,
        SourceBytes, BOMLength, Length(SourceBytes) - BOMLength);

      // 创建临时文件
      DestStream := TFileStream.Create(TempPath, fmCreate);
      try
        // 写入BOM（如果需要）
        if TargetEncoding = TEncoding.UTF8 then
        begin
          var BOM := TEncoding.UTF8.GetPreamble;
          if Length(BOM) > 0 then
            DestStream.WriteBuffer(BOM[0], Length(BOM));
        end
        else if TargetEncoding = TEncoding.Unicode then
        begin
          var BOM := TEncoding.Unicode.GetPreamble;
          if Length(BOM) > 0 then
            DestStream.WriteBuffer(BOM[0], Length(BOM));
        end;

        // 写入转换后的内容
        DestStream.WriteBuffer(DestBytes[0], Length(DestBytes));
      finally
        DestStream.Free;
      end;

      // 备份原文件
      if FileExists(PWideChar(FilePath + '.bak')) then
        DeleteFile(PWideChar(FilePath + '.bak'));
      RenameFile(PWideChar(FilePath), PWideChar(FilePath + '.bak'));

      // 重命名临时文件为目标文件
      RenameFile(PWideChar(TempPath), PWideChar(FilePath));

      Result := True;
    finally
      SourceStream.Free;
    end;
  except
    on E: Exception do
    begin
      if FileExists(TempPath) then
        DeleteFile(PWideChar(TempPath));
      raise;
    end;
  end;
end;





function IsGBKString(const Buffer: TBytes; Size: Integer): Boolean;
var
  ValidCount, InvalidCount: Integer;
begin
  AnalyzeGBKGlobal(Buffer, Size, ValidCount, InvalidCount);
  // 如果有效的GBK字符数量足够多，并且无效字符数量足够少，则认为是GBK编码
  Result := (ValidCount > 0) and (InvalidCount < ValidCount div 2);
end;



function IsBig5String(const Buffer: TBytes; Size: Integer): Boolean;
var
  ValidCount, InvalidCount: Integer;
begin
  AnalyzeBig5Global(Buffer, Size, ValidCount, InvalidCount);
  // 如果有效的Big5字符数量足够多，并且无效字符数量足够少，则认为是Big5编码
  Result := (ValidCount > 0) and (InvalidCount < ValidCount div 2);
end;



function IsShiftJISString(const Buffer: TBytes; Size: Integer): Boolean;
var
  ValidCount, InvalidCount: Integer;
begin
  AnalyzeShiftJISGlobal(Buffer, Size, ValidCount, InvalidCount);
  // 如果有效的Shift-JIS字符数量足够多，并且无效字符数量足够少，则认为是Shift-JIS编码
  Result := (ValidCount > 0) and (InvalidCount < ValidCount div 2);
end;



function IsEUCKRString(const Buffer: TBytes; Size: Integer): Boolean;
var
  ValidCount, InvalidCount: Integer;
begin
  AnalyzeEUCKRGlobal(Buffer, Size, ValidCount, InvalidCount);
  // 如果有效的EUC-KR字符数量足够多，并且无效字符数量足够少，则认为是EUC-KR编码
  Result := (ValidCount > 0) and (InvalidCount < ValidCount div 2);
end;

procedure AnalyzeEUCJPGlobal(const Buffer: TBytes; Size: Integer; out ValidCount, InvalidCount: Integer);
var
  i: Integer;
begin
  ValidCount := 0;
  InvalidCount := 0;
  i := 0;

  while i < Size do
  begin
    if Buffer[i] <= $7F then
    begin
      // ASCII字符
      Inc(i);
    end
    else if Buffer[i] = $8F then
    begin
      // JIS X 0212-1990（补充集）
      if (i + 2 < Size) and
         (Buffer[i + 1] >= $A1) and (Buffer[i + 1] <= $FE) and
         (Buffer[i + 2] >= $A1) and (Buffer[i + 2] <= $FE) then
      begin
        Inc(ValidCount);
        Inc(i, 3);
      end
      else
      begin
        Inc(InvalidCount);
        Inc(i);
      end;
    end
    else if Buffer[i] = $8E then
    begin
      // JIS X 0201片假名
      if (i + 1 < Size) and (Buffer[i + 1] >= $A1) and (Buffer[i + 1] <= $DF) then
      begin
        Inc(ValidCount);
        Inc(i, 2);
      end
      else
      begin
        Inc(InvalidCount);
        Inc(i);
      end;
    end
    else if (Buffer[i] >= $A1) and (Buffer[i] <= $FE) then
    begin
      // JIS X 0208-1990（基本集）
      if (i + 1 < Size) and (Buffer[i + 1] >= $A1) and (Buffer[i + 1] <= $FE) then
      begin
        Inc(ValidCount);
        Inc(i, 2);
      end
      else
      begin
        Inc(InvalidCount);
        Inc(i);
      end;
    end
    else
    begin
      Inc(InvalidCount);
      Inc(i);
    end;
  end;
end;

