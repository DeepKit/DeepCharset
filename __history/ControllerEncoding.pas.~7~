// 全局函数实现
procedure AnalyzeGBKGlobal(const Buffer: TBytes; Size: Integer; out ValidCount, InvalidCount: Integer);
var
  i: Integer;
begin
  ValidCount := 0;
  InvalidCount := 0;
  i := 0;

  while i < Size do
  begin
    if Buffer[i] <= $7F then
    begin
      // ASCII字符
      Inc(i);
    end
    else if (Buffer[i] >= $81) and (Buffer[i] <= $FE) and (i + 1 < Size) and
            (Buffer[i+1] >= $40) and (Buffer[i+1] <= $FE) and (Buffer[i+1] <> $7F) then
    begin
      // 有效的GBK字符
      Inc(ValidCount);
      Inc(i, 2);
    end
    else
    begin
      // 无效的GBK字符
      Inc(InvalidCount);
      Inc(i);
    end;
  end;
end;

procedure AnalyzeBig5Global(const Buffer: TBytes; Size: Integer; out ValidCount, InvalidCount: Integer);
var
  i: Integer;
begin
  ValidCount := 0;
  InvalidCount := 0;
  i := 0;

  while i < Size do
  begin
    if Buffer[i] <= $7F then
    begin
      // ASCII字符
      Inc(i);
    end
    else if (Buffer[i] >= $A1) and (Buffer[i] <= $F9) and (i + 1 < Size) and
            (((Buffer[i+1] >= $40) and (Buffer[i+1] <= $7E)) or
             ((Buffer[i+1] >= $A1) and (Buffer[i+1] <= $FE))) then
    begin
      // 有效的Big5字符
      Inc(ValidCount);
      Inc(i, 2);
    end
    else
    begin
      // 无效的Big5字符
      Inc(InvalidCount);
      Inc(i);
    end;
  end;
end;

procedure AnalyzeShiftJISGlobal(const Buffer: TBytes; Size: Integer; out ValidCount, InvalidCount: Integer);
var
  i: Integer;
begin
  ValidCount := 0;
  InvalidCount := 0;
  i := 0;

  while i < Size do
  begin
    if Buffer[i] <= $7F then
    begin
      // ASCII字符
      Inc(i);
    end
    else if (((Buffer[i] >= $81) and (Buffer[i] <= $9F)) or
             ((Buffer[i] >= $E0) and (Buffer[i] <= $FC))) and (i + 1 < Size) and
            ((Buffer[i+1] >= $40) and (Buffer[i+1] <= $FC) and (Buffer[i+1] <> $7F)) then
    begin
      // 有效的Shift-JIS字符
      Inc(ValidCount);
      Inc(i, 2);
    end
    else if (Buffer[i] >= $A1) and (Buffer[i] <= $DF) then
    begin
      // 半角片假名
      Inc(ValidCount);
      Inc(i);
    end
    else
    begin
      // 无效的Shift-JIS字符
      Inc(InvalidCount);
      Inc(i);
    end;
  end;
end;

procedure AnalyzeEUCKRGlobal(const Buffer: TBytes; Size: Integer; out ValidCount, InvalidCount: Integer);
var
  i: Integer;
begin
  ValidCount := 0;
  InvalidCount := 0;
  i := 0;

  while i < Size do
  begin
    if Buffer[i] <= $7F then
    begin
      // ASCII字符
      Inc(i);
    end
    else if (Buffer[i] >= $A1) and (Buffer[i] <= $FE) and (i + 1 < Size) and
            (Buffer[i+1] >= $A1) and (Buffer[i+1] <= $FE) then
    begin
      // 有效的EUC-KR字符
      Inc(ValidCount);
      Inc(i, 2);
    end
    else
    begin
      // 无效的EUC-KR字符
      Inc(InvalidCount);
      Inc(i);
    end;
  end;
end;

procedure AnalyzeEUCJPGlobal(const Buffer: TBytes; Size: Integer; out ValidCount, InvalidCount: Integer);
var
  i: Integer;
begin
  ValidCount := 0;
  InvalidCount := 0;
  i := 0;

  while i < Size do
  begin
    if Buffer[i] <= $7F then
    begin
      // ASCII字符
      Inc(i);
    end
    else if Buffer[i] = $8F then
    begin
      // JIS X 0212-1990（补充集）
      if (i + 2 < Size) and
         (Buffer[i + 1] >= $A1) and (Buffer[i + 1] <= $FE) and
         (Buffer[i + 2] >= $A1) and (Buffer[i + 2] <= $FE) then
      begin
        Inc(ValidCount);
        Inc(i, 3);
      end
      else
      begin
        Inc(InvalidCount);
        Inc(i);
      end;
    end
    else if Buffer[i] = $8E then
    begin
      // JIS X 0201片假名
      if (i + 1 < Size) and (Buffer[i + 1] >= $A1) and (Buffer[i + 1] <= $DF) then
      begin
        Inc(ValidCount);
        Inc(i, 2);
      end
      else
      begin
        Inc(InvalidCount);
        Inc(i);
      end;
    end
    else if (Buffer[i] >= $A1) and (Buffer[i] <= $FE) then
    begin
      // JIS X 0208-1990（基本集）
      if (i + 1 < Size) and (Buffer[i + 1] >= $A1) and (Buffer[i + 1] <= $FE) then
      begin
        Inc(ValidCount);
        Inc(i, 2);
      end
      else
      begin
        Inc(InvalidCount);
        Inc(i);
      end;
    end
    else
    begin
      Inc(InvalidCount);
      Inc(i);
    end;
  end;
end;

{ TEncodingController }

function TEncodingController.DetectBOMImproved(const Buffer: TBytes; out Encoding: TEncoding): Boolean;
var
  BOMType: string;
begin
  Result := True;
  BOMType := '';

  // UTF-8 BOM: EF BB BF
  if (Length(Buffer) >= 3) and (Buffer[0] = $EF) and (Buffer[1] = $BB) and (Buffer[2] = $BF) then
  begin
    Encoding := TEncoding.UTF8;
    BOMType := 'UTF-8 BOM';
  end
  // UTF-16BE BOM: FE FF
  else if (Length(Buffer) >= 2) and (Buffer[0] = $FE) and (Buffer[1] = $FF) then
  begin
    Encoding := TEncoding.BigEndianUnicode;
    BOMType := 'UTF-16BE BOM';
  end
  // UTF-16LE BOM: FF FE
  else if (Length(Buffer) >= 2) and (Buffer[0] = $FF) and (Buffer[1] = $FE) then
  begin
    // 检查是否是UTF-32LE BOM: FF FE 00 00
    if (Length(Buffer) >= 4) and (Buffer[2] = 0) and (Buffer[3] = 0) then
    begin
      // UTF-32LE not directly supported in older Delphi versions
      Encoding := TEncoding.Unicode;
      BOMType := 'UTF-32LE BOM';
    end
    else
    begin
      Encoding := TEncoding.Unicode;
      BOMType := 'UTF-16LE BOM';
    end;
  end
  // UTF-32BE BOM: 00 00 FE FF
  else if (Length(Buffer) >= 4) and (Buffer[0] = 0) and (Buffer[1] = 0) and (Buffer[2] = $FE) and (Buffer[3] = $FF) then
  begin
    // UTF-32BE not directly supported in older Delphi versions
    Encoding := TEncoding.BigEndianUnicode;
    BOMType := 'UTF-32BE BOM';
  end
  // UTF-7 BOM: 2B 2F 76 and one of: 38, 39, 2B, 2F
  else if (Length(Buffer) >= 4) and (Buffer[0] = $2B) and (Buffer[1] = $2F) and (Buffer[2] = $76) and
          ((Buffer[3] = $38) or (Buffer[3] = $39) or (Buffer[3] = $2B) or (Buffer[3] = $2F)) then
  begin
    // UTF-7 not directly supported in Delphi
    Encoding := TEncoding.ASCII; // 使用ASCII作为替代
    BOMType := 'UTF-7 BOM';
  end
  // UTF-1 BOM: F7 64 4C
  else if (Length(Buffer) >= 3) and (Buffer[0] = $F7) and (Buffer[1] = $64) and (Buffer[2] = $4C) then
  begin
    // UTF-1 not supported in Delphi
    Encoding := TEncoding.ASCII; // 使用ASCII作为替代
    BOMType := 'UTF-1 BOM';
  end
  // UTF-EBCDIC BOM: DD 73 66 73
  else if (Length(Buffer) >= 4) and (Buffer[0] = $DD) and (Buffer[1] = $73) and (Buffer[2] = $66) and (Buffer[3] = $73) then
  begin
    // UTF-EBCDIC not supported in Delphi
    Encoding := TEncoding.ASCII; // 使用ASCII作为替代
    BOMType := 'UTF-EBCDIC BOM';
  end
  // SCSU BOM: 0E FE FF
  else if (Length(Buffer) >= 3) and (Buffer[0] = $0E) and (Buffer[1] = $FE) and (Buffer[2] = $FF) then
  begin
    // SCSU not supported in Delphi
    Encoding := TEncoding.ASCII; // 使用ASCII作为替代
    BOMType := 'SCSU BOM';
  end
  // BOCU-1 BOM: FB EE 28
  else if (Length(Buffer) >= 3) and (Buffer[0] = $FB) and (Buffer[1] = $EE) and (Buffer[2] = $28) then
  begin
    // BOCU-1 not supported in Delphi
    Encoding := TEncoding.ASCII; // 使用ASCII作为替代
    BOMType := 'BOCU-1 BOM';
  end
  // GB18030 BOM: 84 31 95 33
  else if (Length(Buffer) >= 4) and (Buffer[0] = $84) and (Buffer[1] = $31) and (Buffer[2] = $95) and (Buffer[3] = $33) then
  begin
    Encoding := TEncoding.GetEncoding(54936); // GB18030
    BOMType := 'GB18030 BOM';
  end
  else
    Result := False;

  // 输出调试信息
  if Result and (BOMType <> '') and Assigned(FLogCallback) then
    FLogCallback('Detected BOM: ' + BOMType);
end;

// 检测是否是有效的UTF-8字节序列
function IsValidUTF8(const Buffer: PByte; Size: Integer): Boolean;
var
  i: Integer;
  ExpectedBytes: Integer;
  b: Byte;
begin
  Result := True;
  i := 0;

  while i < Size do
  begin
    b := Buffer[i];

    // 判断这个字节是否是UTF-8编码的开始字节
    if b < $80 then
    begin
      // ASCII字符 (0xxxxxxx)
      ExpectedBytes := 1;
    end
    else if (b and $E0) = $C0 then
    begin
      // 2字节序列 (110xxxxx 10xxxxxx)
      ExpectedBytes := 2;
    end
    else if (b and $F0) = $E0 then
    begin
      // 3字节序列 (1110xxxx 10xxxxxx 10xxxxxx)
      ExpectedBytes := 3;
    end
    else if (b and $F8) = $F0 then
    begin
      // 4字节序列 (11110xxx 10xxxxxx 10xxxxxx 10xxxxxx)
      ExpectedBytes := 4;
    end
    else
    begin
      // 无效的UTF-8开始字节
      Result := False;
      Exit;
    end;

    // 检查是否有足够的字节
    if i + ExpectedBytes > Size then
    begin
      // 字节不足，可能是截断的UTF-8序列
      Result := False;
      Exit;
    end;

    // 检查后续字节是否符合UTF-8编码规则 (10xxxxxx)
    for var j := 1 to ExpectedBytes - 1 do
    begin
      if (Buffer[i + j] and $C0) <> $80 then
      begin
        // 后续字节不符合UTF-8编码规则
        Result := False;
        Exit;
      end;
    end;

    // 移动到下一个UTF-8字符
    Inc(i, ExpectedBytes);
  end;
end;

// 分析UTF-8编码的有效性，返回有效和无效字节数
procedure AnalyzeUTF8(const Buffer: PByte; Size: Integer; out ValidCount, InvalidCount: Integer);
var
  i: Integer;
  ExpectedBytes: Integer;
  b: Byte;
  IsValid: Boolean;
begin
  ValidCount := 0;
  InvalidCount := 0;
  i := 0;

  while i < Size do
  begin
    IsValid := True;
    b := Buffer[i];

    // 判断这个字节是否是UTF-8编码的开始字节
    if b < $80 then
    begin
      // ASCII字符 (0xxxxxxx)
      ExpectedBytes := 1;
      Inc(ValidCount);
      Inc(i);
      Continue;
    end
    else if (b and $E0) = $C0 then
    begin
      // 2字节序列 (110xxxxx 10xxxxxx)
      ExpectedBytes := 2;
    end
    else if (b and $F0) = $E0 then
    begin
      // 3字节序列 (1110xxxx 10xxxxxx 10xxxxxx)
      ExpectedBytes := 3;
    end
    else if (b and $F8) = $F0 then
    begin
      // 4字节序列 (11110xxx 10xxxxxx 10xxxxxx 10xxxxxx)
      ExpectedBytes := 4;
    end
    else
    begin
      // 无效的UTF-8开始字节
      Inc(InvalidCount);
      Inc(i);
      Continue;
    end;

    // 检查是否有足够的字节
    if i + ExpectedBytes > Size then
    begin
      // 字节不足，可能是截断的UTF-8序列
      Inc(InvalidCount);
      Inc(i);
      Continue;
    end;

    // 检查后续字节是否符合UTF-8编码规则 (10xxxxxx)
    for var j := 1 to ExpectedBytes - 1 do
    begin
      if (Buffer[i + j] and $C0) <> $80 then
      begin
        // 后续字节不符合UTF-8编码规则
        IsValid := False;
        Break;
      end;
    end;

    if IsValid then
      Inc(ValidCount)
    else
      Inc(InvalidCount);

    // 移动到下一个字节
    Inc(i, ExpectedBytes);
  end;
end;

// 改进的编码检测函数，增强对混合编码文件的检测能力
function TEncodingController.DetectFileEncodingImproved(const FileName: string; out EncodingName: string): Boolean;
var
  FileStream: TFileStream;
  Buffer: TBytes;
  SampleSize, FullSize: Integer;
  ASCIIScore, UTF8Score, ChineseScore, JapaneseScore, KoreanScore, Big5Score: Double;
  EUCJP_Score, GB18030_Score, ISO8859_Score, Windows125x_Score, KOI8_Score: Double;
  Encoding: TEncoding;
  StopWatch: TStopwatch;
  BOMDetected: Boolean;
  EncodingScores: array of record
    Name: string;
    Score: Double;
  end;
  i, MaxScoreIndex: Integer;
  MaxScore: Double;
  IsSmallFile: Boolean;
  MultipleEncodingDetected: Boolean;
  SecondBestScore: Double;
  SecondBestIndex: Integer;
  ScoreDifference: Double;
  UTF8ValidCount, UTF8InvalidCount: Integer;
  MixedEncodingDetected: Boolean;
  MixedEncodingName: string;
begin
  Result := False;
  EncodingName := '';
  StopWatch := TStopwatch.StartNew;

  try
    if not FileExists(FileName) then
    begin
      if Assigned(FLogCallback) then
        FLogCallback('文件不存在: ' + FileName);
      Exit;
    end;

    FileStream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyWrite);
    try
      // 获取文件大小
      FullSize := FileStream.Size;
      IsSmallFile := FullSize < 1024; // 小于1KB的文件视为小文件

      // 读取文件样本，对于小文件读取全部内容
      if IsSmallFile then
        SampleSize := FullSize
      else
        SampleSize := Min(FullSize, 8192); // 增加样本大小到8KB

      SetLength(Buffer, SampleSize);
      FileStream.ReadBuffer(Buffer[0], SampleSize);

      // 首先检测BOM
      BOMDetected := DetectBOMImproved(Buffer, Encoding);
      if BOMDetected then
      begin
        if Encoding = TEncoding.UTF8 then
          EncodingName := 'UTF-8 with BOM'
        else if Encoding = TEncoding.Unicode then
          EncodingName := 'UTF-16LE'
        else if Encoding = TEncoding.BigEndianUnicode then
          EncodingName := 'UTF-16BE'
        else
          EncodingName := 'Unknown with BOM';

        if Assigned(FLogCallback) then
          FLogCallback('检测到BOM编码: ' + EncodingName);

        Result := True;
        Exit;
      end;

      // 初始化编码评分数组
      SetLength(EncodingScores, 10);
      for i := 0 to High(EncodingScores) do
      begin
        EncodingScores[i].Name := '';
        EncodingScores[i].Score := 0;
      end;

      // 尝试检测UTF-8
      UTF8Score := 0;
      UTF8ValidCount := 0;
      UTF8InvalidCount := 0;

      // 改进的UTF-8检测，允许部分无效字节
      AnalyzeUTF8(PByte(Buffer), SampleSize, UTF8ValidCount, UTF8InvalidCount);

      if UTF8ValidCount > 0 then
      begin
        // 计算UTF-8的有效度
        UTF8Score := UTF8ValidCount / (UTF8ValidCount + UTF8InvalidCount);

        // 如果有效度足够高，则认为是UTF-8
        if UTF8Score > 0.95 then
        begin
          EncodingName := 'UTF-8';
          if Assigned(FLogCallback) then
            FLogCallback('检测到UTF-8编码 (无BOM) 置信度: ' + FormatFloat('0.00', UTF8Score));
          Result := True;
          Exit;
        end
        else if UTF8Score > 0.7 then
        begin
          // 可能是混合编码，记录UTF-8的评分
          EncodingScores[0].Name := 'UTF-8';
          EncodingScores[0].Score := UTF8Score;

          if Assigned(FLogCallback) then
            FLogCallback('可能是UTF-8混合编码 置信度: ' + FormatFloat('0.00', UTF8Score));
        end;
      end;

      // 尝试检测ASCII
      ASCIIScore := 0;
      var ASCIICount := 0;
      for var k := 0 to SampleSize - 1 do
        if Buffer[k] < $80 then
          Inc(ASCIICount);

      if SampleSize > 0 then
        ASCIIScore := ASCIICount / SampleSize;

      // 记录ASCII评分
      EncodingScores[1].Name := 'ASCII';
      EncodingScores[1].Score := ASCIIScore;

      if ASCIIScore > 0.99 then
      begin
        EncodingName := 'ASCII';
        if Assigned(FLogCallback) then
          FLogCallback('检测到ASCII编码 置信度: ' + FormatFloat('0.00', ASCIIScore));
        Result := True;
        Exit;
      end;

      // 如果文件内容很少，默认使用ANSI
      if SampleSize < 20 then
      begin
        EncodingName := 'ANSI';
        if Assigned(FLogCallback) then
          FLogCallback('文件太小，默认使用ANSI编码');
        Result := True;
        Exit;
      end;

      // 如果文件内容全是ASCII，默认使用ANSI
      if ASCIIScore = 1.0 then
      begin
        EncodingName := 'ANSI';
        if Assigned(FLogCallback) then
          FLogCallback('文件只包含ASCII字符，默认使用ANSI编码');
        Result := True;
        Exit;
      end;

      // 检测中文编码
      ChineseScore := 0;
      var GBKValidCount := 0;
      var GBKInvalidCount := 0;
      AnalyzeGBK(Buffer, SampleSize, GBKValidCount, GBKInvalidCount);

      if GBKValidCount > 0 then
      begin
        ChineseScore := GBKValidCount / (GBKValidCount + GBKInvalidCount);
        EncodingScores[2].Name := 'GBK';
        EncodingScores[2].Score := ChineseScore;

        if ChineseScore > 0.9 then
        begin
          // 检查是否只有GB2312字符
          var GB2312Only := True;
          var GBKCount := 0;
          var GB2312Count := 0;
          var j := 0;

          while j < SampleSize do
          begin
            if Buffer[j] <= $7F then
            begin
              Inc(j);
            end
            else if (Buffer[j] >= $81) and (Buffer[j] <= $FE) and (j + 1 < SampleSize) and
                    (Buffer[j+1] >= $40) and (Buffer[j+1] <= $FE) and (Buffer[j+1] <> $7F) then
            begin
              Inc(GBKCount);

              // 检查是否是GB2312字符范围
              if (Buffer[j] >= $A1) and (Buffer[j] <= $F7) and
                 (Buffer[j+1] >= $A1) and (Buffer[j+1] <= $FE) then
              begin
                Inc(GB2312Count);
              end
              else
              begin
                GB2312Only := False; // 存在非GB2312字符
              end;

              Inc(j, 2);
            end
            else
            begin
              Inc(j);
            end;
          end;

          // 如果文件中只有GB2312字符，则使用GB2312编码
          if (GB2312Count > 0) and ((GB2312Count = GBKCount) or (GB2312Count >= GBKCount * 0.9)) then
          begin
            EncodingName := 'GB2312';
            if Assigned(FLogCallback) then
              FLogCallback('检测到GB2312编码 置信度: ' + FormatFloat('0.00', ChineseScore));
            Result := True;
            Exit;
          end
          else
          begin
            EncodingName := 'GBK';
            if Assigned(FLogCallback) then
              FLogCallback('检测到GBK编码 置信度: ' + FormatFloat('0.00', ChineseScore));
            Result := True;
            Exit;
          end;
        end;
      end;

      // 检测Big5编码
      Big5Score := 0;
      var Big5ValidCount := 0;
      var Big5InvalidCount := 0;
      AnalyzeBig5(Buffer, SampleSize, Big5ValidCount, Big5InvalidCount);

      if Big5ValidCount > 0 then
      begin
        Big5Score := Big5ValidCount / (Big5ValidCount + Big5InvalidCount);
        EncodingScores[3].Name := 'BIG5';
        EncodingScores[3].Score := Big5Score;

        if Big5Score > 0.9 then
        begin
          EncodingName := 'BIG5';
          if Assigned(FLogCallback) then
            FLogCallback('检测到Big5编码 置信度: ' + FormatFloat('0.00', Big5Score));
          Result := True;
          Exit;
        end;
      end;

      // 检测日文编码
      JapaneseScore := 0;
      var ShiftJISValidCount := 0;
      var ShiftJISInvalidCount := 0;
      AnalyzeShiftJIS(Buffer, SampleSize, ShiftJISValidCount, ShiftJISInvalidCount);

      if ShiftJISValidCount > 0 then
      begin
        JapaneseScore := ShiftJISValidCount / (ShiftJISValidCount + ShiftJISInvalidCount);
        EncodingScores[4].Name := 'Shift-JIS';
        EncodingScores[4].Score := JapaneseScore;

        if JapaneseScore > 0.9 then
        begin
          EncodingName := 'Shift-JIS';
          if Assigned(FLogCallback) then
            FLogCallback('检测到Shift-JIS编码 置信度: ' + FormatFloat('0.00', JapaneseScore));
          Result := True;
          Exit;
        end;
      end;

      // 检测韩文编码
      KoreanScore := 0;
      var EUCKRValidCount := 0;
      var EUCKRInvalidCount := 0;
      AnalyzeEUCKR(Buffer, SampleSize, EUCKRValidCount, EUCKRInvalidCount);

      if EUCKRValidCount > 0 then
      begin
        KoreanScore := EUCKRValidCount / (EUCKRValidCount + EUCKRInvalidCount);
        EncodingScores[5].Name := 'EUC-KR';
        EncodingScores[5].Score := KoreanScore;

        if KoreanScore > 0.9 then
        begin
          EncodingName := 'EUC-KR';
          if Assigned(FLogCallback) then
            FLogCallback('检测到EUC-KR编码 置信度: ' + FormatFloat('0.00', KoreanScore));
          Result := True;
          Exit;
        end;
      end;

      // 检测欧洲语言编码
      ISO8859_Score := 0;
      Windows125x_Score := 0;
      KOI8_Score := 0;

      // 根据文件特征检测可能的欧洲编码
      var ISO8859Count := 0;
      var Windows125xCount := 0;
      var KOI8Count := 0;
      var CyrillicCount := 0;
      var LatinCount := 0;
      var GreekCount := 0;
      var TurkishCount := 0;

      for var j := 0 to SampleSize - 1 do
      begin
        if (Buffer[j] >= $A0) then // $FF是最大的字节值，所以不需要检查上限
        begin
          // 可能是ISO-8859系列编码
          Inc(ISO8859Count);

          // 检测西里尔字符
          if ((Buffer[j] >= $C0) and (Buffer[j] <= $DF)) or (Buffer[j] >= $E0) then // $FF是最大的字节值
            Inc(CyrillicCount);

          // 检测拉丁字符
          if ((Buffer[j] >= $C0) and (Buffer[j] <= $D6)) or ((Buffer[j] >= $D8) and (Buffer[j] <= $F6)) or
             (Buffer[j] >= $F8) then // $FF是最大的字节值
            Inc(LatinCount);

          // 检测希腊字符
          if ((Buffer[j] >= $B4) and (Buffer[j] <= $D1)) then
            Inc(GreekCount);

          // 检测土耳其字符
          if ((Buffer[j] = $D0) or (Buffer[j] = $DD) or (Buffer[j] = $DE) or (Buffer[j] = $F0) or
              (Buffer[j] = $FD) or (Buffer[j] = $FE)) then
            Inc(TurkishCount);
        end;

        if (Buffer[j] >= $80) and (Buffer[j] <= $9F) then
        begin
          // 可能是Windows-125x系列编码
          Inc(Windows125xCount);
        end;

        if ((Buffer[j] >= $80) and (Buffer[j] <= $9F)) or ((Buffer[j] >= $A0) and (Buffer[j] <= $BF)) then
        begin
          // 可能是KOI8系列编码
          Inc(KOI8Count);
        end;
      end;

      if SampleSize > 0 then
      begin
        ISO8859_Score := ISO8859Count / SampleSize;
        Windows125x_Score := Windows125xCount / SampleSize;
        KOI8_Score := KOI8Count / SampleSize;
      end;

      // 根据特征字符判断可能的编码
      if CyrillicCount > LatinCount then
      begin
        if Windows125x_Score > 0.1 then
        begin
          EncodingScores[6].Name := 'Windows-1251';
          EncodingScores[6].Score := Windows125x_Score;

          if Windows125x_Score > 0.3 then
          begin
            EncodingName := 'Windows-1251';
            if Assigned(FLogCallback) then
              FLogCallback('检测到Windows-1251编码 置信度: ' + FormatFloat('0.00', Windows125x_Score));
            Result := True;
            Exit;
          end;
        end
        else if KOI8_Score > 0.1 then
        begin
          EncodingScores[7].Name := 'KOI8-R';
          EncodingScores[7].Score := KOI8_Score;

          if KOI8_Score > 0.3 then
          begin
            EncodingName := 'KOI8-R';
            if Assigned(FLogCallback) then
              FLogCallback('检测到KOI8-R编码 置信度: ' + FormatFloat('0.00', KOI8_Score));
            Result := True;
            Exit;
          end;
        end;
      end
      else if GreekCount > LatinCount / 2 then
      begin
        EncodingScores[8].Name := 'Windows-1253';
        EncodingScores[8].Score := ISO8859_Score;

        if ISO8859_Score > 0.3 then
        begin
          EncodingName := 'Windows-1253';
          if Assigned(FLogCallback) then
            FLogCallback('检测到Windows-1253编码 置信度: ' + FormatFloat('0.00', ISO8859_Score));
          Result := True;
          Exit;
        end;
      end
      else if TurkishCount > 0 then
      begin
        EncodingScores[9].Name := 'Windows-1254';
        EncodingScores[9].Score := ISO8859_Score;

        if ISO8859_Score > 0.3 then
        begin
          EncodingName := 'Windows-1254';
          if Assigned(FLogCallback) then
            FLogCallback('检测到Windows-1254编码 置信度: ' + FormatFloat('0.00', ISO8859_Score));
          Result := True;
          Exit;
        end;
      end
      else if LatinCount > 0 then
      begin
        EncodingScores[6].Name := 'Windows-1252';
        EncodingScores[6].Score := ISO8859_Score;

        if ISO8859_Score > 0.3 then
        begin
          EncodingName := 'Windows-1252';
          if Assigned(FLogCallback) then
            FLogCallback('检测到Windows-1252编码 置信度: ' + FormatFloat('0.00', ISO8859_Score));
          Result := True;
          Exit;
        end;
      end;

      // 检测是否是混合编码
      MixedEncodingDetected := False;
      MaxScore := 0;
      MaxScoreIndex := -1;
      SecondBestScore := 0;
      SecondBestIndex := -1;

      // 找出最高评分和第二高评分
      for i := 0 to High(EncodingScores) do
      begin
        if (EncodingScores[i].Name <> '') and (EncodingScores[i].Score > MaxScore) then
        begin
          SecondBestScore := MaxScore;
          SecondBestIndex := MaxScoreIndex;
          MaxScore := EncodingScores[i].Score;
          MaxScoreIndex := i;
        end
        else if (EncodingScores[i].Name <> '') and (EncodingScores[i].Score > SecondBestScore) then
        begin
          SecondBestScore := EncodingScores[i].Score;
          SecondBestIndex := i;
        end;
      end;

      // 如果最高评分和第二高评分差距小，可能是混合编码
      if (MaxScoreIndex >= 0) and (SecondBestIndex >= 0) and (MaxScore > 0) and (SecondBestScore > 0) then
      begin
        ScoreDifference := MaxScore - SecondBestScore;

        if ScoreDifference < 0.2 then
        begin
          MixedEncodingDetected := True;
          MixedEncodingName := EncodingScores[MaxScoreIndex].Name + '/' + EncodingScores[SecondBestIndex].Name;

          if Assigned(FLogCallback) then
          begin
            FLogCallback('检测到可能的混合编码: ' + MixedEncodingName);
            FLogCallback('  第一编码: ' + EncodingScores[MaxScoreIndex].Name + ' 置信度: ' + FormatFloat('0.00', MaxScore));
            FLogCallback('  第二编码: ' + EncodingScores[SecondBestIndex].Name + ' 置信度: ' + FormatFloat('0.00', SecondBestScore));
          end;

          // 如果混合编码中包含UTF-8，优先使用UTF-8
          if (EncodingScores[MaxScoreIndex].Name = 'UTF-8') or (EncodingScores[SecondBestIndex].Name = 'UTF-8') then
          begin
            EncodingName := 'UTF-8';
            if Assigned(FLogCallback) then
              FLogCallback('混合编码中包含UTF-8，优先使用UTF-8');
            Result := True;
            Exit;
          end
          else
          begin
            // 使用评分最高的编码
            EncodingName := EncodingScores[MaxScoreIndex].Name;
            if Assigned(FLogCallback) then
              FLogCallback('使用混合编码中评分最高的编码: ' + EncodingName);
            Result := True;
            Exit;
          end;
        end;
      end;

      // 如果有一个编码的评分足够高，使用该编码
      if (MaxScoreIndex >= 0) and (MaxScore >= 0.7) then
      begin
        EncodingName := EncodingScores[MaxScoreIndex].Name;
        if Assigned(FLogCallback) then
          FLogCallback('使用评分最高的编码: ' + EncodingName + ' 置信度: ' + FormatFloat('0.00', MaxScore));
        Result := True;
        Exit;
      end;

      // 默认为ANSI
      EncodingName := 'ANSI';
      if Assigned(FLogCallback) then
        FLogCallback('未检测到特定编码，默认使用ANSI编码');
      Result := True;
    finally
      FileStream.Free;
      StopWatch.Stop;
      if Assigned(FLogCallback) then
        FLogCallback('编码检测耗时: ' + StopWatch.ElapsedMilliseconds.ToString + ' ms');
    end;
  except
    on E: Exception do
    begin
      if Assigned(FLogCallback) then
        FLogCallback('编码检测错误: ' + E.Message);
      EncodingName := 'ANSI'; // 出错时默认为ANSI
      Result := False;
    end;
  end;
end;

