                  // 如果临时修复文件仍然存在，清理它
                  if FileExists(FixedFile) then
                    DeleteFile(PChar(FixedFile));
                end;
              end;
            end;
          end
          else
          begin
            if Assigned(FLogCallback) then
              FLogCallback('警告：无法检测转换后的文件编码');
          end;
        end
        else
        begin
          if Assigned(FLogCallback) then
            FLogCallback('警告：转换后的文件不存在: ' + ActualFile);
