procedure TForm1.Log(const Msg: string);
begin
  if FBufferingLogs then
  begin
    // 缓冲模式：将日志添加到缓冲区
    FLogBuffer.Add(Msg);
  end
  else
  begin
    // 正常模式：直接添加到MemLog
    FUIHelper.AppendLog(MemLog, Msg);
  end;
end;

