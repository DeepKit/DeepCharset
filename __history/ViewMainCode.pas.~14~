end;

destructor TForm1.Destroy;
begin
  // 释放MVC架构组件
  FEncodingController.Free;
  FFileHelper.Free;
  FUIHelper.Free;
  FEncodingModel.Free;
  FConfig.Free;

  // 释放语言包装器
  FLanguageWrapper.Free;

  // 释放其他资源
  FLogBuffer.Free;
  FFileExtensions.Free;
