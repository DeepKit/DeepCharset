function TForm1.GetVersionInfo: string;
var
  VersionInfo: Pointer;
  VersionInfoSize: DWORD;
  FileInfo: PVSFixedFileInfo;
  FileInfoSize: DWORD;
  Dummy: DWORD;
  FilePath: string;
begin
  // 默认版本
  Result := '1.0.0';

  try
    // 获取当前程序路径
    FilePath := ParamStr(0);

    // 获取版本信息大小
    VersionInfoSize := GetFileVersionInfoSize(PChar(FilePath), Dummy);
    if VersionInfoSize = 0 then
      Exit;

    // 分配内存
    GetMem(VersionInfo, VersionInfoSize);
    try
      // 获取版本信息
      if not GetFileVersionInfo(PChar(FilePath), 0, VersionInfoSize, VersionInfo) then
        Exit;

      // 获取固定版本信息
      FileInfoSize := SizeOf(TVSFixedFileInfo);
      if not VerQueryValue(VersionInfo, '\\', Pointer(FileInfo), FileInfoSize) then
        Exit;

      // 格式化版本信息
      Result := Format('%d.%d.%d.%d',
        [HiWord(FileInfo^.dwFileVersionMS),
         LoWord(FileInfo^.dwFileVersionMS),
         HiWord(FileInfo^.dwFileVersionLS),
         LoWord(FileInfo^.dwFileVersionLS)]);
    finally
      // 释放内存
      FreeMem(VersionInfo);
    end;
  except
    // 如果出错，返回默认版本
    Result := '1.0.0';
  end;
end;

// 结束日志缓冲并一次性更新MemLog
procedure TForm1.EndLogBuffering;
var
  i: Integer;
begin
  FBufferingLogs := False;

  // 一次性添加所有缓冲的日志
  if FLogBuffer.Count > 0 then
  begin
    // 如果日志太多，只显示最后100条
    if FLogBuffer.Count > 100 then
    begin
      FUIHelper.AppendLog(MemLog, '共有 ' + IntToStr(FLogBuffer.Count) + ' 条日志，只显示最后100条...');
      for i := FLogBuffer.Count - 100 to FLogBuffer.Count - 1 do
        FUIHelper.AppendLog(MemLog, FLogBuffer[i]);
    end
    else
    begin
      for i := 0 to FLogBuffer.Count - 1 do
        FUIHelper.AppendLog(MemLog, FLogBuffer[i]);
    end;

    FLogBuffer.Clear;
