// 尝试将临时文件复制回原始位置
procedure TForm1.TryCopyTempToOriginal(const TempFile, OriginalFile: string);
const
  MaxAttempts = 5;
var
  RetryCount: Integer;
  SourceStream, DestStream: TFileStream;
begin
  RetryCount := 0;
  while RetryCount < MaxAttempts do
  begin
    try
      // 尝试以写入方式打开原始文件
      DestStream := TFileStream.Create(OriginalFile, fmOpenWrite or fmShareDenyWrite);
      try
        DestStream.Size := 0; // 清空原文件
        SourceStream := TFileStream.Create(TempFile, fmOpenRead or fmShareDenyNone);
        try
          SourceStream.Position := 0;
          DestStream.CopyFrom(SourceStream, SourceStream.Size);
          
          Log('成功强制覆盖原始文件!');
          Break; // 成功复制，退出循环
        finally
          SourceStream.Free;
        end;
      finally
        DestStream.Free;
      end;
    except
      on E: Exception do
      begin
        Inc(RetryCount);
        Log('尝试覆盖原始文件失败 (' + IntToStr(RetryCount) + '/' + IntToStr(MaxAttempts) + '): ' + E.Message);
        Sleep(1000); // 等待一秒后重试
        
        if RetryCount >= MaxAttempts then
        begin
          Log('无法覆盖原始文件，请手动复制:');
          Log('  源: ' + TempFile);
          Log('  目标: ' + OriginalFile);
          // 尽管无法覆盖，但转换本身已成功
        end;
      end;
    end;
  end;
end;

