function TForm1.GetEncodingByIndex(Index: Integer; out WithBOM: Boolean): TEncoding;
begin
  // 如果索引无效，返回系统默认编码
  if (Index < 0) or (Index >= Length(FEncodingList)) then
  begin
    Result := TEncoding.Default;
    WithBOM := False;
    Exit;
  end;
  
  // 如果是组标题，返回默认编码
  if FEncodingList[Index].IsGroup then
  begin
    Result := TEncoding.Default;
    WithBOM := False;
    Exit;
  end;

  // 获取编码信息
  var EncodingInfo := FEncodingList[Index];
  WithBOM := EncodingInfo.HasBOM;
  
  Log('选择编码: ' + EncodingInfo.Name + ', CodePage: ' + IntToStr(EncodingInfo.CodePage) + ', BOM: ' + BoolToStr(WithBOM, True));

  // 特殊处理：自动检测、二进制视图等
  case EncodingInfo.CodePage of
    -1: // 全部检测
      begin
        Result := TEncoding.Default;
        WithBOM := False;
      end;
    -2, -3: // 二进制视图
      begin
        Result := TEncoding.ASCII;
        WithBOM := False;
      end;
    0: // 系统默认
      begin
        Result := TEncoding.Default;
        WithBOM := False;
      end;
    1200: // UTF-16LE
      begin
        Result := TEncoding.Unicode;
        WithBOM := True;
      end;
    1201: // UTF-16BE
      begin
        Result := TEncoding.BigEndianUnicode;
        WithBOM := True;
      end;
    65001: // UTF-8
      begin
        Result := TEncoding.UTF8;
        // 明确使用EncodingInfo.HasBOM，确保不会被覆盖
        WithBOM := EncodingInfo.HasBOM;
        Log('选择了UTF-8编码，BOM设置: ' + BoolToStr(WithBOM, True));
      end;
    65000: // UTF-7
      begin
        Result := TEncoding.UTF7;
        WithBOM := False;
      end;
    529: // Windows-1252 (可能是打错了，529不是标准代码页)
      begin
        try
          Result := TEncoding.GetEncoding(1252); // 假设用户想要的是1252
          Log('警告: 529不是标准代码页，使用Windows-1252(1252)代替');
        except
          Result := TEncoding.Default;
          Log('警告: 无法获取代码页1252，使用系统默认编码');
        end;
      end;
    936: // GB2312
      begin
        try
          Result := TEncoding.GetEncoding(936);
        except
          Result := TEncoding.Default;
          Log('警告: 无法获取GB2312编码，使用系统默认编码');
        end;
      end;
    12000: // UTF-32
      begin
        try
          Result := TEncoding.GetEncoding(12000);
          WithBOM := True;
        except
          // 如果找不到编码，使用UTF-8
          Result := TEncoding.UTF8;
          WithBOM := True;
          Log('警告: 无法获取UTF-32编码，使用UTF-8代替');
        end;
      end;
    else // 其他编码页
      begin
        try
          Result := TEncoding.GetEncoding(EncodingInfo.CodePage);
        except
          // 如果找不到编码，使用默认编码
          Log('警告: 无法获取编码页 ' + IntToStr(EncodingInfo.CodePage) + 
              '，使用系统默认编码');
          Result := TEncoding.Default;
        end;
      end;
  end;
end;

