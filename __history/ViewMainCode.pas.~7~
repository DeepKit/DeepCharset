// 添加全选/取消切换函数
procedure TForm1.ToggleAllSelections;
var
  HasChecked, AllChecked: Boolean;
  i: Integer;
begin
  if StringGrid1.RowCount <= 1 then Exit;
  
  // 首先检查是否有任何选中项和是否全部选中
  HasChecked := False;
  AllChecked := True;
  
  for i := 1 to StringGrid1.RowCount - 1 do
  begin
    if StringGrid1.Cells[0, i] = '√' then
      HasChecked := True
    else
      AllChecked := False;
      
    if HasChecked and not AllChecked then
      Break; // 既有选中又有未选中，不需要继续检查
  end;
  
  // 根据当前状态决定是全选还是全不选
  // 如果全部选中或部分选中，则取消所有选择；否则全选
  for i := 1 to StringGrid1.RowCount - 1 do
  begin
    if HasChecked then // 如果有任何选中，则清除所有选择
      StringGrid1.Cells[0, i] := ''
    else // 如果没有任何选中，则全选
      StringGrid1.Cells[0, i] := '√';
  end;
  
  StringGrid1.Repaint;
end;

// 保留此方法作为向后兼容性
procedure TForm1.ConvertFilesToEncoding(const FolderPath: string; TargetEncoding: TEncoding; AddBOM: Boolean);
var
  Files: TArray<string>;
  FileName: string;
  TotalFiles, ConvertedFiles, FailedFiles, SkippedFiles: Integer;
  FileExtensions: TArray<string>;
  FileExtsFromCheckList: TArray<string>;
  i: Integer;
begin
  Log('注意: 使用旧版批量转换方法');
  TotalFiles := 0;
  ConvertedFiles := 0;
  FailedFiles := 0;
  SkippedFiles := 0;
  
  // 获取选中的文件扩展名
  SetLength(FileExtsFromCheckList, 0);
  for i := 0 to CheckListBox1.Items.Count - 1 do
  begin
    if CheckListBox1.Checked[i] then
    begin
      SetLength(FileExtsFromCheckList, Length(FileExtsFromCheckList) + 1);
      FileExtsFromCheckList[Length(FileExtsFromCheckList) - 1] := CheckListBox1.Items[i];
    end;
  end;
  
  // 如果没有选中任何扩展名，默认转换.pas和.dfm文件
  if Length(FileExtsFromCheckList) = 0 then
    FileExtensions := ['.pas', '.dfm']
  else
    FileExtensions := FileExtsFromCheckList;
  
  // 处理每种文件类型
  for var Ext in FileExtensions do
  begin
    Log('处理 ' + Ext + ' 文件...');
    
    // 获取所有指定扩展名的文件
    Files := TDirectory.GetFiles(FolderPath, '*' + Ext, TSearchOption.soAllDirectories);
    TotalFiles := TotalFiles + Length(Files);
    Log(Format('找到 %d 个 %s 文件', [Length(Files), Ext]));
    
    // 处理文件
    for FileName in Files do
    begin
      try
        Log('处理: ' + FileName);
        
        var ConversionResult := ConvertFileEncoding(FileName, FileName, TargetEncoding, AddBOM);
        case ConversionResult of
          crSuccess: Inc(ConvertedFiles);
          crSkipped: Inc(SkippedFiles);
          crFailed: Inc(FailedFiles);
        end;
      except
        on E: Exception do
        begin
          Log('错误: ' + E.Message);
          Inc(FailedFiles);
        end;
      end;
    end;
  end;
  
  // 显示结果
  Log(Format('总结: 总文件数 %d, 成功转换 %d, 跳过 %d, 失败 %d', 
    [TotalFiles, ConvertedFiles, SkippedFiles, FailedFiles]));
  ShowMessage(Format('文件转换完成：总共处理 %d 个文件，成功转换 %d 个文件，' + 
                     '跳过 %d 个文件，失败 %d 个文件。',
    [TotalFiles, ConvertedFiles, SkippedFiles, FailedFiles]));
end;

