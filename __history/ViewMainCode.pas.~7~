procedure TForm1.UpdateFileGrid(const FolderPath: string);
var
  Files: TArray<string>;
  FileName: string;
  FileExt: string;
  i: Integer;
  DetectedEncoding: string;
  HasBomFlag: Boolean;
  CodePage: Integer;
begin
  StringGrid1.RowCount := 1;
  StringGrid1.ColCount := 3; // 增加一列用于Checkbox
  StringGrid1.Cells[0, 0] := FLanguageStrings.FileSelectColumn;
  StringGrid1.Cells[1, 0] := FLanguageStrings.FileNameColumn;
  StringGrid1.Cells[2, 0] := FLanguageStrings.EncodingColumn;
  StringGrid1.OnSelectCell := StringGridSelectCell;
  StringGrid1.OnClick := StringGrid1Click;

  try
    FFileList.Clear;

    // 获取选中的文件类型
    for i := 0 to CheckListBox1.Items.Count - 1 do
    begin
      if CheckListBox1.Checked[i] then
      begin
        FileExt := CheckListBox1.Items[i];
        Files := TDirectory.GetFiles(FolderPath, '*' + FileExt);
        for FileName in Files do
        begin
          // 检查文件是否是不支持的格式，如果是则跳过
          if not IsUnsupportedFile(FileName) then
            FFileList.Add(FileName);
        end;
      end;
    end;

    // 更新到表格StringGrid
    StringGrid1.BeginUpdate;
    try
      StringGrid1.RowCount := Max(2, FFileList.Count + 1);

      if FFileList.Count > 0 then
      begin
        for i := 0 to FFileList.Count - 1 do
        begin
          StringGrid1.Cells[0, i + 1] := '√'; // 默认全选
          StringGrid1.Cells[1, i + 1] := ExtractFileName(FFileList[i]);
          
          // 获取格式化的编码名称
          DetectedEncoding := DetectEncoding(FFileList[i]);
          HasBomFlag := HasBOM(FFileList[i]);
          
          // 尝试将数字编码转换为友好名称
          if TryStrToInt(DetectedEncoding, CodePage) then
            StringGrid1.Cells[2, i + 1] := GetFormattedEncodingName(CodePage, HasBomFlag)
          else
            StringGrid1.Cells[2, i + 1] := DetectedEncoding;
        end;
      end
      else
      begin
        StringGrid1.Cells[0, 1] := '';
        StringGrid1.Cells[1, 1] := FLanguageStrings.NoFilesText;
        StringGrid1.Cells[2, 1] := '';
      end;
    finally
      StringGrid1.EndUpdate;
    end;
  except
    on E: Exception do
    begin
      Log('Error: ' + E.Message);
      StringGrid1.RowCount := 2;
      StringGrid1.Cells[0, 1] := '';
      StringGrid1.Cells[1, 1] := FLanguageStrings.ReadErrorText;
      StringGrid1.Cells[2, 1] := '';
      FFileList.Clear;
    end;
  end;
end;

procedure TForm1.btnRefreshClick(Sender: TObject);
begin
  if FSelectedFolder <> '' then
  begin
    Screen.Cursor := crHourGlass;
    try
      DirectoryListBox1.Directory := FSelectedFolder;
      DirectoryListBox1.Update;
      
      // 更新文件扩展名和文件列表
      UpdateFileExtensions(FSelectedFolder);
      UpdateFileGrid(FSelectedFolder);
      
      Log('已刷新目录: ' + FSelectedFolder);
    finally
      Screen.Cursor := crDefault;
    end;
  end;
end;

procedure TForm1.btnSingleFileClick(Sender: TObject);
var
  FileName: string;
  TargetEncoding: TEncoding;
  WithBOM: Boolean;
  EncodingName: string;
  SourceCodePage: Integer;
  SourceEncodingName: string;
begin
  // 检查是否有选中的行
  if (FSelectedRow <= 0) or (FSelectedRow >= StringGrid1.RowCount) then
  begin
    ShowMessage('请先选择一个文件！');
    Exit;
  end;

  // 获取所选的目标编码
  TargetEncoding := GetEncodingByIndex(ListBox1.ItemIndex, WithBOM);
  
  // 特殊情况处理：全部检测等无法用于转换的选项
  if ListBox1.ItemIndex = 0 then // 全部检测
  begin
    ShowMessage('全部检测选项不能用于转换，请选择一个具体的编码格式！');
    Exit;
  end;
  
  // 获取编码名称
  if ListBox1.ItemIndex >= 0 then
    EncodingName := ListBox1.Items[ListBox1.ItemIndex]
  else
    EncodingName := '未知编码';

  // 记录选择的目标编码
  var TargetCodePage := GetEncodingCodePage(TargetEncoding);
  Log('选择的目标编码代码页: ' + IntToStr(TargetCodePage) + ', BOM设置: ' + BoolToStr(WithBOM, True));

  // 获取选中文件的完整路径
  if FFileList.Count >= FSelectedRow then
  begin
    FileName := FFileList[FSelectedRow - 1];
    if FileExists(FileName) then
    begin
      Screen.Cursor := crHourGlass;
      try
        // 获取源文件编码信息
        SourceEncodingName := StringGrid1.Cells[2, FSelectedRow];
        
        Log('开始转换文件: ' + FileName);
        Log('源编码: ' + SourceEncodingName);
        Log('目标编码: ' + EncodingName);
        Log('BOM设置: ' + BoolToStr(WithBOM, True));
        
        // 使用我们自己的转换方法，支持指定编码和BOM设置
        var Result := ConvertFileEncoding(FileName, FileName, TargetEncoding, WithBOM);
        
        if Result = crSuccess then
        begin
          // 获取最新的源文件编码信息
          if TryStrToInt(DetectEncoding(FileName), SourceCodePage) then
            SourceEncodingName := GetFormattedEncodingName(SourceCodePage, HasBOM(FileName));
          
          ShowMessage(Format('文件 %s 转换成功！' + #13#10 + 
                             '从: %s' + #13#10 +
                             '到: %s', 
                             [ExtractFileName(FileName), 
                              SourceEncodingName, 
                              EncodingName]));
          // 刷新文件显示
          UpdateFileGrid(FSelectedFolder);
        end
        else if Result = crSkipped then
          ShowMessage(Format('文件 %s 已经是目标编码 (%s)，跳过转换', 
                             [ExtractFileName(FileName), EncodingName]))
        else
          ShowMessage(Format('文件 %s 转换失败', [ExtractFileName(FileName)]));
      finally
        Screen.Cursor := crDefault;
      end;
    end
    else
      ShowMessage('文件不存在：' + ExtractFileName(FileName));
  end;
end;

procedure TForm1.btnConvertClick(Sender: TObject);
begin
  if FSelectedFolder = '' then
  begin
    ShowMessage('请先选择一个目录!');
    Exit;
  end;

  if not System.SysUtils.DirectoryExists(FSelectedFolder) then
  begin
    ShowMessage('所选目录不存在!');
    Exit;
  end;

  // 检查是否有文件被选中
  var HasSelectedFiles := False;
  for var i := 1 to StringGrid1.RowCount - 1 do
  begin
    if StringGrid1.Cells[0, i] = '√' then
    begin
      HasSelectedFiles := True;
      Break;
    end;
  end;
  
  if not HasSelectedFiles then
  begin
    ShowMessage('请先选择要转换的文件!');
    Exit;
  end;

  // 确认是否转换
  if MessageDlg('确认要将选中的文件转换为所选编码格式吗?' + #13#10 +
                '注意: 操作前会自动备份原始文件', 
     mtConfirmation, [mbYes, mbNo], 0) = mrYes then
  begin
    Screen.Cursor := crHourGlass;
    try
      memLog.Clear;
      Log('开始转换文件...');
      
      // 获取所选的目标编码
      var TargetEncoding: TEncoding;
      var EncodingName: string;
      var WithBOM: Boolean;
      
      // 使用GetEncodingByIndex函数获取编码
      TargetEncoding := GetEncodingByIndex(ListBox1.ItemIndex, WithBOM);
      
      // 特殊情况处理：全部检测等无法用于转换的选项
      if ListBox1.ItemIndex = 0 then // 全部检测
      begin
        ShowMessage('全部检测选项不能用于转换，请选择一个具体的编码格式！');
        Exit;
      end;
      
      // 获取编码名称
      if ListBox1.ItemIndex >= 0 then
        EncodingName := ListBox1.Items[ListBox1.ItemIndex]
      else
        EncodingName := '未知编码';
      
      Log('选择的目标编码: ' + EncodingName);
      Log('BOM设置: ' + BoolToStr(WithBOM, True));
      
      // 调用新的转换方法
      ConvertSelectedFilesToEncoding(TargetEncoding, WithBOM);
      Log('转换完成!');
    finally
      Screen.Cursor := crDefault;
    end;
  end;
end;

procedure TForm1.ConvertSelectedFilesToEncoding(TargetEncoding: TEncoding; AddBOM: Boolean);
var
  FileName, FullPath: string;
  TotalFiles, ConvertedFiles, FailedFiles, SkippedFiles: Integer;
  i: Integer;
begin
  TotalFiles := 0;
  ConvertedFiles := 0;
  FailedFiles := 0;
  SkippedFiles := 0;
  
  // 处理StringGrid中的选中文件
  for i := 1 to StringGrid1.RowCount - 1 do
  begin
    // 只处理选中的文件
    if StringGrid1.Cells[0, i] = '√' then
    begin
      FileName := StringGrid1.Cells[1, i];
      FullPath := PathWithSeparator(FSelectedFolder) + FileName;
      
      if FileExists(FullPath) then
      begin
        Inc(TotalFiles);
        Log('处理文件: ' + FullPath);
        
        try
          var ConversionResult := ConvertFileEncoding(FullPath, FullPath, TargetEncoding, AddBOM);
          case ConversionResult of
            crSuccess: 
            begin
              Inc(ConvertedFiles);
              // 更新编码信息显示
              var DetectedEncoding := DetectEncoding(FullPath);
              var HasBomFlag := HasBOM(FullPath);
              var CodePage: Integer;
              
              if TryStrToInt(DetectedEncoding, CodePage) then
                StringGrid1.Cells[2, i] := GetFormattedEncodingName(CodePage, HasBomFlag)
              else
                StringGrid1.Cells[2, i] := DetectedEncoding;
            end;
            crSkipped: Inc(SkippedFiles);
            crFailed: Inc(FailedFiles);
          end;
        except
          on E: Exception do
          begin
            Log('错误: ' + E.Message);
            Inc(FailedFiles);
          end;
        end;
      end
      else
      begin
        Log('文件不存在: ' + FullPath);
        Inc(FailedFiles);
      end;
    end;
  end;
  
  // 显示结果
  Log(Format('总结: 总文件数 %d, 成功转换 %d, 跳过 %d, 失败 %d', 
    [TotalFiles, ConvertedFiles, SkippedFiles, FailedFiles]));
  ShowMessage(Format('文件转换完成：总共处理 %d 个文件，成功转换 %d 个文件，' + 
                     '跳过 %d 个文件，失败 %d 个文件。',
    [TotalFiles, ConvertedFiles, SkippedFiles, FailedFiles]));
end;

// 获取编码的代码页
function TForm1.GetEncodingCodePage(Encoding: TEncoding): Integer;
begin
  Result := 0; // 默认未知
  
  if Encoding = TEncoding.ASCII then
    Result := 20127
  else if Encoding = TEncoding.UTF8 then
    Result := 65001
  else if Encoding = TEncoding.Unicode then
    Result := 1200
  else if Encoding = TEncoding.BigEndianUnicode then
    Result := 1201
  else if Encoding = TEncoding.Default then
    Result := GetACP
  else if Encoding = TEncoding.UTF7 then
    Result := 65000;
    
  // 尝试通过RTTI获取代码页 (适用于自定义编码)
  if Result = 0 then
  begin
    try
      var RTTIContext := TRttiContext.Create;
      try
        var EncodingType := RTTIContext.GetType(Encoding.ClassType);
        var CodePageField := EncodingType.GetField('FCodePage');
        if Assigned(CodePageField) then
          Result := CodePageField.GetValue(Encoding).AsInteger;
      finally
        RTTIContext.Free;
      end;
    except
      // 忽略异常
    end;
  end;
end;

