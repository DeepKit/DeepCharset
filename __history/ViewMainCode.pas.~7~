// 检查文件是否有BOM标记
function TForm1.HasBOM(const FileName: string; Encoding: TEncoding = nil): Boolean;
var
  Stream: TFileStream;
  Buffer: TBytes;
  BOM: TBytes;
begin
  Result := False;
  
  if not FileExists(FileName) then
    Exit;
  
  Stream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
  try
    if Stream.Size > 0 then
    begin
      SetLength(Buffer, Min(Stream.Size, 4)); // 读取前4个字节足够检测BOM
      Stream.ReadBuffer(Buffer[0], Length(Buffer));
      
      if Encoding = nil then
      begin
        // 检查所有已知BOM
        // UTF-8 BOM
        if (Length(Buffer) >= 3) and (Buffer[0] = $EF) and (Buffer[1] = $BB) and (Buffer[2] = $BF) then
          Result := True
        // UTF-16 LE BOM
        else if (Length(Buffer) >= 2) and (Buffer[0] = $FF) and (Buffer[1] = $FE) then
          Result := True
        // UTF-16 BE BOM
        else if (Length(Buffer) >= 2) and (Buffer[0] = $FE) and (Buffer[1] = $FF) then
          Result := True
        // UTF-32 LE BOM
        else if (Length(Buffer) >= 4) and (Buffer[0] = $FF) and (Buffer[1] = $FE) and (Buffer[2] = $00) and (Buffer[3] = $00) then
          Result := True;
      end
      else
      begin
        // 检查特定编码的BOM
        BOM := Encoding.GetPreamble;
        if Length(BOM) > 0 then
        begin
          Result := True;
          for var i := 0 to Length(BOM) - 1 do
          begin
            if (i >= Length(Buffer)) or (Buffer[i] <> BOM[i]) then
            begin
              Result := False;
              Break;
            end;
          end;
        end;
      end;
    end;
  finally
    Stream.Free;
  end;
end;

