// 获取编码的友好名称
function TForm1.GetEncodingName(Encoding: TEncoding): string;
begin
  if Encoding = nil then
    Result := '未知编码'
  else if Encoding = TEncoding.UTF8 then
    Result := 'UTF-8 (65001)'
  else if Encoding = TEncoding.Unicode then
    Result := 'UTF-16LE (1200)'
  else if Encoding = TEncoding.BigEndianUnicode then
    Result := 'UTF-16BE (1201)'
  else if Encoding = TEncoding.ASCII then
    Result := 'ASCII (20127)'
  else if Encoding = TEncoding.Default then
    Result := Format('ANSI/默认 (%d)', [GetACP])
  else
  begin
    try
      var CP := GetEncodingCodePage(Encoding);
      case CP of
        936: Result := 'GB2312/GBK (936)';
        950: Result := 'Big5 (950)';
        932: Result := 'Shift-JIS (932)';
        1252: Result := 'Windows-1252 (1252)';
        else Result := Format('CodePage %d', [CP]);
      end;
    except
      Result := '未知编码';
    end;
  end;
end;

// 添加IsUnsupportedFile方法实现
function TForm1.IsUnsupportedFile(const Filename: string): Boolean;
var
  i: Integer;
  ShortName: string;
begin
  Result := False;
  ShortName := ExtractFileName(Filename);
  
  for i := Low(UNSUPPORTED_FILES) to High(UNSUPPORTED_FILES) do
    if CompareText(ShortName, UNSUPPORTED_FILES[i]) = 0 then
      Exit(True);
end;


