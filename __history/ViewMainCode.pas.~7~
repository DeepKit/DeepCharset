// 将文件转换为指定编码
function TForm1.ConvertFileEncoding(const SourceFile, TargetFile: string; 
  TargetEncoding: TEncoding; AddBOM: Boolean): TConversionResult;
var
  UseTemp: Boolean;
  SourceFileToUse: string;
  BackupFile, TempFile: string;
  TargetPath: string;
  SourceEncoding: TEncoding;
  SourceCodePage: Integer;
  Buffer: TBytes;
  FileExt: string;
begin
  Result := crFailed;
  UseTemp := False;
  FileExt := LowerCase(ExtractFileExt(SourceFile));
  
  // 记录目标编码信息
  var TargetCodePage := GetEncodingCodePage(TargetEncoding);
  Log('目标编码代码页: ' + IntToStr(TargetCodePage) + ', BOM: ' + BoolToStr(AddBOM, True));
  
  // 检查源文件是否存在
  if not FileExists(SourceFile) then
  begin
    Log('文件不存在: ' + SourceFile);
    Exit;
  end;
  
  try
    // 检查文件是否被锁定，如果被锁定则使用临时文件
    if not CheckFileAccessibility(SourceFile, UseTemp) then
    begin
      Result := crFailed;
      Exit;
    end;
    
    // 如果需要使用临时文件，创建临时文件副本
    if UseTemp then
    begin
      TempFile := ChangeFileExt(SourceFile, '.temp' + ExtractFileExt(SourceFile));
      if not CreateTemporaryFileCopy(SourceFile, TempFile) then
      begin
        Result := crFailed;
        Exit;
      end;
      SourceFileToUse := TempFile;
    end
    else
      SourceFileToUse := SourceFile;

    // 根据文件名检测特定编码
    if Pos('gb2312', LowerCase(SourceFile)) > 0 then
      SourceCodePage := 936
    else if Pos('gbk', LowerCase(SourceFile)) > 0 then
      SourceCodePage := 936
    else if Pos('big5', LowerCase(SourceFile)) > 0 then
      SourceCodePage := 950
    else if Pos('shift_jis', LowerCase(SourceFile)) > 0 then
      SourceCodePage := 932
    else if Pos('euc-jp', LowerCase(SourceFile)) > 0 then
      SourceCodePage := 51932
    else if Pos('euc-kr', LowerCase(SourceFile)) > 0 then
      SourceCodePage := 51949
    else
      SourceCodePage := 0;

    // 读取源文件内容
    if not ReadFileContent(SourceFileToUse, Buffer) then
    begin
      Result := crFailed;
      Exit;
    end;

    // 检测源文件编码
    if SourceCodePage > 0 then
    begin
      try
        SourceEncoding := TEncoding.GetEncoding(SourceCodePage);
        Log('使用文件名指示的编码: ' + IntToStr(SourceCodePage));
      except
        SourceEncoding := nil;
      end;
    end;

    // 如果没有特定编码，尝试检测
    if SourceEncoding = nil then
    begin
      if HasBOM(SourceFileToUse) then
      begin
        if (Length(Buffer) >= 3) and (Buffer[0] = $EF) and (Buffer[1] = $BB) and (Buffer[2] = $BF) then
        begin
          SourceEncoding := TEncoding.UTF8;
          Log('检测到UTF-8 BOM');
        end
        else if (Length(Buffer) >= 2) and (Buffer[0] = $FF) and (Buffer[1] = $FE) then
        begin
          SourceEncoding := TEncoding.Unicode;
          Log('检测到UTF-16 LE BOM');
        end
        else if (Length(Buffer) >= 2) and (Buffer[0] = $FE) and (Buffer[1] = $FF) then
        begin
          SourceEncoding := TEncoding.BigEndianUnicode;
          Log('检测到UTF-16 BE BOM');
        end;
      end
      else if IsValidUTF8(@Buffer[0], Length(Buffer)) then
      begin
        SourceEncoding := TEncoding.UTF8;
        Log('检测到有效的UTF-8编码（无BOM）');
      end
      else
      begin
        // 尝试检测常见编码特征
        var HasGB2312Markers := False;
        var HasBig5Markers := False;
        
        for var i := 0 to Length(Buffer) - 2 do
        begin
          if (Buffer[i] >= $A1) and (Buffer[i] <= $F7) and 
             (Buffer[i+1] >= $A1) and (Buffer[i+1] <= $FE) then
          begin
            HasGB2312Markers := True;
            Break;
          end;
          
          if (Buffer[i] >= $A1) and (Buffer[i] <= $F9) and 
             (Buffer[i+1] >= $40) and (Buffer[i+1] <= $7E) then
          begin
            HasBig5Markers := True;
            Break;
          end;
        end;
        
        if HasGB2312Markers then
        begin
          try
            SourceEncoding := TEncoding.GetEncoding(936);
            Log('根据内容特征使用GB2312编码');
          except
            SourceEncoding := TEncoding.Default;
          end;
        end
        else if HasBig5Markers then
        begin
          try
            SourceEncoding := TEncoding.GetEncoding(950);
            Log('根据内容特征使用Big5编码');
          except
            SourceEncoding := TEncoding.Default;
          end;
        end
        else
        begin
          SourceEncoding := TEncoding.Default;
          Log('无法检测编码，使用系统默认编码');
        end;
      end;
    end;
    
    // 处理文件内容
    var Content := ProcessFileContent(Buffer, SourceFileToUse, SourceEncoding, SourceCodePage);
    
    // 处理行尾
    HandleLineEndings(SourceFile, Content);
    
    // 确定目标文件路径
    if UseTemp then
      TargetPath := ChangeFileExt(TempFile, '.out' + ExtractFileExt(SourceFile))
    else
      TargetPath := TargetFile;
    
    // 创建备份文件(如果需要)
    if (SourceFile = TargetFile) and not UseTemp then
      CreateBackupFile(SourceFile, BackupFile);
    
    // 转换并写入目标文件
    if WriteConvertedContent(Content, TargetPath, TargetEncoding, AddBOM) then
      Result := crSuccess
    else
    begin
      HandleWriteFailure(UseTemp, SourceFile, TargetPath);
      if UseTemp then
        Result := crSuccess
      else
        Result := crFailed;
    end;
    
    // 如果使用了临时文件，尝试复制回原始位置
    if UseTemp and (Result = crSuccess) then
      TryCopyTempToOriginal(TargetPath, SourceFile);
    
    // 记录编码转换日志
    if Result = crSuccess then
      LogConversionSuccess(SourceFile, GetEncodingCodePage(SourceEncoding), TargetCodePage, AddBOM);
    
  except
    on E: Exception do
    begin
      Log('转换过程出现异常: ' + E.Message);
      if (SourceFile = TargetFile) and FileExists(BackupFile) and not UseTemp then
        RestoreFromBackup(SourceFile, BackupFile);
      Result := crFailed;
    end;
  end;
end;

// 检查文件是否可访问
function TForm1.CheckFileAccessibility(const FileName: string; var UseTemp: Boolean): Boolean;
begin
  Result := True;
  
  try
    // 先尝试以只读方式打开文件测试是否可访问
    var Stream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
    try
      // 文件可以访问
      UseTemp := False;
    finally
      Stream.Free;
    end;
  except
    on E: Exception do
    begin
      // 文件被锁定，切换到临时文件模式
      Log('警告: 文件被锁定 - ' + E.Message);
      Log('尝试使用临时文件进行强制转换...');
      UseTemp := True;
    end;
  end;
end;

// 创建临时文件副本
function TForm1.CreateTemporaryFileCopy(const SourceFile, TempFile: string): Boolean;
const
  MaxAttempts = 5;
var
  RetryCount: Integer;
begin
  Result := False;
  
  // 如果临时文件已存在，删除它
  if FileExists(TempFile) then
    DeleteFile(TempFile);
  
  // 尝试多次复制文件
  RetryCount := 0;
  
  while RetryCount < MaxAttempts do
  begin
    try
      // 以共享只读方式复制文件
      var SourceStream := TFileStream.Create(SourceFile, fmOpenRead or fmShareDenyNone);
      try
        var DestStream := TFileStream.Create(TempFile, fmCreate);
        try
          SourceStream.Position := 0;
          var BufferSize := SourceStream.Size;
          var Buffer: TBytes;
          SetLength(Buffer, BufferSize);
          SourceStream.ReadBuffer(Buffer[0], BufferSize);
          DestStream.WriteBuffer(Buffer[0], BufferSize);
          
          Log('成功创建临时文件副本: ' + TempFile);
          Result := True;
          Break; // 成功复制，退出循环
        finally
          DestStream.Free;
        end;
      finally
        SourceStream.Free;
      end;
    except
      on E: Exception do
      begin
        Inc(RetryCount);
        Log('复制到临时文件失败，重试 (' + IntToStr(RetryCount) + '/' + IntToStr(MaxAttempts) + '): ' + E.Message);
        Sleep(500); // 短暂等待后重试
        
        if RetryCount >= MaxAttempts then
        begin
          Log('无法创建临时文件，转换失败');
          Result := False;
        end;
      end;
    end;
  end;
end;

// 检测源文件的代码页
function TForm1.DetectSourceCodePage(const FileName: string; SourceEncoding: TEncoding): Integer;
var
  DetectedCodePage: Integer;
begin
  Result := 0;
  
  // 获取源编码的代码页
  if SourceEncoding = TEncoding.ASCII then
    Result := 20127
  else if SourceEncoding = TEncoding.UTF8 then
    Result := 65001
  else if SourceEncoding = TEncoding.Unicode then
    Result := 1200
  else if SourceEncoding = TEncoding.BigEndianUnicode then
    Result := 1201
  else if SourceEncoding = TEncoding.Default then
  begin
    Result := GetACP; // 获取系统默认代码页
    Log('使用系统默认代码页: ' + IntToStr(Result));
  end;
  
  // 从文件名中检测源编码
  var FileEncoding := DetectEncoding(FileName);
  if TryStrToInt(FileEncoding, DetectedCodePage) then
    Result := DetectedCodePage;
end;

// 特别处理GB2312编码
procedure TForm1.HandleGB2312Encoding(SourceCodePage: Integer; var SourceEncoding: TEncoding);
begin
  if (SourceCodePage = 936) then
  begin
    try
      // 使用更详细的日志
      Log('检测到GB2312/GBK编码(936)，尝试使用专用编码对象...');
      SourceEncoding := TEncoding.GetEncoding(936);
      Log('成功创建GB2312/GBK(936)编码对象');
    except
      on E: Exception do
      begin
        Log('警告: 无法创建GB2312/GBK编码对象: ' + E.Message);
        Log('尝试使用系统默认ANSI编码代替...');
        SourceEncoding := TEncoding.Default;
      end;
    end;
  end;
end;

// 检查是否应该跳过转换
function TForm1.ShouldSkipConversion(const SourceFile, TargetFile: string; 
  SourceEncoding, TargetEncoding: TEncoding; AddBOM, UseTemp: Boolean): Boolean;
begin
  Result := False;
  
  // 如果源文件已经是目标编码，则跳过
  if (SourceEncoding = TargetEncoding) and (SourceFile = TargetFile) and not UseTemp then
  begin
    // 检查BOM情况
    var SourceHasBOM := HasBOM(SourceFile, SourceEncoding);
    // 只有当BOM状态也一致时才跳过
    if (SourceHasBOM and AddBOM) or (not SourceHasBOM and not AddBOM) then
    begin
      Log('文件已经是目标编码，跳过: ' + SourceFile);
      Result := True;
    end;
  end;
end;

// 创建备份文件
procedure TForm1.CreateBackupFile(const SourceFile: string; var BackupFile: string);
begin
  BackupFile := SourceFile + '.bak';
  if FileExists(BackupFile) then
    DeleteFile(BackupFile);
  CopyFile(PChar(SourceFile), PChar(BackupFile), False);
  Log('已创建备份: ' + BackupFile);
end;

// 读取文件内容
function TForm1.ReadFileContent(const FileName: string; var Buffer: TBytes): Boolean;
const
  ChunkSize = 1024 * 1024; // 1MB chunks
var
  SourceStream: TFileStream;
  BufferSize, TotalRead, ReadNow: Integer;
begin
  Result := False;
  
  try
    // 打开源文件
    SourceStream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
    try
      // 对于大文件使用分块读取
      BufferSize := SourceStream.Size;
      
      if BufferSize > 100 * ChunkSize then // 如果文件大于100MB，显示警告
        Log('警告: 处理大文件，可能需要较长时间: ' + FileName);
      
      // 读取源文件内容
      SetLength(Buffer, BufferSize);
      TotalRead := 0;
      
      while TotalRead < BufferSize do
      begin
        ReadNow := Min(ChunkSize, BufferSize - TotalRead);
        SourceStream.ReadBuffer(Buffer[TotalRead], ReadNow);
        Inc(TotalRead, ReadNow);
        
        // 对于非常大的文件，显示进度
        if BufferSize > 10 * ChunkSize then
          Log(Format('读取中: %.1f%%', [TotalRead / BufferSize * 100]));
      end;
      
      Result := True;
    finally
      SourceStream.Free;
    end;
  except
    on E: Exception do
    begin
      Log('读取文件失败: ' + E.Message);
      Result := False;
    end;
  end;
end;

// 处理文件内容并转换
function TForm1.ProcessFileContent(const Buffer: TBytes; const FileName: string;
  var SourceEncoding: TEncoding; SourceCodePage: Integer): string;
var
  ContentBytes: TBytes;
  FileExt: string;
begin
  Result := '';
  
  // 处理BOM
  if HasBOM(FileName) then
  begin
    var BomLength := 0;
    
    // 检测BOM类型
    if (Length(Buffer) >= 3) and (Buffer[0] = $EF) and (Buffer[1] = $BB) and (Buffer[2] = $BF) then
    begin
      BomLength := 3; // UTF-8 BOM
      Log('检测到UTF-8 BOM标记');
      SourceEncoding := TEncoding.UTF8;
    end
    else if (Length(Buffer) >= 2) and (Buffer[0] = $FF) and (Buffer[1] = $FE) then
    begin
      BomLength := 2; // UTF-16 LE BOM
      Log('检测到UTF-16 LE BOM标记');
      SourceEncoding := TEncoding.Unicode;
    end
    else if (Length(Buffer) >= 2) and (Buffer[0] = $FE) and (Buffer[1] = $FF) then
    begin
      BomLength := 2; // UTF-16 BE BOM
      Log('检测到UTF-16 BE BOM标记');
      SourceEncoding := TEncoding.BigEndianUnicode;
    end;
    
    // 跳过BOM字节
    if BomLength > 0 then
    begin
      SetLength(ContentBytes, Length(Buffer) - BomLength);
      Move(Buffer[BomLength], ContentBytes[0], Length(ContentBytes));
    end
    else
      ContentBytes := Buffer;
  end
  else
    ContentBytes := Buffer;
  
  // 如果没有提供编码，尝试检测
  if SourceEncoding = nil then
  begin
    FileExt := LowerCase(ExtractFileExt(FileName));
    
    // 根据文件名检测特定编码
    if Pos('gb2312', LowerCase(FileName)) > 0 then
      SourceCodePage := 936
    else if Pos('gbk', LowerCase(FileName)) > 0 then
      SourceCodePage := 936
    else if Pos('big5', LowerCase(FileName)) > 0 then
      SourceCodePage := 950
    else if Pos('shift_jis', LowerCase(FileName)) > 0 then
      SourceCodePage := 932
    else if Pos('euc-jp', LowerCase(FileName)) > 0 then
      SourceCodePage := 51932
    else if Pos('euc-kr', LowerCase(FileName)) > 0 then
      SourceCodePage := 51949;
    
    // 根据文件扩展名设置默认编码
    if (FileExt = '.txt') or (FileExt = '.md') or 
       (FileExt = '.java') or (FileExt = '.js') or 
       (FileExt = '.py') or (FileExt = '.cs') or 
       (FileExt = '.cpp') or (FileExt = '.h') or 
       (FileExt = '.hpp') then
    begin
      // 文本文件优先使用UTF-8
      if IsValidUTF8(@ContentBytes[0], Length(ContentBytes)) then
      begin
        SourceEncoding := TEncoding.UTF8;
        Log('检测到有效的UTF-8编码');
      end
      else if SourceCodePage > 0 then
      begin
        try
          SourceEncoding := TEncoding.GetEncoding(SourceCodePage);
          Log('使用指定的代码页: ' + IntToStr(SourceCodePage));
        except
          SourceEncoding := TEncoding.Default;
          Log('无法使用指定代码页，使用系统默认编码');
        end;
      end
      else
      begin
        // 尝试检测编码
        var HasGB2312Markers := False;
        var HasBig5Markers := False;
        
        for var i := 0 to Length(ContentBytes) - 2 do
        begin
          // 检查GB2312编码特征
          if (ContentBytes[i] >= $A1) and (ContentBytes[i] <= $F7) and 
             (ContentBytes[i+1] >= $A1) and (ContentBytes[i+1] <= $FE) then
          begin
            HasGB2312Markers := True;
            Break;
          end;
          
          // 检查Big5编码特征
          if (ContentBytes[i] >= $A1) and (ContentBytes[i] <= $F9) and 
             (ContentBytes[i+1] >= $40) and (ContentBytes[i+1] <= $7E) then
          begin
            HasBig5Markers := True;
            Break;
          end;
        end;
        
        if HasGB2312Markers then
        begin
          try
            SourceEncoding := TEncoding.GetEncoding(936);
            Log('根据内容特征使用GB2312编码');
          except
            SourceEncoding := TEncoding.Default;
          end;
        end
        else if HasBig5Markers then
        begin
          try
            SourceEncoding := TEncoding.GetEncoding(950);
            Log('根据内容特征使用Big5编码');
          except
            SourceEncoding := TEncoding.Default;
          end;
        end
        else
        begin
          SourceEncoding := TEncoding.Default;
          Log('无法检测编码，使用系统默认编码');
        end;
      end;
    end
    else
    begin
      // 非文本文件使用系统默认编码
      SourceEncoding := TEncoding.Default;
    end;
  end;
  
  try
    // 使用检测到的编码读取内容
    Result := SourceEncoding.GetString(ContentBytes);
  except
    on E: Exception do
    begin
      Log('使用' + GetEncodingName(SourceEncoding) + '读取失败: ' + E.Message);
      // 如果失败，尝试使用系统默认编码
      try
        SourceEncoding := TEncoding.Default;
        Result := SourceEncoding.GetString(ContentBytes);
        Log('使用系统默认编码成功读取内容');
      except
        on E2: Exception do
        begin
          Log('使用系统默认编码也失败: ' + E2.Message);
          // 最后尝试使用ASCII编码
          Result := TEncoding.ASCII.GetString(ContentBytes);
          Log('使用ASCII编码作为最后尝试');
        end;
      end;
    end;
  end;
end;

// 处理行尾
procedure TForm1.HandleLineEndings(const FileName: string; var Content: string);
var
  IsSourceCode: string;
  IsPasFile: Boolean;
  HasLFOnly: Boolean;
  ProcessedContent: string;
  i: Integer;
begin
  // 处理行尾问题 - 确保使用CRLF (适用于Delphi源文件)
  // 这段代码会检测文件的行尾类型，如果发现是LF（Unix风格）则转换为CRLF（Windows风格）
  IsSourceCode := ExtractFileExt(FileName).ToLower;
  IsPasFile := (IsSourceCode = '.pas') or 
               (IsSourceCode = '.dfm') or 
               (IsSourceCode = '.dpr') or 
               (IsSourceCode = '.dproj');
  
  if IsPasFile then
  begin
    // 检查当前行尾类型
    HasLFOnly := (Pos(#10, Content) > 0) and (Pos(#13#10, Content) = 0);
    
    if HasLFOnly then
    begin
      Log('检测到LF行尾，转换为CRLF');
      // 替换所有LF为CRLF
      ProcessedContent := '';
      for i := 1 to Length(Content) do
      begin
        if (Content[i] = #10) and ((i = 1) or (Content[i-1] <> #13)) then
          ProcessedContent := ProcessedContent + #13#10
        else
          ProcessedContent := ProcessedContent + Content[i];
      end;
      Content := ProcessedContent;
    end
    else
    begin
      Log('文件行尾已经是CRLF或混合格式');
    end;
  end;
end;

// 写入转换后的内容
function TForm1.WriteConvertedContent(const Content: string; const TargetPath: string; 
  TargetEncoding: TEncoding; AddBOM: Boolean): Boolean;
var
  EncodedContent: TBytes;
  DestStream: TFileStream;
  BOMBytes: TBytes;
begin
  Result := False;
  
  try
    // 转换内容到目标编码
    Log('正在转换为目标编码: ' + GetEncodingName(TargetEncoding) + ', BOM: ' + BoolToStr(AddBOM, True));
    
    // 对于UTF-8编码，确保总是使用正确的UTF-8编码方式
    if (TargetEncoding = TEncoding.UTF8) or 
       ((TargetEncoding <> nil) and (GetEncodingCodePage(TargetEncoding) = 65001)) then
    begin
      Log('使用UTF-8编码写入内容');
      
      if AddBOM then
      begin
        // 使用带BOM的UTF-8
        BOMBytes := TEncoding.UTF8.GetPreamble;
        EncodedContent := TEncoding.UTF8.GetBytes(Content);
        
        // 合并BOM和内容
        var TotalLength := Length(BOMBytes) + Length(EncodedContent);
        var FinalContent: TBytes;
        SetLength(FinalContent, TotalLength);
        if Length(BOMBytes) > 0 then
          Move(BOMBytes[0], FinalContent[0], Length(BOMBytes));
        if Length(EncodedContent) > 0 then
          Move(EncodedContent[0], FinalContent[Length(BOMBytes)], Length(EncodedContent));
        EncodedContent := FinalContent;
        
        Log('已添加UTF-8 BOM (EF BB BF)');
      end
      else
      begin
        // 使用不带BOM的UTF-8
        EncodedContent := TEncoding.UTF8.GetBytes(Content);
        Log('使用不带BOM的UTF-8编码');
      end;
    end
    else
    begin
      // 其他编码
      try
        if AddBOM then
        begin
          BOMBytes := TargetEncoding.GetPreamble;
          EncodedContent := TargetEncoding.GetBytes(Content);
          
          // 合并BOM和内容
          var TotalLength := Length(BOMBytes) + Length(EncodedContent);
          var FinalContent: TBytes;
          SetLength(FinalContent, TotalLength);
          if Length(BOMBytes) > 0 then
            Move(BOMBytes[0], FinalContent[0], Length(BOMBytes));
          if Length(EncodedContent) > 0 then
            Move(EncodedContent[0], FinalContent[Length(BOMBytes)], Length(EncodedContent));
          EncodedContent := FinalContent;
          
          Log('已添加目标编码的BOM');
        end
        else
          EncodedContent := TargetEncoding.GetBytes(Content);
      except
        on E: Exception do
        begin
          Log('使用目标编码转换失败: ' + E.Message);
          Log('尝试使用UTF-8编码作为备选...');
          
          // 如果目标编码转换失败，尝试使用UTF-8
          if AddBOM then
          begin
            BOMBytes := TEncoding.UTF8.GetPreamble;
            EncodedContent := TEncoding.UTF8.GetBytes(Content);
            
            var TotalLength := Length(BOMBytes) + Length(EncodedContent);
            var FinalContent: TBytes;
            SetLength(FinalContent, TotalLength);
            if Length(BOMBytes) > 0 then
              Move(BOMBytes[0], FinalContent[0], Length(BOMBytes));
            if Length(EncodedContent) > 0 then
              Move(EncodedContent[0], FinalContent[Length(BOMBytes)], Length(EncodedContent));
            EncodedContent := FinalContent;
          end
          else
            EncodedContent := TEncoding.UTF8.GetBytes(Content);
            
          Log('已切换到UTF-8编码');
        end;
      end;
    end;
    
    // 创建目标文件
    try
      DestStream := TFileStream.Create(TargetPath, fmCreate);
      try
        if Length(EncodedContent) > 0 then
        begin
          DestStream.WriteBuffer(EncodedContent[0], Length(EncodedContent));
          Log(Format('写入%d字节到文件', [Length(EncodedContent)]));
        end;
        
        Result := True;
        Log('成功写入到: ' + TargetPath);
      finally
        DestStream.Free;
      end;
    except
      on E: Exception do
      begin
        Log('创建或写入文件失败: ' + E.Message);
        // 尝试使用共享写入模式
        try
          DestStream := TFileStream.Create(TargetPath, fmCreate or fmShareDenyNone);
          try
            if Length(EncodedContent) > 0 then
            begin
              DestStream.WriteBuffer(EncodedContent[0], Length(EncodedContent));
              Log(Format('使用共享模式写入%d字节到文件', [Length(EncodedContent)]));
            end;
            
            Result := True;
            Log('使用共享模式成功写入到: ' + TargetPath);
          finally
            DestStream.Free;
          end;
        except
          on E2: Exception do
          begin
            Log('共享模式写入也失败: ' + E2.Message);
            Result := False;
          end;
        end;
      end;
    end;
  except
    on E: Exception do
    begin
      Log('写入文件失败: ' + E.Message);
      Result := False;
    end;
  end;
end;

// 处理写入失败
procedure TForm1.HandleWriteFailure(UseTemp: Boolean; const SourceFile, TargetPath: string);
begin
  // 如果是被锁定的文件，提供额外信息
  if UseTemp then
  begin
    Log('被锁定文件已转换到临时文件: ' + TargetPath);
    Log('请在退出Delphi后，手动将此文件复制到: ' + SourceFile);
    
    // 创建一个标记文件，供用户参考
    try
      var InfoFile := ChangeFileExt(TargetPath, '.info');
      var InfoStream := TStringList.Create;
      try
        InfoStream.Add('原始文件: ' + SourceFile);
        InfoStream.Add('临时文件: ' + TargetPath);
        InfoStream.Add('时间戳: ' + FormatDateTime('yyyy-mm-dd hh:nn:ss', Now));
