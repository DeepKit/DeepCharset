// 获取用户主目录路径
function TForm1.GetHomePath: string;
var
  Path: array[0..MAX_PATH] of Char;
begin
  if SHGetFolderPath(0, CSIDL_PERSONAL, 0, 0, Path) = S_OK then
    Result := Path
  else
    Result := GetCurrentDir;
end;

procedure TForm1.DirectoryListBox1MouseDown(Sender: TObject; Button: TMouseButton;
      Shift: TShiftState; X, Y: Integer);
var
  ItemIndex: Integer;
begin
  if Button = mbLeft then
  begin
    ItemIndex := DirectoryListBox1.ItemAtPos(Point(X, Y), True);
    if ItemIndex >= 0 then
    begin
      DirectoryListBox1.Directory := DirectoryListBox1.GetItemPath(ItemIndex);
      FSelectedFolder := DirectoryListBox1.Directory;
      UpdateFileExtensions(FSelectedFolder);
      UpdateFileGrid(FSelectedFolder);
    end;
  end;
end;

