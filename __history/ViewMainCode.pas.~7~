  begin
    LangInfo := LangInfoList[i];
    FLanguageComboBox.Items.AddObject(LangInfo.Name, TObject(NativeInt(i)));
  end;
  
  // 设置当前语言
  for i := 0 to FLanguageComboBox.Items.Count - 1 do
  begin
    LangInfo := LangInfoList[Integer(FLanguageComboBox.Items.Objects[i])];
    if LangInfo.Code = LanguageManager.CurrentLanguage then
    begin
      FLanguageComboBox.ItemIndex := i;
      Break;
    end;
  end;

end;

// 语言选择器变更事件
procedure TForm1.cmbLanguageChange(Sender: TObject);
var
  SelectedIndex: Integer;
  LangInfoList: TArray<TLanguageInfo>;
begin
  SelectedIndex := FLanguageComboBox.ItemIndex;
  if SelectedIndex >= 0 then
  begin
    LangInfoList := LanguageManager.GetLanguageList;
    if (SelectedIndex < Length(LangInfoList)) then
    begin
      SwitchToLanguageCode(LangInfoList[Integer(FLanguageComboBox.Items.Objects[SelectedIndex])].Code);
    end;
  end;
end;

// 切换到指定语言代码
procedure TForm1.SwitchToLanguageCode(const LangCode: string);
begin
  LanguageManager.SetLanguage(LangCode);
  FCurrentAppLanguage := GetLanguageEnumByCode(LangCode);
  FLanguageStrings := LanguageManager.GetLanguageStrings(LangCode);
  ApplyLanguageStrings;
end;

// 语言变更事件处理
procedure TForm1.OnLanguageChange(const LangCode: string);
begin
  // 更新UI界面语言
  FLanguageStrings := LanguageManager.GetLanguageStrings(LangCode);
  ApplyLanguageStrings;
  
  // 记录语言变更
  Log('已切换语言: ' + LanguageManager.GetLanguageNameByCode(LangCode));
end;

// 初始化程序
class procedure TForm1.Initialize;
begin
  // 确保语言管理器初始化
  if not Assigned(LanguageManager) then
  begin
    LanguageManager := TLanguageManager.Create;
    LanguageManager.Initialize;
  end;
end;



