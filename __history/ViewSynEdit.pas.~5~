unit ViewSynEdit;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ExtCtrls, Vcl.StdCtrls, System.IOUtils,
  SynEdit, SynEditHighlighter, SynHighlighterPas, SynHighlighterXML, SynHighlighterHtml,
  SynHighlighterCpp, SynHighlighterJava, SynHighlighterPython, SynHighlighterJSON,
  SynHighlighterSQL, SynHighlighterCS, SynHighlighterCSS, SynHighlighterJScript,
  SynHighlighterIni, SynHighlighterYAML, SynHighlighterTxt;

type
  TSynEditForm = class(TForm)
    Panel1: TPanel;
    btnClose: TButton;
    lblFileInfo: TLabel;
    procedure FormCreate(Sender: TObject);
    procedure btnCloseClick(Sender: TObject);
  private
    { Private declarations }
    FEditor: TSynEdit;
    FHighlighters: TDictionary<string, TSynCustomHighlighter>;
    
    procedure CreateSynEditor;
    procedure InitHighlighters;
    procedure ApplyHighlighter(const FileName: string);
    function GetHighlighterForFile(const FileName: string): TSynCustomHighlighter;
  public
    { Public declarations }
    constructor Create(AOwner: TComponent); override;
    destructor Destroy; override;
    procedure LoadFile(const FileName: string; Encoding: TEncoding);
    procedure SetFileInfo(const FileName, EncodingName: string; HasBOM: Boolean);
  end;

var
  SynEditForm: TSynEditForm;

implementation

{$R *.dfm}

constructor TSynEditForm.Create(AOwner: TComponent);
begin
  inherited Create(AOwner);
  FHighlighters := TDictionary<string, TSynCustomHighlighter>.Create;
  InitHighlighters;
end;

destructor TSynEditForm.Destroy;
begin
  // 释放所有语法高亮器
  for var Highlighter in FHighlighters.Values do
    Highlighter.Free;
  FHighlighters.Free;
  inherited;
end;

procedure TSynEditForm.btnCloseClick(Sender: TObject);
begin
  Close;
end;

procedure TSynEditForm.FormCreate(Sender: TObject);
begin
  try
    CreateSynEditor;
    Position := poScreenCenter;
    Width := 1000;
    Height := 700;
  except
    on E: Exception do
    begin
      ShowMessage('初始化编辑器失败: ' + E.Message);
    end;
  end;
end;

procedure TSynEditForm.CreateSynEditor;
begin
  try
    // 创建 SynEdit 编辑器
    FEditor := TSynEdit.Create(Self);
    FEditor.Parent := Self;
    FEditor.Align := alClient;
    FEditor.Font.Name := 'Consolas';
    FEditor.Font.Size := 10;
    FEditor.Font.Quality := fqClearType;
    
    // 设置编辑器属性
    FEditor.Gutter.ShowLineNumbers := True;
    FEditor.Gutter.AutoSize := True;
    FEditor.Options := FEditor.Options + [eoScrollPastEol, eoShowScrollHint];
    FEditor.WantTabs := True;
    FEditor.TabWidth := 4;
    FEditor.ReadOnly := True;
    
    // 设置颜色
    FEditor.Color := clWindow;
    FEditor.Gutter.Color := clBtnFace;
    
    // 设置Unicode支持
    FEditor.UTF8Text := '';
    
    Panel1.Align := alBottom;
  except
    on E: Exception do
      ShowMessage('创建编辑器失败: ' + E.Message);
  end;
end;

procedure TSynEditForm.InitHighlighters;
begin
  // 初始化所有支持的语法高亮器
  FHighlighters.Add('.pas', TSynPasSyn.Create(Self));
  FHighlighters.Add('.dpr', TSynPasSyn.Create(Self));
  FHighlighters.Add('.dfm', TSynPasSyn.Create(Self));
  FHighlighters.Add('.xml', TSynXMLSyn.Create(Self));
  FHighlighters.Add('.html', TSynHTMLSyn.Create(Self));
  FHighlighters.Add('.htm', TSynHTMLSyn.Create(Self));
  FHighlighters.Add('.cpp', TSynCppSyn.Create(Self));
  FHighlighters.Add('.h', TSynCppSyn.Create(Self));
  FHighlighters.Add('.java', TSynJavaSyn.Create(Self));
  FHighlighters.Add('.py', TSynPythonSyn.Create(Self));
  FHighlighters.Add('.json', TSynJSONSyn.Create(Self));
  FHighlighters.Add('.sql', TSynSQLSyn.Create(Self));
  FHighlighters.Add('.cs', TSynCSSyn.Create(Self));
  FHighlighters.Add('.css', TSynCssSyn.Create(Self));
  FHighlighters.Add('.js', TSynJScriptSyn.Create(Self));
  FHighlighters.Add('.ini', TSynIniSyn.Create(Self));
  FHighlighters.Add('.yaml', TSynYAMLSyn.Create(Self));
  FHighlighters.Add('.yml', TSynYAMLSyn.Create(Self));
  FHighlighters.Add('.txt', TSynTxtSyn.Create(Self));
end;

function TSynEditForm.GetHighlighterForFile(const FileName: string): TSynCustomHighlighter;
var
  Ext: string;
begin
  Result := nil;
  Ext := LowerCase(ExtractFileExt(FileName));
  if FHighlighters.ContainsKey(Ext) then
    Result := FHighlighters[Ext];
end;

procedure TSynEditForm.ApplyHighlighter(const FileName: string);
var
  Highlighter: TSynCustomHighlighter;
begin
  Highlighter := GetHighlighterForFile(FileName);
  FEditor.Highlighter := Highlighter;
end;

procedure TSynEditForm.LoadFile(const FileName: string; Encoding: TEncoding);
var
  Stream: TFileStream;
  Reader: TStreamReader;
  Content: string;
  MaxReadSize: Int64;
  IsBinary: Boolean;
  Buffer: TBytes;
  NonTextChars: Integer;
  i: Integer;
begin
  try
    // 检查文件是否存在
    if not FileExists(FileName) then
      raise Exception.Create('文件不存在');
      
    Stream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
    try
      // 检测二进制文件
      IsBinary := False;
      if Stream.Size > 0 then
      begin
        SetLength(Buffer, Min(Stream.Size, 1024));
        Stream.ReadBuffer(Buffer[0], Length(Buffer));
        Stream.Position := 0;
        
        // 检查是否包含二进制字符
        for i := 0 to High(Buffer) do
          if (Buffer[i] < 7) or ((Buffer[i] > 14) and (Buffer[i] < 32) and (Buffer[i] <> 9)) then
          begin
            IsBinary := True;
            Break;
          end;
      end;
      
      // 处理二进制文件
      if IsBinary then
      begin
        FEditor.Lines.Clear;
        FEditor.Lines.Add('(二进制文件，不显示内容)');
        Caption := ExtractFileName(FileName) + ' [二进制文件]';
        Exit;
      end;
      
      // 读取文本内容
      Stream.Position := 0;
      Reader := TStreamReader.Create(Stream, Encoding, True);
      try
        Content := Reader.ReadToEnd;
        FEditor.UTF8Text := Content;
        FEditor.Modified := False;
        
        // 应用语法高亮
        ApplyHighlighter(FileName);
        
        // 更新标题
        Caption := ExtractFileName(FileName);
      finally
        Reader.Free;
      end;
    finally
      Stream.Free;
    end;
  except
    on E: Exception do
    begin
      ShowMessage('加载文件失败: ' + E.Message);
      FEditor.Lines.Clear;
      FEditor.Lines.Add('无法加载文件。错误: ' + E.Message);
    end;
  end;
end;

procedure TSynEditForm.SetFileInfo(const FileName, EncodingName: string; HasBOM: Boolean);
var
  FileSize: Int64;
  BOMStr: string;
begin
  // 获取文件大小
  if FileExists(FileName) then
    FileSize := TFile.GetSize(FileName)
  else
    FileSize := 0;
    
  // BOM状态文本
  if HasBOM then
    BOMStr := '带BOM'
  else
    BOMStr := '无BOM';
    
  // 更新文件信息标签
  lblFileInfo.Caption := Format('文件: %s | 大小: %d 字节 | 编码: %s (%s) | 行数: %d',
    [ExtractFileName(FileName), FileSize, EncodingName, BOMStr, FEditor.Lines.Count]);
end;

end. 