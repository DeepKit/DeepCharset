end;

function TEncodingController.IsUnsupportedFile(const Filename: string): Boolean;
var
  BaseName: string;
  i: Integer;
begin
  BaseName := ExtractFileName(Filename);
  Result := False;
  
  for i := Low(UNSUPPORTED_FILES) to High(UNSUPPORTED_FILES) do
  begin
    if SameText(BaseName, UNSUPPORTED_FILES[i]) then
    begin
      Result := True;
      Break;
    end;
  end;
end;

function TEncodingController.HasBOM(const FileName: string; Encoding: TEncoding): Boolean;
var
  Stream: TFileStream;
  Preamble: TBytes;
  DetectedBytes: TBytes;
begin
  Result := False;
  
  if not FileExists(FileName) then
    Exit;
    
  try
    Stream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
    try
      if Encoding = nil then
        Encoding := TEncoding.UTF8;
        
      Preamble := Encoding.GetPreamble;
      
      if Length(Preamble) = 0 then
        Exit(False);
        
      SetLength(DetectedBytes, Length(Preamble));
      
      if Stream.Size < Length(Preamble) then
        Exit(False);
        
      Stream.ReadBuffer(DetectedBytes[0], Length(Preamble));
      
      // 比较BOM标记
      for var i := 0 to High(Preamble) do
      begin
        if Preamble[i] <> DetectedBytes[i] then
          Exit(False);
      end;
      
      Result := True;
    finally
      Stream.Free;
    end;
  except
    // 如果读取失败，假设没有BOM
    Result := False;
  end;
end;

function TEncodingController.DetectFileEncoding(const FileName: string; out EncodingName: string): Boolean;
begin
  // 使用iconv库检测文件编码
  try
    if not FileExists(FileName) then
    begin
      EncodingName := '';
      Result := False;
      Exit;
    end;
    
    // 调用iconv的编码检测方法
    Result := FIconvHelper.DetectFileEncoding(FileName, EncodingName);
    
    if Result then
       WriteLog('iconv detected file encoding: ' + FileName + ' -> ' + EncodingName); // 替换为 WriteLog
  except
    on E: Exception do
    begin
      WriteLog('Encoding detection error: ' + E.Message); // 替换为 WriteLog
      EncodingName := '';
      Result := False;
    end;
  end;
end;

function TEncodingController.ConvertWithIconv(const SourceFile, TargetFile: string;
  const SourceEncoding, TargetEncoding: string; AddBOM: Boolean): Boolean;
var
  SourceContent, TargetContent: TBytes;
  BOM: TBytes;
  BOMStream: TFileStream;
  BackupFile: string;
  TempFile: string;
  ErrorMsg: string;
begin
  Result := False;
  BackupFile := '';
  TempFile := '';
  
  try
    if not FileExists(SourceFile) then
    begin
      // if Assigned(FLogCallback) then
      //  FLogCallback('错误：源文件不存在 - ' + SourceFile);
      WriteLog('Error: Source file does not exist - ' + SourceFile); // 替换为 WriteLog
      Exit;
    end;
    
    // 创建备份文件
    BackupFile := SourceFile + '.bak';
    if FileExists(BackupFile) then
      DeleteFile(PChar(BackupFile));
    TFile.Copy(SourceFile, BackupFile);
    WriteLog('Backup created: ' + BackupFile); // 添加日志
    
    // 创建临时文件
    TempFile := TargetFile + '.tmp';
    if FileExists(TempFile) then
      DeleteFile(PChar(TempFile));
    WriteLog('Temp file path: ' + TempFile); // 添加日志
    
    // 读取源文件内容
    SourceContent := TFile.ReadAllBytes(SourceFile);
    
    // 使用iconv进行编码转换
    WriteLog('Attempting conversion: ' + SourceFile + ' (' + SourceEncoding + ') -> ' + TargetFile + ' (' + TargetEncoding + ')'); // 添加日志
    if FIconvHelper.ConvertEncoding(SourceContent, SourceEncoding, TargetEncoding, TargetContent) then
    begin
      WriteLog('iconv conversion successful (in memory). Writing to temp file...'); // 添加日志
      // 写入目标文件，考虑BOM
      if AddBOM then
      begin
        if TargetEncoding = 'UTF-8' then
          BOM := TEncoding.UTF8.GetPreamble
        else if (TargetEncoding = 'UTF-16LE') or (TargetEncoding = 'UTF-16') then
          BOM := TEncoding.Unicode.GetPreamble
        else if TargetEncoding = 'UTF-16BE' then
          BOM := TEncoding.BigEndianUnicode.GetPreamble
        else if TargetEncoding = 'UTF-32LE' then
          BOM := TEncoding.GetEncoding(12000).GetPreamble
        else if TargetEncoding = 'UTF-32BE' then
          BOM := TEncoding.GetEncoding(12001).GetPreamble
        else
          SetLength(BOM, 0);
          
        if Length(BOM) > 0 then
        begin
          // 先创建文件并写入BOM
          BOMStream := TFileStream.Create(TempFile, fmCreate);
          try
            WriteLog('Writing BOM (' + IntToStr(Length(BOM)) + ' bytes) to temp file.'); // 添加日志
            BOMStream.WriteBuffer(BOM[0], Length(BOM));
            WriteLog('Writing content (' + IntToStr(Length(TargetContent)) + ' bytes) to temp file.'); // 添加日志
            BOMStream.WriteBuffer(TargetContent[0], Length(TargetContent));
          finally
            BOMStream.Free;
          end;
        end 
        else
        begin 
          TFile.WriteAllBytes(TempFile, TargetContent);
          WriteLog('Writing content (' + IntToStr(Length(TargetContent)) + ' bytes) to temp file (no BOM).'); // 添加日志
        end;
      end 
      else
      begin 
        TFile.WriteAllBytes(TempFile, TargetContent);
        WriteLog('Writing content (' + IntToStr(Length(TargetContent)) + ' bytes) to temp file (BOM explicitly disabled).'); // 添加日志
      end;

      // 验证转换后的文件
      WriteLog('Validating converted file: ' + TempFile); // 添加日志
      if ValidateConvertedFile(TempFile, TargetEncoding) then
      begin
        // 如果验证通过，将临时文件移动到目标位置
        if FileExists(TargetFile) then
        begin
           WriteLog('Target file exists, deleting: ' + TargetFile); // 添加日志
           DeleteFile(PChar(TargetFile));
        end;
        WriteLog('Renaming temp file ' + TempFile + ' to ' + TargetFile); // 添加日志
        RenameFile(PChar(TempFile), PChar(TargetFile));
        Result := True;

        // 恢复原始调用
        WriteLog('Success: File converted to ' + TargetEncoding + ': ' + TargetFile);
      end
      else
      begin
        ErrorMsg := 'Error: Validation failed for converted file: ' + TempFile;
        // if Assigned(FLogCallback) then
        //  FLogCallback(ErrorMsg);
        WriteLog(ErrorMsg); // 替换为 WriteLog
        raise Exception.Create(ErrorMsg);
      end;
    end
    else
    begin
      ErrorMsg := 'Error: iconv encoding conversion failed for ' + SourceFile;
      // if Assigned(FLogCallback) then
      //  FLogCallback(ErrorMsg);
      WriteLog(ErrorMsg); // 替换为 WriteLog
      raise Exception.Create(ErrorMsg);
    end;
  except
    on E: Exception do
    begin
      WriteLog('Exception during conversion: ' + E.ClassName + ': ' + E.Message); // 添加异常日志
      // 清理临时文件
      if FileExists(TempFile) then
      begin
        WriteLog('Deleting temp file due to error: ' + TempFile); // 添加日志
        DeleteFile(PChar(TempFile));
      end ;

      // 恢复备份
      if FileExists(BackupFile) then
      begin
         WriteLog('Restoring from backup: ' + BackupFile + ' to ' + SourceFile); // 添加日志
        if FileExists(SourceFile) then
          DeleteFile(PChar(SourceFile));
        RenameFile(PChar(BackupFile), PChar(SourceFile));
      end;

      // if Assigned(FLogCallback) then
      //  FLogCallback('错误：' + E.Message); // 已在上面记录更详细的异常信息
      Result := False;
    end;
  end;
  
  // 清理备份文件
  if FileExists(BackupFile) then
  begin
    WriteLog('Deleting backup file: ' + BackupFile); // 添加日志
    DeleteFile(PChar(BackupFile));
  end
end;

function TEncodingController.ValidateConvertedFile(const FileName: string; const Encoding: string): Boolean;
var
  Content: TBytes;
  DetectedEncoding: string;
  HasBOM: Boolean;
  CodePg: Integer;
  EncObj: TEncoding;
begin
  Result := False;
  WriteLog('Starting validation for: ' + FileName + ', expecting encoding: ' + Encoding); // 添加日志

  try
    // 读取文件内容
    Content := TFile.ReadAllBytes(FileName);
    
    // 检测文件编码
    if FIconvHelper.DetectEncodingFromBytes(Content, DetectedEncoding) then
    begin
      WriteLog('Validation: Detected encoding ' + DetectedEncoding); // 添加日志
      // 检查BOM (分解步骤)
      CodePg := GetCodePage(Encoding);
      if CodePg = 0 then
      begin
         WriteLog('Validation Error: Unknown target encoding name for GetCodePage: ' + Encoding); // 添加日志
         Exit; // 无法获取 CodePage，验证失败
      end;
      EncObj := TEncoding.GetEncoding(CodePg); // 获取 TEncoding 对象
      HasBOM := HasBOM(FileName, EncObj); // 使用 TEncoding 对象调用 HasBOM
      WriteLog('Validation: Has BOM = ' + BoolToStr(HasBOM, True)); // 添加日志

      // 验证编码和BOM
      Result := SameText(DetectedEncoding, Encoding);

      if Result then
      begin
         WriteLog('Validation PASSED: Detected encoding matches expected (' + DetectedEncoding + '). BOM: ' + BoolToStr(HasBOM, True)); // 替换为 WriteLog
      end
      else
      begin
         WriteLog('Validation FAILED: Expected encoding ' + Encoding + ', but detected ' + DetectedEncoding); // 替换为 WriteLog
      end;

    end
    else
    begin
       WriteLog('Validation FAILED: Could not detect encoding for file: ' + FileName); // 替换为 WriteLog
    end;
  except
    on E: Exception do
    begin
      WriteLog('Validation Exception: ' + E.ClassName + ': ' + E.Message); // 替换为 WriteLog
    end;
  end;
end;

function TEncodingController.GetCodePage(const Encoding: string): Integer;
begin
  if SameText(Encoding, 'UTF-8') then
    Result := 65001
  else if SameText(Encoding, 'UTF-16LE') or SameText(Encoding, 'UTF-16') then
    Result := 1200
  else if SameText(Encoding, 'UTF-16BE') then
    Result := 1201
  else if SameText(Encoding, 'UTF-32LE') then
    Result := 12000
  else if SameText(Encoding, 'UTF-32BE') then
    Result := 12001
  else if SameText(Encoding, 'GBK') or SameText(Encoding, 'GB2312') then
    Result := 936
  else if SameText(Encoding, 'BIG5') then
    Result := 950
  else if SameText(Encoding, 'SHIFT-JIS') then
    Result := 932
  else if SameText(Encoding, 'EUC-KR') then
    Result := 949
  else if SameText(Encoding, 'ISO-8859-1') then
    Result := 28591
  else if SameText(Encoding, 'KOI8-R') then
    Result := 20866
  else
    Result := 0;
end;

// NEW: Internal helper to perform single file conversion using names
function TEncodingController.DoConvertSingleFileByName(const SourceFile: string;
  const TargetEncodingName: string; AddBOM: Boolean;
  UpdateCallback: TProc<string>): TConversionResult;
var
  TempFile, BackupFile: string;
  UseTemp: Boolean;
  SourceEncodingName: string;
  ConversionOk: Boolean;
begin
  Result := crFailed;
  TempFile := '';
  BackupFile := '';

  if not FileExists(SourceFile) or IsUnsupportedFile(SourceFile) then
  begin
    // if Assigned(FLogCallback) then
    //  FLogCallback('跳过: ' + SourceFile + ' (不支持或不存在)');
    WriteLog('Skipping: ' + SourceFile + ' (unsupported or does not exist)'); // 替换为 WriteLog
    Exit(crSkipped);
  end;

  if not CheckFileAccessibility(SourceFile, UseTemp) then
  begin
    // if Assigned(FLogCallback) then
    //  FLogCallback('错误: 无法访问文件 ' + SourceFile);
    WriteLog('Error: Cannot access file ' + SourceFile); // 替换为 WriteLog
    Exit(crFailed);
  end;

  CreateBackupFile(SourceFile, BackupFile);

  if UseTemp then
    TempFile := TPath.ChangeExtension(SourceFile, '.tmpconvert')
  else
    TempFile := SourceFile; 

  if not DetectFileEncoding(SourceFile, SourceEncodingName) then
  begin
     // if Assigned(FLogCallback) then
     //   FLogCallback('警告: 未能检测源编码 ' + SourceFile + ', 将尝试默认转换。');
     WriteLog('Warning: Failed to detect source encoding for ' + SourceFile + '. Attempting default conversion.'); // 替换为 WriteLog
     SourceEncodingName := '';
  end;

  try
    ConversionOk := ConvertWithIconv(SourceFile, TempFile, SourceEncodingName, TargetEncodingName, AddBOM);
  except
    on E: Exception do
    begin
      // if Assigned(FLogCallback) then
      //  FLogCallback('转换失败 (' + SourceFile + ' -> ' + TargetEncodingName + '): ' + E.Message);
      // ConvertWithIconv already logged the exception, maybe add context here?
      WriteLog('Exception caught in DoConvertSingleFileByName for ' + SourceFile + ' -> ' + TargetEncodingName + ': ' + E.Message); // Contextual log
      ConversionOk := False;
    end;
  end;

  if ConversionOk then
  begin
    if UseTemp then
      TryCopyTempToOriginal(TempFile, SourceFile);
      
    LogConversionSuccess(SourceFile);
    Result := crSuccess;
    
    // Call update callback DIRECTLY (Removed TTask.Run)
    if Assigned(UpdateCallback) then
    begin
      try
        UpdateCallback(SourceFile);
      except
        on E: Exception do
          // if Assigned(FLogCallback) then
          //   FLogCallback('UpdateCallback 失败 (' + SourceFile + '): ' + E.Message);
          WriteLog('UpdateCallback failed for ' + SourceFile + ': ' + E.Message); // 替换为 WriteLog
      end;
    end;

  end
  else
  begin
    // if Assigned(FLogCallback) then
    //  FLogCallback('错误: 转换失败，正在从备份恢复 ' + SourceFile);
    // Restore happens inside ConvertWithIconv's exception handler, which logs
    WriteLog('Conversion failed for ' + SourceFile + '. Restore should have happened.'); // Confirmation log
    // RestoreFromBackup(SourceFile, BackupFile); // This is likely redundant if ConvertWithIconv failed
    Result := crFailed;
  end;

  // Clean up temp and backup files
  // ConvertWithIconv should handle its own temp/backup cleanup on success/failure
  // This might be double cleanup or cleanup for cases where ConvertWithIconv wasn't called? Review needed.
  // For now, let's add logging here too.
  if (TempFile <> '') and FileExists(TempFile) and UseTemp then
  begin
    WriteLog('Cleaning up temp file: ' + TempFile); // 添加日志
    DeleteFile(PChar(TempFile));
  end;
  if (BackupFile <> '') and FileExists(BackupFile) then
  begin
     WriteLog('Cleaning up backup file: ' + BackupFile); // 添加日志
     DeleteFile(PChar(BackupFile));
  end;
end;

// NEW Public Method Implementation: ConvertSingleFileByName
function TEncodingController.ConvertSingleFileByName(const SourceFile: string; 
  const TargetEncodingName: string; AddBOM: Boolean; 
  UpdateCallback: TProc<string>): TConversionResult;
begin
  WriteLog('Starting ConvertSingleFileByName for: ' + SourceFile + ' to ' + TargetEncodingName); // 添加日志
  Result := DoConvertSingleFileByName(SourceFile, TargetEncodingName, AddBOM, UpdateCallback);
  WriteLog('Finished ConvertSingleFileByName for: ' + SourceFile + ' with result: ' + CRToStr(Result)); // 添加日志
end;

// NEW Public Method Implementation: ConvertFilesByName
procedure TEncodingController.ConvertFilesByName(const SelectedFiles: TArray<string>;
  const TargetEncodingName: string; AddBOM: Boolean;
  UpdateCallback: TProc<string>);
var
  i: Integer;
  FileToConvert: string;
  Total, SuccessCount, FailCount, SkipCount: Integer; // For summary
begin
  Total := Length(SelectedFiles);
  SuccessCount := 0;
  FailCount := 0;
  SkipCount := 0;

  // if Assigned(FLogCallback) then
  //  FLogCallback(Format('开始批量转换 %d 个文件到 %s', [Length(SelectedFiles), TargetEncodingName]));
  WriteLog(Format('Starting batch conversion of %d files to %s', [Total, TargetEncodingName])); // 替换为 WriteLog

  for i := 0 to High(SelectedFiles) do
  begin
    FileToConvert := SelectedFiles[i];
    // Call the internal helper for each file
    case DoConvertSingleFileByName(FileToConvert, TargetEncodingName, AddBOM, UpdateCallback) of
      crSuccess: Inc(SuccessCount);
      crFailed: Inc(FailCount);
      crSkipped: Inc(SkipCount);
    end;
    // Potential improvement: Use parallel tasks for conversion if safe
  end;

  // if Assigned(FLogCallback) then
  //  FLogCallback('批量转换完成。');
  WriteLog(Format('Batch conversion finished. Total: %d, Success: %d, Failed: %d, Skipped: %d', [Total, SuccessCount, FailCount, SkipCount])); // 替换为 WriteLog
end;

