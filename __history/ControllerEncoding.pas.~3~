// Helper function implementations (CheckFileAccessibility, CreateBackupFile, etc.)
// Assuming these helpers are already implemented correctly.
function TEncodingController.CheckFileAccessibility(const FileName: string; var UseTemp: Boolean): Boolean;
begin
  // Simplified check - should ideally check write permissions etc.
  Result := FileExists(FileName);
  UseTemp := True; // Assume we always need a temp file for safety
  if not Result then
    WriteLog('CheckAccessibility FAILED for ' + FileName);
  // else WriteLog('CheckAccessibility PASSED for ' + FileName); // Optional success log
end;

procedure TEncodingController.CreateBackupFile(const SourceFile: string; var BackupFile: string);
begin
  BackupFile := SourceFile + '.backup.' + FormatDateTime('yyyymmddhhnnsszzz', Now);
  try
    if FileExists(BackupFile) then DeleteFile(PChar(BackupFile)); // Ensure unique backup name didn't somehow collide
    TFile.Copy(SourceFile, BackupFile);
    WriteLog('Backup created: ' + SourceFile + ' -> ' + BackupFile);
  except
    on E: Exception do
    begin
      WriteLog('Failed to create backup for ' + SourceFile + ': ' + E.Message);
      BackupFile := ''; // Indicate backup failed
    end;
  end;
end;

procedure TEncodingController.TryCopyTempToOriginal(const TempFile, OriginalFile: string);
begin
  try
    // This might need more robust handling (e.g., delete original first?)
    if FileExists(OriginalFile) then DeleteFile(PChar(OriginalFile));
    RenameFile(PChar(TempFile), PChar(OriginalFile)); // Using RenameFile for atomicity if possible
    WriteLog('Temp file renamed to original: ' + TempFile + ' -> ' + OriginalFile);
  except
    on E: Exception do
      WriteLog('Failed to copy/rename temp file ' + TempFile + ' to ' + OriginalFile + ': ' + E.Message);
  end;
end;

procedure TEncodingController.LogConversionSuccess(const SourceFile: string);
begin
   WriteLog('Successfully processed: ' + SourceFile);
end;

procedure TEncodingController.RestoreFromBackup(const OriginalFile, BackupFile: string);
begin
  if (BackupFile = '') or not FileExists(BackupFile) then
  begin
    WriteLog('Cannot restore ' + OriginalFile + ': Backup file missing or invalid (' + BackupFile + ')');
    Exit;
  end;

  try
    if FileExists(OriginalFile) then DeleteFile(PChar(OriginalFile));
    RenameFile(PChar(BackupFile), PChar(OriginalFile));
    WriteLog('Restored from backup: ' + BackupFile + ' -> ' + OriginalFile);
  except
    on E: Exception do
      WriteLog('Failed to restore ' + OriginalFile + ' from backup ' + BackupFile + ': ' + E.Message);
  end;
end;

// Correct implementation signature for WriteLog
procedure TEncodingController.WriteLog(const LogMessage: string);
var
  // 修正：使用 TStreamWriter 替代 TFile.AppendAllLines
  LogWriter: TStreamWriter; 
begin
  try
    // Create/Open the file in append mode with UTF8 encoding
    LogWriter := TStreamWriter.Create(FLogFilePath, True, TEncoding.UTF8);
    try
      // Write the timestamp and message
      LogWriter.WriteLine(FormatDateTime('[yyyy-mm-dd hh:nn:ss] ', Now) + LogMessage);
    finally
      LogWriter.Free; // Close the file
    end;
  except
    on E: Exception do
      OutputDebugString(PChar('Failed to write to log file: ' + E.Message));
  end;
end;

end. 