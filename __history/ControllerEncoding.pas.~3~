begin
  inherited Create;
  // FLogCallback := ALogCallback; // 移除回调赋值
  FLogFilePath := TPath.Combine(TPath.GetDirectoryName(ParamStr(0)), 'controller_log.txt'); // 设置默认日志文件路径
  
