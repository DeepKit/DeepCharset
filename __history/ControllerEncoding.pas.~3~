// Helper function to convert TConversionResult to string
function CRToStr(AResult: TConversionResult): string;
begin
  case AResult of
    crSuccess: Result := 'Success';
    crFailed: Result := 'Failed';
    crSkipped: Result := 'Skipped';
  else
    Result := 'Unknown';
  end;
end;

