implementation

{$R *.dfm}

// Markdown高亮器的标记类型常量
const
  tkHeader = 0;
  tkEmphasis = 1;
  tkStrong = 2;
  tkCode = 3;
  tkLink = 4;
  tkList = 5;
  tkBlockquote = 6;
  tkLineBreak = 7;
  tkHtml = 8;
  tkSpace = 9;
  tkSymbol = 10;
  tkNull = 11;

{ TSynMarkdownSyn }

constructor TSynMarkdownSyn.Create(AOwner: TComponent);
begin
  inherited Create(AOwner);
  
  fHeaderAttri := TSynHighlighterAttributes.Create('Header', 'Header');
  fHeaderAttri.Style := [fsBold];
  fHeaderAttri.Foreground := clNavy;
  AddAttribute(fHeaderAttri);
  
  fEmphasisAttri := TSynHighlighterAttributes.Create('Emphasis', 'Emphasis');
  fEmphasisAttri.Style := [fsItalic];
  AddAttribute(fEmphasisAttri);
  
  fStrongAttri := TSynHighlighterAttributes.Create('Strong', 'Strong');
  fStrongAttri.Style := [fsBold];
  AddAttribute(fStrongAttri);
  
  fCodeAttri := TSynHighlighterAttributes.Create('Code', 'Code');
  fCodeAttri.Foreground := clTeal;
  fCodeAttri.Background := clCream;
  AddAttribute(fCodeAttri);
  
  fLinkAttri := TSynHighlighterAttributes.Create('Link', 'Link');
  fLinkAttri.Foreground := clBlue;
  fLinkAttri.Style := [fsUnderline];
  AddAttribute(fLinkAttri);
  
  fListAttri := TSynHighlighterAttributes.Create('List', 'List');
  fListAttri.Foreground := clMaroon;
  fListAttri.Style := [fsBold];
  AddAttribute(fListAttri);
  
  fBlockquoteAttri := TSynHighlighterAttributes.Create('Blockquote', 'Blockquote');
  fBlockquoteAttri.Style := [fsItalic];
  fBlockquoteAttri.Foreground := clGreen;
  AddAttribute(fBlockquoteAttri);
  
  fLineBreakAttri := TSynHighlighterAttributes.Create('LineBreak', 'LineBreak');
  fLineBreakAttri.Background := clSilver;
  AddAttribute(fLineBreakAttri);
  
  fHtmlAttri := TSynHighlighterAttributes.Create('Html', 'Html');
  fHtmlAttri.Foreground := clPurple;
  AddAttribute(fHtmlAttri);
  
  fSpaceAttri := TSynHighlighterAttributes.Create('Space', 'Space');
  AddAttribute(fSpaceAttri);
  
  fSymbolAttri := TSynHighlighterAttributes.Create('Symbol', 'Symbol');
  fSymbolAttri.Foreground := clRed;
  AddAttribute(fSymbolAttri);
  
  SetAttributesOnChange(DefHighlightChange);
  
  fDefaultFilter := 'Markdown Files (*.md,*.markdown)|*.md;*.markdown';
  ResetRange;
end;

procedure TSynMarkdownSyn.HeaderProc;
begin
  fTokenID := tkHeader;
  while not (CharInSet(fLine[fRun], [#0, #10, #13])) do
    Inc(fRun);
end;

procedure TSynMarkdownSyn.EmphasisProc;
begin
  if fLine[fRun] = '*' then
    fTokenID := tkEmphasis
  else if fLine[fRun] = '*' then
    fTokenID := tkStrong;
    
  Inc(fRun);
  while not (CharInSet(fLine[fRun], [#0, #10, #13, '*', '_'])) do
    Inc(fRun);
  if CharInSet(fLine[fRun], ['*', '_']) then
    Inc(fRun);
end;

procedure TSynMarkdownSyn.CodeProc;
begin
  fTokenID := tkCode;
  Inc(fRun);  // 跳过开始的`
  
  while not (CharInSet(fLine[fRun], [#0, #10, #13, '`'])) do
    Inc(fRun);
    
  if fLine[fRun] = '`' then
    Inc(fRun);  // 跳过结束的`
end;

procedure TSynMarkdownSyn.LinkProc;
begin
  fTokenID := tkLink;
  
  // 处理 [xxx](yyy) 格式的链接
  if fLine[fRun] = '[' then
  begin
    Inc(fRun); // 跳过 [
    while not (CharInSet(fLine[fRun], [#0, #10, #13, ']'])) do
      Inc(fRun);
      
    if fLine[fRun] = ']' then
      Inc(fRun); // 跳过 ]
      
    if fLine[fRun] = '(' then
    begin
      Inc(fRun); // 跳过 (
      while not (CharInSet(fLine[fRun], [#0, #10, #13, ')'])) do
        Inc(fRun);
        
      if fLine[fRun] = ')' then
        Inc(fRun); // 跳过 )
    end;
  end
  // 处理 ![xxx](yyy) 格式的图片
  else if (fLine[fRun] = '!') and (fLine[fRun + 1] = '[') then
  begin
    Inc(fRun, 2); // 跳过 ![
    while not (CharInSet(fLine[fRun], [#0, #10, #13, ']'])) do
      Inc(fRun);
      
    if fLine[fRun] = ']' then
      Inc(fRun); // 跳过 ]
      
    if fLine[fRun] = '(' then
    begin
      Inc(fRun); // 跳过 (
      while not (CharInSet(fLine[fRun], [#0, #10, #13, ')'])) do
        Inc(fRun);
        
      if fLine[fRun] = ')' then
        Inc(fRun); // 跳过 )
    end;
  end;
end;

procedure TSynMarkdownSyn.ListProc;
begin
  fTokenID := tkList;
  Inc(fRun);
  while (fLine[fRun] = ' ') do
    Inc(fRun);
end;

procedure TSynMarkdownSyn.BlockquoteProc;
begin
  fTokenID := tkBlockquote;
  Inc(fRun);
  while not (CharInSet(fLine[fRun], [#0, #10, #13])) do
    Inc(fRun);
end;

procedure TSynMarkdownSyn.SymbolProc;
begin
  fTokenID := tkSymbol;
  Inc(fRun);
end;

procedure TSynMarkdownSyn.NullProc;
begin
  fTokenID := tkNull;
  fEol := True;
end;

procedure TSynMarkdownSyn.CRProc;
begin
  fTokenID := tkSpace;
  Inc(fRun);
  if fLine[fRun] = #10 then
    Inc(fRun);
  fEol := True;
end;

procedure TSynMarkdownSyn.LFProc;
begin
  fTokenID := tkSpace;
  Inc(fRun);
  fEol := True;
end;

procedure TSynMarkdownSyn.SpaceProc;
begin
  fTokenID := tkSpace;
  repeat
    Inc(fRun);
  until not (CharInSet(fLine[fRun], [#1..#9, #11, #12, #14..#32]));
end;

procedure TSynMarkdownSyn.HtmlProc;
begin
  fTokenID := tkHtml;
  Inc(fRun);
  while not (CharInSet(fLine[fRun], [#0, #10, #13, '>'])) do
    Inc(fRun);
  if fLine[fRun] = '>' then
    Inc(fRun);
end;

procedure TSynMarkdownSyn.Next;
begin
  fTokenPos := fRun;
  
  case fLine[fRun] of
    #0: NullProc;
    #10: LFProc;
    #13: CRProc;
    #1..#9, #11, #12, #14..#32: SpaceProc;
    '#': HeaderProc;
    '*', '_': EmphasisProc;
    '`': CodeProc;
    '-', '+', '0'..'9': ListProc;
    '>': BlockquoteProc;
    '[', '!': LinkProc;
    '<': HtmlProc;
    else
      SymbolProc;
  end;
end;

function TSynMarkdownSyn.GetDefaultAttribute(Index: Integer): TSynHighlighterAttributes;
begin
  case Index of
    SYN_ATTR_COMMENT: Result := fBlockquoteAttri;
    SYN_ATTR_IDENTIFIER: Result := fEmphasisAttri;
    SYN_ATTR_KEYWORD: Result := fHeaderAttri;
    SYN_ATTR_STRING: Result := fLinkAttri;
    SYN_ATTR_WHITESPACE: Result := fSpaceAttri;
    SYN_ATTR_SYMBOL: Result := fSymbolAttri;
  else
    Result := nil;
  end;
end;

function TSynMarkdownSyn.GetEol: Boolean;
begin
  Result := fEol;
end;

function TSynMarkdownSyn.GetToken: string;
var
  Len: Integer;
begin
  Len := fRun - fTokenPos;
  SetString(Result, PChar(@fLine[fTokenPos + 1]), Len);
end;

function TSynMarkdownSyn.GetTokenAttribute: TSynHighlighterAttributes;
begin
  case fTokenID of
    tkHeader: Result := fHeaderAttri;
    tkEmphasis: Result := fEmphasisAttri;
    tkStrong: Result := fStrongAttri;
    tkCode: Result := fCodeAttri;
    tkLink: Result := fLinkAttri;
    tkList: Result := fListAttri;
    tkBlockquote: Result := fBlockquoteAttri;
    tkLineBreak: Result := fLineBreakAttri;
    tkHtml: Result := fHtmlAttri;
    tkSpace: Result := fSpaceAttri;
    tkSymbol: Result := fSymbolAttri;
    else Result := nil;
  end;
end;

function TSynMarkdownSyn.GetTokenKind: Integer;
begin
  Result := fTokenID;
end;

function TSynMarkdownSyn.GetTokenPos: Integer;
begin
  Result := fTokenPos;
end;

procedure TSynMarkdownSyn.ResetRange;
begin
  inherited;
end;

procedure TSynMarkdownSyn.SetLine(const NewValue: string; LineNumber: Integer);
begin
  fLine := NewValue;
  fLineNumber := LineNumber;
  fRun := 0;
  fEol := False;
  Next;
end;

function TSynMarkdownSyn.GetLanguageName: string;
begin
  Result := 'Markdown';
end;

class function TSynMarkdownSyn.GetFriendlyLanguageName: string;
begin
  Result := 'Markdown';
end;

procedure TForm2.btnCloseClick(Sender: TObject);
begin
  Close;
end;

procedure TForm2.FormCreate(Sender: TObject);
begin
  try
    // 初始化语法高亮器
    FHighlighterXML := TSynXMLSyn.Create(Self);
    FHighlighterHTML := TSynHTMLSyn.Create(Self);
    FHighlighterPas := TSynPasSyn.Create(Self);
    
    // 特别确保Pascal高亮器正确配置
    if Assigned(FHighlighterPas) then
    begin
      FHighlighterPas.KeyAttri.Foreground := clBlue;
      FHighlighterPas.StringAttri.Foreground := clRed;
      FHighlighterPas.CommentAttri.Foreground := clGreen;
      FHighlighterPas.NumberAttri.Foreground := clMaroon;
      OutputDebugString(PChar('Pascal高亮器初始化成功'));
    end
    else
      OutputDebugString(PChar('警告: Pascal高亮器创建失败'));
    
    FHighlighterJava := TSynJavaSyn.Create(Self);
    FHighlighterCpp := TSynCppSyn.Create(Self);
    FHighlighterPython := TSynPythonSyn.Create(Self);
    
    // 特别配置Python高亮器
    if Assigned(FHighlighterPython) then
    begin
      FHighlighterPython.KeyAttri.Foreground := clBlue;
      FHighlighterPython.StringAttri.Foreground := clRed;
      FHighlighterPython.CommentAttri.Foreground := clGreen;
      FHighlighterPython.NumberAttri.Foreground := clMaroon;
      FHighlighterPython.SymbolAttri.Foreground := clPurple;
      FHighlighterPython.IdentifierAttri.Foreground := clBlack;
      FHighlighterPython.NonKeyAttri.Foreground := clTeal; // 内置函数
      FHighlighterPython.SystemAttri.Foreground := clOlive; // 系统单词
      OutputDebugString(PChar('Python高亮器初始化成功'));
    end
    else
      OutputDebugString(PChar('警告: Python高亮器创建失败'));
    
    FHighlighterCS := TSynCSSyn.Create(Self);
    FHighlighterSQL := TSynSQLSyn.Create(Self);
    FHighlighterJS := TSynJScriptSyn.Create(Self);
    FHighlighterCSS := TSynCssSyn.Create(Self);
    FHighlighterJSON := TSynJSONSyn.Create(Self);
    FHighlighterIni := TSynIniSyn.Create(Self);
    FHighlighterBat := TSynBatSyn.Create(Self);
    FHighlighterVB := TSynVBSyn.Create(Self);
    FHighlighterPerl := TSynPerlSyn.Create(Self);
    FHighlighterPHP := TSynPHPSyn.Create(Self);
    FHighlighterTeX := TSynTeXSyn.Create(Self);
    FHighlighterRuby := TSynRubySyn.Create(Self);
    
    // 初始化Markdown高亮器
    FHighlighterMarkdown := TSynMarkdownSyn.Create(Self);
    OutputDebugString(PChar('Markdown高亮器初始化成功'));
    
    // 设置SynEdit基本属性
    SynEdit1.Gutter.ShowLineNumbers := True;
    SynEdit1.Font.Name := 'Consolas';
    SynEdit1.Font.Size := 10;
    SynEdit1.Options := SynEdit1.Options + [eoTabsToSpaces];
    SynEdit1.TabWidth := 2;
    
    // 设置窗体属性
    Position := poScreenCenter;
    
    // 检查高亮器状态
    CheckHighlightersStatus;
  except
    on E: Exception do
      ShowMessage('初始化高亮器失败: ' + E.Message);
  end;
end;

procedure TForm2.ApplyHighlighter(const FileName: string);
var
  Ext: string;
begin
  Ext := LowerCase(ExtractFileExt(FileName));
  
  // 先清除当前高亮
  SynEdit1.Highlighter := nil;
  
  // 调试信息
  OutputDebugString(PChar('正在为文件应用高亮: ' + FileName + ' 扩展名: ' + Ext));
  
  // Delphi/Pascal
  if (Ext = '.pas') or (Ext = '.dpr') or (Ext = '.dpk') or (Ext = '.inc') 
    or (Ext = '.dfm') or (Ext = '.fmx') then
  begin
    SynEdit1.Highlighter := FHighlighterPas;
    OutputDebugString(PChar('应用Pascal高亮器'));
    if FHighlighterPas = nil then
      OutputDebugString(PChar('警告: Pascal高亮器为nil'));
  end
    
  // XML相关
  else if (Ext = '.xml') or (Ext = '.svg') or (Ext = '.config') or (Ext = '.xsd') 
    or (Ext = '.xsl') or (Ext = '.xslt') or (Ext = '.dtd') or (Ext = '.resx') 
    or (Ext = '.manifest') then
    SynEdit1.Highlighter := FHighlighterXML
    
  // HTML相关
  else if (Ext = '.html') or (Ext = '.htm') or (Ext = '.shtml') or (Ext = '.xhtml') then
    SynEdit1.Highlighter := FHighlighterHTML
    
  // Java
  else if (Ext = '.java') or (Ext = '.jav') then
    SynEdit1.Highlighter := FHighlighterJava
    
  // C/C++
  else if (Ext = '.c') or (Ext = '.cpp') or (Ext = '.cc') or (Ext = '.h') 
    or (Ext = '.hpp') or (Ext = '.hh') or (Ext = '.cxx') or (Ext = '.hxx') then
    SynEdit1.Highlighter := FHighlighterCpp
    
  // Rust (使用C++高亮器作为替代)
  else if (Ext = '.rs') or (Ext = '.rust') then
  begin
    OutputDebugString(PChar('检测到Rust文件，使用C++高亮器作为替代'));
    if Assigned(FHighlighterCpp) then
    begin
      SynEdit1.Highlighter := FHighlighterCpp;
      Caption := ExtractFileName(FileName) + ' - [Rust (using C++ highlighter)]';
    end;
  end
    
  // Python
  else if (Ext = '.py') or (Ext = '.pyw') or (Ext = '.pyc') or (Ext = '.pyd') 
    or (Ext = '.pyo') then
  begin
    OutputDebugString(PChar('检测到Python文件，尝试应用Python高亮器'));
    if Assigned(FHighlighterPython) then
    begin
      SynEdit1.Highlighter := FHighlighterPython;
      OutputDebugString(PChar('已应用Python高亮器'));
      
      // 验证高亮器应用状态
      if SynEdit1.Highlighter = FHighlighterPython then
      begin
        OutputDebugString(PChar('确认: Python高亮器已成功应用'));
        // 确保关键字颜色设置正确
        if Assigned(FHighlighterPython.KeyAttri) then
          OutputDebugString(PChar('Python关键字颜色: ' + IntToStr(FHighlighterPython.KeyAttri.Foreground)));
      end
      else
        OutputDebugString(PChar('错误: Python高亮器应用失败'));
    end
    else
    begin
      OutputDebugString(PChar('警告: Python高亮器为nil，尝试使用C++高亮器替代'));
      if Assigned(FHighlighterCpp) then
        SynEdit1.Highlighter := FHighlighterCpp;
    end;
  end
    
  // C#
  else if (Ext = '.cs') then
    SynEdit1.Highlighter := FHighlighterCS
    
  // SQL
  else if (Ext = '.sql') or (Ext = '.ddl') or (Ext = '.dml') or (Ext = '.pls') 
    or (Ext = '.pks') or (Ext = '.pkb') then
    SynEdit1.Highlighter := FHighlighterSQL
    
  // JavaScript
  else if (Ext = '.js') or (Ext = '.jsx') or (Ext = '.mjs') then
    SynEdit1.Highlighter := FHighlighterJS
    
  // CSS
  else if (Ext = '.css') or (Ext = '.scss') or (Ext = '.sass') or (Ext = '.less') then
    SynEdit1.Highlighter := FHighlighterCSS
    
  // JSON
  else if (Ext = '.json') then
    SynEdit1.Highlighter := FHighlighterJSON
    
  // INI files
  else if (Ext = '.ini') or (Ext = '.inf') or (Ext = '.conf') or (Ext = '.cfg') 
    or (Ext = '.properties') then
    SynEdit1.Highlighter := FHighlighterIni
    
  // Batch files
  else if (Ext = '.bat') or (Ext = '.cmd') then
    SynEdit1.Highlighter := FHighlighterBat
    
  // Visual Basic
  else if (Ext = '.vb') or (Ext = '.bas') or (Ext = '.vbs') or (Ext = '.frm') 
    or (Ext = '.cls') then
    SynEdit1.Highlighter := FHighlighterVB
    
  // Perl
  else if (Ext = '.pl') or (Ext = '.pm') or (Ext = '.perl') then
    SynEdit1.Highlighter := FHighlighterPerl
    
  // PHP
  else if (Ext = '.php') or (Ext = '.php3') or (Ext = '.php4') or (Ext = '.php5') 
    or (Ext = '.phtml') then
    SynEdit1.Highlighter := FHighlighterPHP
    
  // TeX/LaTeX
  else if (Ext = '.tex') or (Ext = '.latex') or (Ext = '.sty') or (Ext = '.cls') 
    or (Ext = '.ltx') then
    SynEdit1.Highlighter := FHighlighterTeX
    
  // Ruby
  else if (Ext = '.rb') or (Ext = '.rbw') or (Ext = '.rake') or (Ext = '.gemspec') then
    SynEdit1.Highlighter := FHighlighterRuby
  
  // Markdown
  else if (Ext = '.md') or (Ext = '.markdown') or (Ext = '.mdown') or (Ext = '.mkd') then
  begin
    OutputDebugString(PChar('检测到Markdown文件，应用Markdown高亮器'));
    SynEdit1.Highlighter := FHighlighterMarkdown;
  end
    
  // 未知扩展名时尝试基于内容进行智能检测
  else
  begin
    OutputDebugString(PChar('未知扩展名: ' + Ext + '，尝试智能检测文件类型'));
    // 如果文件内容第一行包含Python特征，仍应用Python高亮
    if (SynEdit1.Lines.Count > 0) and 
       ((Pos('python', LowerCase(SynEdit1.Lines[0])) > 0) or 
        (Pos('#!/usr/bin', SynEdit1.Lines[0]) = 1) or
        (Pos('# -*- coding', SynEdit1.Lines[0]) > 0)) then
    begin
      OutputDebugString(PChar('检测到可能的Python文件内容，应用Python高亮器'));
      SynEdit1.Highlighter := FHighlighterPython;
    end
    // 如果文件内容看起来像Rust
    else if (SynEdit1.Lines.Count > 0) and
            ((Pos('fn main', LowerCase(SynEdit1.Lines.Text)) > 0) or
             (Pos('use std', LowerCase(SynEdit1.Lines.Text)) > 0) or
             (Pos('impl ', LowerCase(SynEdit1.Lines.Text)) > 0) or
             (Pos('struct ', LowerCase(SynEdit1.Lines.Text)) > 0)) then
    begin
      OutputDebugString(PChar('检测到可能的Rust文件内容，使用C++高亮器'));
      SynEdit1.Highlighter := FHighlighterCpp;
      Caption := ExtractFileName(FileName) + ' - [Rust (using C++ highlighter)]';
    end
    // 如果文件内容看起来像Markdown
    else if (SynEdit1.Lines.Count > 0) and
            ((Pos('# ', SynEdit1.Lines[0]) = 1) or
             (Pos('## ', SynEdit1.Lines[0]) = 1) or
             (Pos('### ', SynEdit1.Lines[0]) = 1) or
             (Pos('> ', SynEdit1.Lines[0]) = 1) or
             (Pos('- ', SynEdit1.Lines[0]) = 1) or
             (Pos('* ', SynEdit1.Lines[0]) = 1)) then
    begin
      OutputDebugString(PChar('检测到可能的Markdown文件内容，应用Markdown高亮器'));
      SynEdit1.Highlighter := FHighlighterMarkdown;
    end;
  end;
  
  // 为标题添加语言信息
  if (SynEdit1.Highlighter <> nil) and (Pos('[Rust', Caption) = 0) then
  begin
    Caption := ExtractFileName(FileName) + ' - [' + SynEdit1.Highlighter.LanguageName + ']';
    OutputDebugString(PChar('成功应用高亮器: ' + SynEdit1.Highlighter.LanguageName));
  end
  else if SynEdit1.Highlighter = nil then
  begin
    Caption := ExtractFileName(FileName);
    OutputDebugString(PChar('未应用任何高亮器'));
  end;
end;

procedure TForm2.LoadFile(const FileName: string; Encoding: TEncoding);
var
  Stream: TFileStream;
  Reader: TStreamReader;
  Content: string;
  MaxReadSize: Int64;
  IsBinary: Boolean;
  Buffer: TBytes;
  NonTextChars: Integer;
  i: Integer;
  Ext: string;
begin
  try
    // 检查文件是否存在
    if not FileExists(FileName) then
      raise Exception.Create('文件不存在');
      
    // 获取文件扩展名
    Ext := LowerCase(ExtractFileExt(FileName));
    OutputDebugString(PChar('加载文件: ' + FileName + ' 扩展名: ' + Ext));
      
    Stream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
    try
      // 判断是否为二进制文件（通过检查前1024字节）
      IsBinary := False;
      MaxReadSize := System.Math.Min(Stream.Size, 1024);
      if MaxReadSize > 0 then
      begin
        SetLength(Buffer, MaxReadSize);
        Stream.ReadBuffer(Buffer[0], MaxReadSize);
        Stream.Position := 0;
        
        // 检查是否包含二进制字符
        for i := 0 to High(Buffer) do
          if (Buffer[i] < 7) or ((Buffer[i] > 14) and (Buffer[i] < 32) and (Buffer[i] <> 9)) then
          begin
            IsBinary := True;
            Break;
          end;
      end;
      
      if IsBinary then
      begin
        // 显示二进制文件信息
        SynEdit1.Lines.Clear;
        SynEdit1.Lines.Add('(二进制文件，不显示内容)');
        
        Caption := ExtractFileName(FileName) + ' [二进制文件]';
        Exit;
      end;
      
      // 读取文本文件
      Stream.Position := 0;
      Reader := TStreamReader.Create(Stream, Encoding, True);
      try
        Content := Reader.ReadToEnd;
        
        // 设置编辑器内容
        SynEdit1.Lines.Text := Content;
        SynEdit1.Modified := False; // 标记为未修改
        
        // 应用语法高亮
        ApplyHighlighter(FileName);
        
        // 特殊处理Pascal文件
        if (Ext = '.pas') and (SynEdit1.Highlighter = nil) then
        begin
          OutputDebugString(PChar('特殊处理Pascal文件'));
          if Assigned(FHighlighterPas) then
          begin
            SynEdit1.Highlighter := FHighlighterPas;
            Caption := ExtractFileName(FileName) + ' - [Object Pascal]';
            OutputDebugString(PChar('手动设置Pascal高亮器'));
          end;
        end;
        
        // 检查内容是否包含大量乱码
        NonTextChars := 0;
        for i := 1 to System.Math.Min(Length(Content), 1000) do
        begin
          // 检查是否为可见ASCII字符、空白字符或中文字符
          if (Ord(Content[i]) < 32) and not CharInSet(Content[i], [#9, #10, #13]) then
            Inc(NonTextChars)
          else if (Ord(Content[i]) > 126) and (Ord(Content[i]) < $4E00) then
            Inc(NonTextChars)
          else if (Ord(Content[i]) > $9FFF) then
            Inc(NonTextChars);
        end;
            
        if (Length(Content) > 0) and ((NonTextChars / System.Math.Min(Length(Content), 1000)) > 0.3) then
          raise Exception.Create('文件可能使用了不支持的编码，或包含乱码');
      finally
        Reader.Free;
      end;
    finally
      Stream.Free;
    end;
    
    // 设置窗口标题
    if SynEdit1.Highlighter = nil then
      Caption := ExtractFileName(FileName);
  except
    on E: Exception do
      raise Exception.Create('加载文件失败: ' + E.Message);
  end;
end;

procedure TForm2.SetFileInfo(const FileName, EncodingName: string; HasBOM: Boolean);
var
  FileSize: Int64;
  BOMStr: string;
begin
  // 获取文件大小
  if FileExists(FileName) then
    FileSize := TFile.GetSize(FileName)
  else
    FileSize := 0;
    
  // BOM状态文本
  if HasBOM then
    BOMStr := '有BOM'
  else
    BOMStr := '无BOM';
    
  // 设置信息标签
  lblFileInfo.Caption := Format('文件: %s | 大小: %d 字节 | 编码: %s (%s) | 行数: %d', 
    [ExtractFileName(FileName), FileSize, EncodingName, BOMStr, SynEdit1.Lines.Count]);
end;

procedure TForm2.CheckHighlightersStatus;
var
  status: string;
begin
  status := '';
  
  if FHighlighterPas = nil then status := status + 'Pascal高亮器不可用' + #13#10;
  if FHighlighterPython = nil then status := status + 'Python高亮器不可用' + #13#10;
  if FHighlighterCpp = nil then status := status + 'C++高亮器不可用' + #13#10;
  if FHighlighterJava = nil then status := status + 'Java高亮器不可用' + #13#10;
  if FHighlighterXML = nil then status := status + 'XML高亮器不可用' + #13#10;
  if FHighlighterHTML = nil then status := status + 'HTML高亮器不可用' + #13#10;
  if FHighlighterMarkdown = nil then status := status + 'Markdown高亮器不可用' + #13#10;
  
  if status <> '' then
    OutputDebugString(PChar('高亮器状态检查:' + #13#10 + status))
  else
    OutputDebugString(PChar('所有高亮器加载成功'));
end;

