unit UtilsSVGConverter;

interface

uses
  System.SysUtils, System.Classes, Vcl.Graphics, Vcl.Imaging.pngimage,
  Vcl.Imaging.jpeg, Vcl.Imaging.GIFImg, System.Types, System.IOUtils,
  Vcl.Skia, System.Skia, System.UITypes, Winapi.Windows, Vcl.Forms, Vcl.Controls;

type
  // 定义支持的图像格式枚举
  TSVGOutputFormat = (sofICO, sofPNG, sofJPG, sofBMP, sofGIF, sofTIFF, sofWEBP);

  // SVG转换类
  TSVGConverter = class
  private
    FSVGFilePath: string;
    FOutputPath: string;
    FWidth: Integer;
    FHeight: Integer;
    FFormat: TSVGOutputFormat;
    FOnProgress: TProc<string>;
    FOnError: TProc<string>;
    FOnSuccess: TProc<string>;

    function GetFormatExt: string;
    function FormatToStr(Format: TSVGOutputFormat): string;
    function SVGToBitmap(const SVGFilePath: string; Width, Height: Integer): TBitmap;
  public
    constructor Create;
    destructor Destroy; override;

    // 执行转换
    function Convert: Boolean;

    // 一次性转换为多种格式
    procedure ConvertToMultiFormats(const OutputFolder: string);

    // 获取支持的格式名称数组
    class function GetSupportedFormats: TArray<string>;

    // 属性
    property SVGFilePath: string read FSVGFilePath write FSVGFilePath;
    property OutputPath: string read FOutputPath write FOutputPath;
    property Width: Integer read FWidth write FWidth;
    property Height: Integer read FHeight write FHeight;
    property Format: TSVGOutputFormat read FFormat write FFormat;

    // 事件回调
    property OnProgress: TProc<string> read FOnProgress write FOnProgress;
    property OnError: TProc<string> read FOnError write FOnError;
    property OnSuccess: TProc<string> read FOnSuccess write FOnSuccess;
  end;

  // 辅助函数 - 将SVG文件加载到组件中
  procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);

  // 辅助函数 - 生成合适的输出路径
  function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;

// 声明ICO文件相关的数据结构（简化版）
type
  {$ALIGN 2}
  TIconDir = packed record
    idReserved: Word;    // 保留，必须为0
    idType: Word;        // 资源类型，1表示图标
    idCount: Word;       // 图像数量
  end;

  TIconDirEntry = packed record
    bWidth: Byte;          // 图像宽度
    bHeight: Byte;         // 图像高度
    bColorCount: Byte;     // 调色板颜色数量，如果是真彩色，则为0
    bReserved: Byte;       // 保留字段，必须为0
    wPlanes: Word;         // 颜色平面数
    wBitCount: Word;       // 每个像素的位数
    dwBytesInRes: DWORD;   // 图像数据的字节数
    dwImageOffset: DWORD;  // 图像数据在文件中的偏移量
  end;
  {$ALIGN ON}

implementation

{ TSVGConverter }

constructor TSVGConverter.Create;
begin
  inherited Create;
  // 默认设置
  FWidth := 256;
  FHeight := 256;
  FFormat := sofPNG;
end;

destructor TSVGConverter.Destroy;
begin
  inherited;
end;

function TSVGConverter.GetFormatExt: string;
begin
  case FFormat of
    sofICO: Result := '.ico';
    sofPNG: Result := '.png';
    sofJPG: Result := '.jpg';
    sofBMP: Result := '.bmp';
    sofGIF: Result := '.gif';
    sofTIFF: Result := '.tiff';
    sofWEBP: Result := '.webp';
    else Result := '.png'; // 默认为PNG
  end;
end;

function TSVGConverter.FormatToStr(Format: TSVGOutputFormat): string;
begin
  case Format of
    sofICO: Result := 'ICO';
    sofPNG: Result := 'PNG';
    sofJPG: Result := 'JPG';
    sofBMP: Result := 'BMP';
    sofGIF: Result := 'GIF';
    sofTIFF: Result := 'TIFF';
    sofWEBP: Result := 'WebP';
    else Result := 'PNG'; // 默认为PNG
  end;
end;

// 将SVG转换为位图的辅助方法
function TSVGConverter.SVGToBitmap(const SVGFilePath: string; Width, Height: Integer): TBitmap;
var
  LForm: TForm;
  LSVG: TSkSvg;
  LBitmap: TBitmap;
  E: Exception;
begin
  Result := nil;
  LBitmap := TBitmap.Create;
  try
    LBitmap.Width := Width;
    LBitmap.Height := Height;
    LBitmap.PixelFormat := pf32bit;

    // 创建临时表单
    LForm := TForm.Create(nil);
    try
      LForm.Width := Width;
      LForm.Height := Height;
      LForm.Position := poScreenCenter;
      LForm.BorderStyle := bsNone;
      LForm.FormStyle := fsStayOnTop;
      LForm.Visible := False;

      // 创建临时SVG控件
      LSVG := TSkSvg.Create(LForm);
      try
        LSVG.Parent := LForm;
        LSVG.Width := Width;
        LSVG.Height := Height;
        LSVG.Align := alClient;

        // 加载SVG文件
        if FileExists(SVGFilePath) then
        begin
          try
            LSVG.Svg.Source.Data := TFile.ReadAllText(SVGFilePath);
          except
            on E: Exception do
            begin
              if Assigned(FOnError) then
                FOnError('加载SVG文件失败 (' + ExtractFileName(SVGFilePath) + '): ' + E.Message);
              Exit;
            end;
          end;
        end
        else
        begin
          if Assigned(FOnError) then
            FOnError('SVG源文件未找到: ' + SVGFilePath);
          Exit;
        end;

        // 绘制SVG到位图
        LForm.Visible := True;
        Application.ProcessMessages;
        try
          if LBitmap.Canvas.Handle <> 0 then
          begin
            LForm.PaintTo(LBitmap.Canvas.Handle, 0, 0);
          end
          else
          begin
            if Assigned(FOnError) then
              FOnError('创建位图Canvas失败 (Width: ' + IntToStr(Width) + ', Height: ' + IntToStr(Height) + ')');
            Exit;
          end;
        finally
          LForm.Visible := False;
        end;
      finally
        LSVG.Free;
      end;
    finally
      LForm.Free;
    end;
    Result := LBitmap;
  except
    on E: Exception do
    begin
      LBitmap.Free;
      if Assigned(FOnError) then
        FOnError('创建/绘制位图失败: ' + E.Message);
    end;
  end;
end;

function TSVGConverter.Convert: Boolean;
var
  LBitmap: TBitmap;
  LPngImage: TPngImage;
  LJpegImage: TJPEGImage;
  LGifImage: TGIFImage;
  LFormatStr: string;
  I: Integer;
  LIconSizes: array[0..3] of Integer;
  LFileStream: TFileStream;
  LIconDir: TIconDir;
  LIconDirEntry: TIconDirEntry;
  LMemStream: TMemoryStream;
  LHeaderSize, LOffsetBytes: DWORD;
  LSizeBitmap: TBitmap;
begin
  Result := False;
  LFormatStr := FormatToStr(FFormat);

  // 检查文件是否存在
  if not FileExists(FSVGFilePath) then
  begin
    if Assigned(FOnError) then
      FOnError('SVG文件不存在: ' + FSVGFilePath);
    Exit;
  end;

  // 确保输出路径有效
  if FOutputPath = '' then
    FOutputPath := GenerateOutputPath(FSVGFilePath, FFormat);

  // 确保输出目录存在
  try
    ForceDirectories(ExtractFilePath(FOutputPath));
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('创建输出目录失败: ' + ExtractFilePath(FOutputPath) + ' Error: ' + E.Message);
      Exit;
    end;
  end;

  try
    if Assigned(FOnProgress) then
      FOnProgress('正在转换为' + LFormatStr + '格式...');

    // 处理ICO格式的特殊情况
    if FFormat = sofICO then
    begin
      // 设置ICO尺寸数组
      LIconSizes[0] := 16;
      LIconSizes[1] := 32;
      LIconSizes[2] := 48;
      LIconSizes[3] := 64;

      LFileStream := TFileStream.Create(FOutputPath, fmCreate or fmShareDenyWrite);
      try
        // 初始化ICO头部
        FillChar(LIconDir, SizeOf(LIconDir), 0);
        LIconDir.idType := 1; // ICO类型
        LIconDir.idCount := Length(LIconSizes);

        // 写入头部占位符 (will be updated later if needed)
        LFileStream.WriteBuffer(LIconDir, SizeOf(TIconDir));

        // 写入目录条目占位符
        LHeaderSize := SizeOf(TIconDir) + DWORD(Length(LIconSizes)) * SizeOf(TIconDirEntry);
        LOffsetBytes := LHeaderSize;

        // Create entries first, store PNG data temporarily
        var LEntryStreams: array of TMemoryStream;
        SetLength(LEntryStreams, Length(LIconSizes));
        var LEntries: array of TIconDirEntry;
        SetLength(LEntries, Length(LIconSizes));
        var LSuccessCount: Integer := 0;

        for I := 0 to High(LIconSizes) do
        begin
          LEntryStreams[I] := TMemoryStream.Create;
          LSizeBitmap := SVGToBitmap(FSVGFilePath, LIconSizes[I], LIconSizes[I]);
          if LSizeBitmap <> nil then
          begin
            try
              LPngImage := TPngImage.Create;
              try
                LPngImage.Assign(LSizeBitmap);
                if LSizeBitmap.PixelFormat = pf32bit then
                  LPngImage.TransparencyMode := ptmPartial;

                LPngImage.SaveToStream(LEntryStreams[I]);
              finally
                LPngImage.Free;
              end;

              // Prepare icon directory entry
              FillChar(LIconDirEntry, SizeOf(LIconDirEntry), 0);
              LIconDirEntry.bWidth := Byte(LIconSizes[I]);
              LIconDirEntry.bHeight := Byte(LIconSizes[I]);
              LIconDirEntry.wPlanes := 1;
              LIconDirEntry.wBitCount := 32;
              LIconDirEntry.dwBytesInRes := LEntryStreams[I].Size;
              LIconDirEntry.dwImageOffset := LOffsetBytes;

              LEntries[I] := LIconDirEntry;
              Inc(LOffsetBytes, LEntryStreams[I].Size);
              Inc(LSuccessCount);
            finally
              LSizeBitmap.Free;
            end;
          end
          else
          begin
            if Assigned(FOnError) then
              FOnError('创建 ' + IntToStr(LIconSizes[I]) + 'x' + IntToStr(LIconSizes[I]) + ' ICO图像失败');
          end;
        end;

        // Check if any images were created successfully
        if LSuccessCount = 0 then
        begin
          if Assigned(FOnError) then
            FOnError('未能创建任何ICO图像尺寸');
          Exit;
        end;

        // Update the main ICO header with the actual count of successful images
        LIconDir.idCount := LSuccessCount;
        LFileStream.Position := 0;
        LFileStream.WriteBuffer(LIconDir, SizeOf(TIconDir));

        // Write the actual Icon Directory Entries for successful images
        LFileStream.Position := SizeOf(TIconDir);
        for I := 0 to High(LIconSizes) do
        begin
          if LEntryStreams[I].Size > 0 then
            LFileStream.WriteBuffer(LEntries[I], SizeOf(TIconDirEntry));
        end;

        // Write the image data (PNG streams) for successful images
        LFileStream.Position := LHeaderSize;
        for I := 0 to High(LIconSizes) do
        begin
          if LEntryStreams[I].Size > 0 then
          begin
            LEntryStreams[I].Position := 0;
            LFileStream.CopyFrom(LEntryStreams[I], LEntryStreams[I].Size);
          end;
        end;

        Result := True;
      finally
        for I := 0 to High(LEntryStreams) do
          if Assigned(LEntryStreams[I]) then LEntryStreams[I].Free;
        LFileStream.Free;
      end;
    end
    else
    begin
      LBitmap := SVGToBitmap(FSVGFilePath, FWidth, FHeight);
      if LBitmap = nil then
        Exit;

      try
        case FFormat of
          sofPNG:
            begin
              LPngImage := TPngImage.Create;
              try
                LPngImage.Assign(LBitmap);
                if LBitmap.PixelFormat = pf32bit then
                  LPngImage.TransparencyMode := ptmPartial;
                LPngImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                LPngImage.Free;
              end;
            end;

          sofJPG:
            begin
              LJpegImage := TJPEGImage.Create;
              try
                if LBitmap.PixelFormat = pf32bit then
                  LBitmap.PixelFormat := pf24bit;
                LJpegImage.Assign(LBitmap);
                LJpegImage.CompressionQuality := 90;
                LJpegImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                LJpegImage.Free;
              end;
            end;

          sofBMP:
            begin
              if LBitmap.PixelFormat = pf32bit then
                LBitmap.PixelFormat := pf24bit;
              LBitmap.SaveToFile(FOutputPath);
              Result := True;
            end;

          sofGIF:
            begin
              LGifImage := TGIFImage.Create;
              try
                if LBitmap.PixelFormat = pf32bit then
                  LBitmap.PixelFormat := pf24bit;
                LGifImage.Assign(LBitmap);
                LGifImage.SaveToFile(FOutputPath);
                Result := True;
              finally
                LGifImage.Free;
              end;
            end;

          sofTIFF, sofWEBP:
            begin
              LPngImage := TPngImage.Create;
              try
                LPngImage.Assign(LBitmap);
                if LBitmap.PixelFormat = pf32bit then
                  LPngImage.TransparencyMode := ptmPartial;

                LPngImage.SaveToFile(FOutputPath);
                Result := True;

                if Assigned(FOnProgress) then
                  FOnProgress('注意: ' + LFormatStr + '格式不直接支持，已保存为PNG文件，扩展名为 ' + GetFormatExt);
              finally
                LPngImage.Free;
              end;
            end;
        end;
      finally
        LBitmap.Free;
      end;
    end;

    if Result and Assigned(FOnSuccess) then
      FOnSuccess(LFormatStr + '文件已保存到: ' + FOutputPath);
  except
    on E: Exception do
    begin
      if Assigned(FOnError) then
        FOnError('转换' + LFormatStr + '失败: ' + E.Message);
      Result := False;
    end;
  end;
end;

procedure TSVGConverter.ConvertToMultiFormats(const OutputFolder: string);
var
  LOrigFormat: TSVGOutputFormat;
  LOrigOutput: string;
  LFormat: TSVGOutputFormat;
begin
  // 保存原始设置
  LOrigFormat := FFormat;
  LOrigOutput := FOutputPath;

  try
    // 确保输出文件夹存在
    if not DirectoryExists(OutputFolder) then
    begin
      try
        ForceDirectories(OutputFolder);
      except
        on E: Exception do
        begin
          if Assigned(FOnError) then
            FOnError('创建批量输出目录失败: ' + OutputFolder + ' Error: ' + E.Message);
          Exit;
        end;
      end;
    end;

    if Assigned(FOnProgress) then
      FOnProgress('开始批量转换SVG到多种格式...');

    // 依次转换为各种格式
    for LFormat := Low(TSVGOutputFormat) to High(TSVGOutputFormat) do
    begin
      FFormat := LFormat;
      FOutputPath := IncludeTrailingPathDelimiter(OutputFolder) +
                     ChangeFileExt(ExtractFileName(FSVGFilePath), GetFormatExt);

      if Assigned(FOnProgress) then
        FOnProgress('正在转换为' + FormatToStr(LFormat) + '格式...');

      if Convert then
      begin
        if Assigned(FOnSuccess) then
          FOnSuccess(FormatToStr(LFormat) + '转换成功: ' + FOutputPath);
      end
    end;

    if Assigned(FOnSuccess) then
      FOnSuccess('批量转换完成，输出目录: ' + OutputFolder);
  finally
    // 还原原始设置
    FFormat := LOrigFormat;
    FOutputPath := LOrigOutput;
  end;
end;

class function TSVGConverter.GetSupportedFormats: TArray<string>;
begin
  SetLength(Result, Ord(High(TSVGOutputFormat)) + 1);
  Result[Ord(sofICO)] := 'ICO';
  Result[Ord(sofPNG)] := 'PNG';
  Result[Ord(sofJPG)] := 'JPG';
  Result[Ord(sofBMP)] := 'BMP';
  Result[Ord(sofGIF)] := 'GIF';
  Result[Ord(sofTIFF)] := 'TIFF';
  Result[Ord(sofWEBP)] := 'WebP';
end;

// 辅助函数 - 将SVG文件加载到组件中
procedure LoadSVGToComponent(const SVGFilePath: string; SVGControl: TSkSvg);
begin
  if not FileExists(SVGFilePath) then
  begin
    Exit;
  end;

  if not Assigned(SVGControl) then
  begin
    Exit;
  end;

  try
    // 加载SVG文件内容到控件
    SVGControl.Svg.Source.Data := TFile.ReadAllText(SVGFilePath);

    // 确保控件刷新显示
    SVGControl.Invalidate;
  except
    // Optional: Log error or show message to user
    // ShowMessage('加载SVG预览失败: ' + E.Message);
  end;
end;

// 辅助函数 - 生成合适的输出路径
function GenerateOutputPath(const SVGFilePath: string; Format: TSVGOutputFormat): string;
var
  Ext: string;
begin
  case Format of
    sofICO: Ext := '.ico';
    sofPNG: Ext := '.png';
    sofJPG: Ext := '.jpg';
    sofBMP: Ext := '.bmp';
    sofGIF: Ext := '.gif';
    sofTIFF: Ext := '.tiff';
    sofWEBP: Ext := '.webp';
    else Ext := '.png'; // Default
  end;

  Result := ChangeFileExt(SVGFilePath, Ext);
end;

end.