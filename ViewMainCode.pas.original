procedure TForm1.MenuItemCopyFullPathClick(Sender: TObject);
var
  FullPath: string;
begin
  // ȷ��ѡ������Ч����
  if (FSelectedRow <= 0) or (FSelectedRow >= StringGrid1.RowCount) then
  begin
    ShowLocalizedMessage('MsgSelectFile');
    Exit;
