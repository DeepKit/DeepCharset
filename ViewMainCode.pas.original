procedure TForm1.TreeViewEncodingsClick(Sender: TObject);
    begin
  // ���û����TreeViewEncodings�е���Ŀʱ����
  // ��������������⣨���ڵ㣩��ȡ��ѡ��
  if (TreeViewEncodings.Selected <> nil) and (TreeViewEncodings.Selected.Level = 0) then
    begin
    TreeViewEncodings.Selected := nil;
    end;
end;

procedure TForm1.Log(const Msg: string);
var
  SafeMsg: string;
begin
  try
    // ��ȫ������Ϣ���Ƴ����ܵ���������ַ�
    SafeMsg := StringReplace(Msg, #0, '', [rfReplaceAll]);

    // ���MemLog�Ƿ��Ѵ���
    if not Assigned(MemLog) then
    begin
      // ���MemLog��δ������ֻ��������Դ���
      try
        OutputDebugString(PChar('��־: ' + SafeMsg));
      except
        // �������д���
      end;
      Exit;
    end;

    // ʹ����־��������������¼��־
    if Assigned(FLogBufferManager) then
    begin
      try
        FLogBufferManager.Log(SafeMsg);
      except
        on E: Exception do
        begin
          try
            OutputDebugString(PChar('��־��������������¼��־ʧ��: ' + E.Message));

            // �����־������������ʧ�ܣ����˵��ɵķ���
            if FBufferingLogs then
            begin
              if Assigned(FLogBuffer) then
                FLogBuffer.Add(SafeMsg);
            end
            else
            begin
              if Assigned(FUIHelper) then
                FUIHelper.AppendLog(MemLog, SafeMsg)
              else
                MemLog.Lines.Add(FormatDateTime('[yyyy-mm-dd hh:nn:ss] ', Now) + SafeMsg);
            end;
          except
            // �������д���
          end;
        end;
      end;
    end
    else
    begin
      // �����־������������δ��ʼ����ʹ�þɵķ���
      if FBufferingLogs then
      begin
        if Assigned(FLogBuffer) then
          FLogBuffer.Add(SafeMsg);
      end
      else
      begin
        if Assigned(FUIHelper) then
          FUIHelper.AppendLog(MemLog, SafeMsg)
        else
          MemLog.Lines.Add(FormatDateTime('[yyyy-mm-dd hh:nn:ss] ', Now) + SafeMsg);
      end;
    end;
  except
    on E: Exception do
    begin
      // �������п��ܵ��쳣��ȷ����־��¼���ᵼ�³������
      try
        OutputDebugString(PChar('���ش���: ��־��¼�����г���δ�������쳣: ' + E.Message));
      except
        // �������д���
      end;
    end;
  end;
end;

// ��ʼ��־����
procedure TForm1.StartLogBuffering;
begin
  try
    // ʹ����־��������������ʼ������ģʽ
    if Assigned(FLogBufferManager) then
    begin
      try
        FLogBufferManager.BeginBatch;
        OutputDebugString(PChar('��ʼ��־������ģʽ'));
      except
        on E: Exception do
        begin
          OutputDebugString(PChar('��ʼ��־������ģʽʧ��: ' + E.Message));

          // �����־������������ʧ�ܣ����˵��ɵķ���
          FBufferingLogs := True;
          if Assigned(FLogBuffer) then
            FLogBuffer.Clear;
        end;
      end;
    end
    else
    begin
      // �����־������������δ��ʼ����ʹ�þɵķ���
      FBufferingLogs := True;

      // ��ȫ��飺ȷ��FLogBuffer�ѳ�ʼ��
      if not Assigned(FLogBuffer) then
        FLogBuffer := TStringList.Create
      else
        FLogBuffer.Clear;
    end;
  except
    on E: Exception do
    begin
      OutputDebugString(PChar('��ʼ��־����ʱ����: ' + E.Message));
      FBufferingLogs := False;
    end;
  end;
end;

// ������־���岢һ���Ը���MemLog
procedure TForm1.EndLogBuffering;
begin
  try
    // ʹ����־����������������������ģʽ
    if Assigned(FLogBufferManager) then
    begin
      try
        FLogBufferManager.EndBatch;
        OutputDebugString(PChar('������־������ģʽ'));
      except
        on E: Exception do
        begin
          OutputDebugString(PChar('������־������ģʽʧ��: ' + E.Message));

          // �����־������������ʧ�ܣ����˵��ɵķ���
          FBufferingLogs := False;

          // ��ȫ��飺ȷ��FLogBuffer��MemLog�ѳ�ʼ��
          if Assigned(FLogBuffer) and Assigned(MemLog) then
          begin
            // ��������UI
            MemLog.Lines.BeginUpdate;
            try
              // �����־̫�ֻ࣬��ʾ���100��
              if FLogBuffer.Count > 100 then
              begin
                MemLog.Lines.Add('���� ' + IntToStr(FLogBuffer.Count) + ' ����־��ֻ��ʾ���100��...');
                for var i := FLogBuffer.Count - 100 to FLogBuffer.Count - 1 do
                  if Assigned(FUIHelper) then
                    FUIHelper.AppendLog(MemLog, FLogBuffer[i])
                  else
                    MemLog.Lines.Add(FLogBuffer[i]);
              end
              else
              begin
                for var i := 0 to FLogBuffer.Count - 1 do
                  if Assigned(FUIHelper) then
                    FUIHelper.AppendLog(MemLog, FLogBuffer[i])
                  else
                    MemLog.Lines.Add(FLogBuffer[i]);
              end;
            finally
              MemLog.Lines.EndUpdate;
            end;

            // �������ײ�
            MemLog.SelStart := Length(MemLog.Text);
            MemLog.SelLength := 0;
            MemLog.Perform(EM_SCROLLCARET, 0, 0);

            // ��ջ�����
            FLogBuffer.Clear;
          end;
        end;
      end;
    end
    else
    begin
      // �����־������������δ��ʼ����ʹ�þɵķ���
      FBufferingLogs := False;

      // ��ȫ��飺ȷ��FLogBuffer��MemLog�ѳ�ʼ��
      if Assigned(FLogBuffer) and Assigned(MemLog) then
      begin
        // ��������UI
        MemLog.Lines.BeginUpdate;
        try
          // �����־̫�ֻ࣬��ʾ���100��
          if FLogBuffer.Count > 100 then
          begin
            MemLog.Lines.Add('���� ' + IntToStr(FLogBuffer.Count) + ' ����־��ֻ��ʾ���100��...');
            for var i := FLogBuffer.Count - 100 to FLogBuffer.Count - 1 do
              if Assigned(FUIHelper) then
                FUIHelper.AppendLog(MemLog, FLogBuffer[i])
              else
                MemLog.Lines.Add(FLogBuffer[i]);
          end
          else
          begin
            for var i := 0 to FLogBuffer.Count - 1 do
              if Assigned(FUIHelper) then
                FUIHelper.AppendLog(MemLog, FLogBuffer[i])
              else
                MemLog.Lines.Add(FLogBuffer[i]);
          end;
        finally
          MemLog.Lines.EndUpdate;
        end;

        // �������ײ�
        MemLog.SelStart := Length(MemLog.Text);
        MemLog.SelLength := 0;
        MemLog.Perform(EM_SCROLLCARET, 0, 0);

        // ��ջ�����
        FLogBuffer.Clear;
      end;
    end;
  except
    on E: Exception do
    begin
      OutputDebugString(PChar('���ش���: ������־��������г���δ�������쳣: ' + E.Message));
    end;
  end;
end;

procedure TForm1.MenuItemConvertAllFilesClick(Sender: TObject);
var
  SuccessCount: Integer;
  AllFiles: TArray<string>;
  Encoding: TEncoding;
  EncodingName: string;
  StartTime: TDateTime;
  ElapsedTime: Int64;
  UseParallel: Boolean;
  TargetEncoding: TEncoding;
  WithBOM: Boolean;
begin
  StartTime := Now;

  // Get file list - use FIncludeSubdirs parameter
  AllFiles := FFileHelper.GetSelectedFilesInFolder(FSelectedFolder, FFileExtensions,
    function(const FilePath: string): Boolean
    begin
      Result := True; // Select all files
    end,
    FIncludeSubdirs
  );

  // If no files, show message and exit
  if Length(AllFiles) = 0 then
  begin
    ShowLocalizedMessage('MsgNoFilesForConversion');
    Exit;
  end;

  // Get selected encoding (from TreeView)
  Encoding := FEncodingModel.GetSelectedEncoding;
  EncodingName := FEncodingModel.GetEncodingName(Encoding);
  WithBOM := EncodingName.Contains('BOM');

  // ȷ���Ƿ�ʹ�ò��д��������ļ���������10ʱʹ�ò��д�����
  UseParallel := Length(AllFiles) >= 10;

  // ��ȡĿ��������
  case Encoding.CodePage of
    65001: begin // UTF-8
      if WithBOM then
        TargetEncoding := TEncoding.UTF8 // UTF-8 with BOM
      else
        TargetEncoding := TEncoding.UTF8; // UTF-8 without BOM (��Ҫ���⴦��BOM)
    end;
    936: TargetEncoding := TEncoding.GetEncoding(936); // GBK
    950: TargetEncoding := TEncoding.GetEncoding(950); // Big5
    1200: TargetEncoding := TEncoding.Unicode; // UTF-16 LE
    1201: TargetEncoding := TEncoding.BigEndianUnicode; // UTF-16 BE
    else TargetEncoding := TEncoding.Default; // ANSI
  end;

  // Confirmation dialog
  if Application.MessageBox(
    PChar(System.SysUtils.Format('ȷ��Ҫ�������ļ� (%d ��) ת��Ϊ��ǰѡ��ı��� %s? ',
      [Length(AllFiles), EncodingName])),
    '����ת��ȷ��',
    MB_YESNO + MB_ICONQUESTION) <> IDYES then
  begin
    Log('ȡ������ת��');
    Exit;
  end;

  // Start batch conversion
  if UseParallel then
    Log('��ʼ��������ת�������ļ� (' + IntToStr(Length(AllFiles)) + ' ��)...')
  else
    Log('��ʼ����ת�������ļ� (' + IntToStr(Length(AllFiles)) + ' ��)...');

  StartLogBuffering;
  SuccessCount := 0;

  try
    // Set cursor to wait state
    Screen.Cursor := crHourGlass;

    // ʹ�ò��л�˳����
    if UseParallel then
    begin
      // ʹ�ò��д���
      SuccessCount := FFileHelper.BatchConvertParallel(AllFiles, TargetEncoding, WithBOM);
    end
    else
    begin
      // ʹ��˳����
      SuccessCount := FFileHelper.BatchConvert(AllFiles, TargetEncoding, WithBOM);
    end;

    // �����ʱ
    ElapsedTime := System.DateUtils.MilliSecondsBetween(StartTime, Now);

    // ���±����������ļ���״̬
    UpdateFileGrid(FSelectedFolder);

    // Complete batch conversion, show result
    if UseParallel then
      Log(System.SysUtils.Format('��������ת�����: �ɹ� %d/%d ���ļ� (�ܺ�ʱ: %d ms, ƽ��ÿ�ļ� %.2f ms)',
        [SuccessCount, Length(AllFiles), ElapsedTime, ElapsedTime / Length(AllFiles)]))
    else
      Log(System.SysUtils.Format('����ת�����: �ɹ� %d/%d ���ļ� (�ܺ�ʱ: %d ms)',
        [SuccessCount, Length(AllFiles), ElapsedTime]));

    if SuccessCount < Length(AllFiles) then
      Log(System.SysUtils.Format('ע��: %d ���ļ�δ�ܳɹ�ת�� (�����Ƿ��ı��ļ����޷�����)',
        [Length(AllFiles) - SuccessCount]));

    ShowMessage(System.SysUtils.Format('ת�����: �ɹ� %d/%d ���ļ� (��ʱ: %d ms)',
      [SuccessCount, Length(AllFiles), ElapsedTime]));
  finally
    // Restore cursor
    Screen.Cursor := crDefault;
    EndLogBuffering;
  end;
end;

procedure TForm1.MenuItemConvertClick(Sender: TObject);
var
  TargetInfo: TEncodingInfo;
  WithBOM: Boolean;
  SelectedFiles: TArray<string>;
  SelectedIndex: Integer;
  SuccessCount: Integer;
  StartTime: TDateTime;
  ElapsedTime: Int64;
  UseParallel: Boolean;
  TargetEncoding: TEncoding;
begin
  // ��¼��ʼ����
  Log('��ʼ�����Ҽ��˵���ת��ѡ���ļ�������');
  StartTime := Now;

  if StringGrid1.RowCount <= 1 then
  begin
    Log('������û���ļ�������ȡ��');
    Exit; // No files loaded
  end;

  // ��ȡѡ�еı�����Ϣ
  if (TreeViewEncodings.Selected = nil) or (TreeViewEncodings.Selected.Level = 0) then
  begin
    Log('δѡ��Ŀ����룬����ȡ��');
    ShowLocalizedMessage('MsgSelectTargetEncoding');
    Exit;
  end;
  SelectedIndex := Integer(TreeViewEncodings.Selected.Data);
  TargetInfo := FEncodingModel.Encodings[SelectedIndex];
  WithBOM := TargetInfo.HasBOM;
  Log('ѡ���Ŀ�����: ' + TargetInfo.Name + ', BOM: ' + BoolToStr(WithBOM, True));

  // ��ȡѡ�е��ļ�
  SelectedFiles := FUIHelper.GetSelectedFiles(StringGrid1, FSelectedFolder);
  Log('�ҵ� ' + IntToStr(Length(SelectedFiles)) + ' ��ѡ�е��ļ�');

  if Length(SelectedFiles) = 0 then
  begin
    Log('û��ѡ���ļ�������ȡ��');
    ShowMessage('������ѡ��һ���ļ�����ת����');
    Exit;
  end;

  // ȷ���Ƿ�ʹ�ò��д��������ļ���������10ʱʹ�ò��д�����
  UseParallel := Length(SelectedFiles) >= 10;

  // ��ȡĿ��������
  case TargetInfo.CodePage of
    65001: begin // UTF-8
      if WithBOM then
        TargetEncoding := TEncoding.UTF8 // UTF-8 with BOM
      else
        TargetEncoding := TEncoding.UTF8; // UTF-8 without BOM (��Ҫ���⴦��BOM)
    end;
    936: TargetEncoding := TEncoding.GetEncoding(936); // GBK
    950: TargetEncoding := TEncoding.GetEncoding(950); // Big5
    1200: TargetEncoding := TEncoding.Unicode; // UTF-16 LE
    1201: TargetEncoding := TEncoding.BigEndianUnicode; // UTF-16 BE
    else TargetEncoding := TEncoding.Default; // ANSI
  end;

  // ��ʼ����ת��
  if UseParallel then
    Log('��ʼ��������ת��ѡ�е��ļ�...')
  else
    Log('��ʼ����ת��ѡ�е��ļ�...');

  StartLogBuffering;
  SuccessCount := 0;

  try
    // ���õȴ����
    Screen.Cursor := crHourGlass;

    // ʹ�ò��л�˳����
    if UseParallel then
    begin
      // ʹ�ò��д���
      SuccessCount := FFileHelper.BatchConvertParallel(SelectedFiles, TargetEncoding, WithBOM);
    end
    else
    begin
      // ʹ��˳����
      SuccessCount := FFileHelper.BatchConvert(SelectedFiles, TargetEncoding, WithBOM);
    end;

    // �����ʱ
    ElapsedTime := System.DateUtils.MilliSecondsBetween(StartTime, Now);

    // ���±����������ļ���״̬
    UpdateFileGrid(FSelectedFolder);

    // �������ת������ʾ���
    if UseParallel then
      Log(System.SysUtils.Format('��������ת�����: �ɹ� %d/%d ���ļ� (�ܺ�ʱ: %d ms, ƽ��ÿ�ļ� %.2f ms)',
        [SuccessCount, Length(SelectedFiles), ElapsedTime, ElapsedTime / Length(SelectedFiles)]))
    else
      Log(System.SysUtils.Format('����ת�����: �ɹ� %d/%d ���ļ� (�ܺ�ʱ: %d ms)',
        [SuccessCount, Length(SelectedFiles), ElapsedTime]));

    if SuccessCount < Length(SelectedFiles) then
      Log(System.SysUtils.Format('ע��: %d ���ļ�δ�ܳɹ�ת�� (�����Ƿ��ı��ļ����޷�����)',
        [Length(SelectedFiles) - SuccessCount]));

    ShowMessage(System.SysUtils.Format('ת�����: �ɹ� %d/%d ���ļ� (��ʱ: %d ms)',
      [SuccessCount, Length(SelectedFiles), ElapsedTime]));
  finally
    // �ָ����
    Screen.Cursor := crDefault;
    EndLogBuffering;
  end;
end;

procedure TForm1.MenuItemConvertCurrentClick(Sender: TObject);
var
  FilePath: string;
  Encoding: TEncoding;
  SuccessCount: Integer;
  SelectedFiles: TArray<string>;
  CurrentRowFile: string;
  FileName: string;
  StartTime: TDateTime;
  ElapsedTime: Int64;
  UseParallel: Boolean;
  EncodingName: string;
  WithBOM: Boolean;
  TargetEncoding: TEncoding;
begin
  // ��¼��ʼ����
  Log('��ʼ�����Ҽ��˵�ת���ļ�����');
  StartTime := Now;

  // ���ȼ�鵱ǰѡ�е����Ƿ���Ч
  if (FSelectedRow > 0) and (FSelectedRow < StringGrid1.RowCount) and
     (StringGrid1.Cells[2, FSelectedRow] <> '') and
     (StringGrid1.Cells[2, FSelectedRow] <> '(���ļ�)') and
     (StringGrid1.Cells[2, FSelectedRow] <> '(Ŀ¼������)') and
     (StringGrid1.Cells[2, FSelectedRow] <> '(��ѡ������һ���ļ�����)') then
  begin
    // ��ȡ�ļ���
    FileName := StringGrid1.Cells[2, FSelectedRow];
    Log('��ǰѡ���е��ļ���: ' + FileName);

    // ��������·��
    CurrentRowFile := IncludeTrailingPathDelimiter(FSelectedFolder) + FileName;
    Log('����������·��: ' + CurrentRowFile);

    // ����ļ��Ƿ����
    if FileExists(CurrentRowFile) then
    begin
      SetLength(SelectedFiles, 1);
      SelectedFiles[0] := CurrentRowFile;
      Log('ʹ�õ�ǰ�е��ļ�: ' + CurrentRowFile);
    end
    else
    begin
      Log('�ļ�������: ' + CurrentRowFile);
      ShowMessage('�ļ�������: ' + CurrentRowFile);
      Exit;
    end;
  end
  else
  begin
    // �����ǰ����Ч�����Ի�ȡѡ�е��ļ�
    Log('��ǰ����Ч�����Ի�ȡѡ�е��ļ�');
    SelectedFiles := FFileHelper.GetSelectedFilesInFolder(FSelectedFolder, FFileExtensions,
      function(const FilePath: string): Boolean
      begin
        Result := False; // Assume no file selected first

        // Find this file in the grid
        for var j := 1 to StringGrid1.RowCount - 1 do
        begin
          if (StringGrid1.Cells[2, j] <> '') and
             (FilePath = IncludeTrailingPathDelimiter(FSelectedFolder) + StringGrid1.Cells[2, j]) and
             (StringGrid1.Cells[0, j] = '��') then
          begin
            Result := True;
            Break;
          end;
        end;
      end,
      FIncludeSubdirs
    );

    // �����Ȼû���ļ���ת����ֱ���˳�
    if Length(SelectedFiles) = 0 then
    begin
      Log('û��ѡ���ļ���Ҳû����Ч�ĵ�ǰ���ļ�������ȡ��');
      ShowMessage('��ѡ��Ҫת�����ļ�');
      Exit;
    end;
  end;

  // Get selected encoding (from TreeView)
  Encoding := FEncodingModel.GetSelectedEncoding;
  EncodingName := FEncodingModel.GetEncodingName(Encoding);
  WithBOM := EncodingName.Contains('BOM');

  // ȷ���Ƿ�ʹ�ò��д��������ļ���������10ʱʹ�ò��д�����
  UseParallel := Length(SelectedFiles) >= 10;

  // ��ȡĿ��������
  case Encoding.CodePage of
    65001: begin // UTF-8
      if WithBOM then
        TargetEncoding := TEncoding.UTF8 // UTF-8 with BOM
      else
        TargetEncoding := TEncoding.UTF8; // UTF-8 without BOM (��Ҫ���⴦��BOM)
    end;
    936: TargetEncoding := TEncoding.GetEncoding(936); // GBK
    950: TargetEncoding := TEncoding.GetEncoding(950); // Big5
    1200: TargetEncoding := TEncoding.Unicode; // UTF-16 LE
    1201: TargetEncoding := TEncoding.BigEndianUnicode; // UTF-16 BE
    else TargetEncoding := TEncoding.Default; // ANSI
  end;

  // Start batch conversion
  if UseParallel then
    Log('��ʼ����ת��ѡ�е��ļ�...')
  else
    Log('��ʼת��ѡ�е��ļ�...');

  StartLogBuffering;
  SuccessCount := 0;

  try
    // Set cursor to wait state
    Screen.Cursor := crHourGlass;

    // ʹ�ò��л�˳����
    if UseParallel then
    begin
      // ʹ�ò��д���
      SuccessCount := FFileHelper.BatchConvertParallel(SelectedFiles, TargetEncoding, WithBOM);
    end
    else
    begin
      // ʹ��˳����
      SuccessCount := FFileHelper.BatchConvert(SelectedFiles, TargetEncoding, WithBOM);
    end;

    // �����ʱ
    ElapsedTime := System.DateUtils.MilliSecondsBetween(StartTime, Now);

    // ���±����������ļ���״̬
    UpdateFileGrid(FSelectedFolder);

    // Complete batch conversion, show result
    if UseParallel then
      Log(System.SysUtils.Format('��������ת�����: �ɹ� %d/%d ���ļ� (�ܺ�ʱ: %d ms, ƽ��ÿ�ļ� %.2f ms)',
        [SuccessCount, Length(SelectedFiles), ElapsedTime, ElapsedTime / Length(SelectedFiles)]))
    else
      Log(System.SysUtils.Format('����ת�����: �ɹ� %d/%d ���ļ� (�ܺ�ʱ: %d ms)',
        [SuccessCount, Length(SelectedFiles), ElapsedTime]));

    if SuccessCount < Length(SelectedFiles) then
      Log(System.SysUtils.Format('ע��: %d ���ļ�δ�ܳɹ�ת�� (�����Ƿ��ı��ļ����޷�����)',
        [Length(SelectedFiles) - SuccessCount]));

    ShowMessage(System.SysUtils.Format('ת�����: �ɹ� %d/%d ���ļ� (��ʱ: %d ms)',
      [SuccessCount, Length(SelectedFiles), ElapsedTime]));
  finally
    // Restore cursor
    Screen.Cursor := crDefault;
    EndLogBuffering;
  end;
end;

