  Application.CreateForm(TForm1, Form1);
end;

procedure TForm1.FormCreate(Sender: TObject);
begin
  // ��������������м����¼�
  KeyPreview := True;

  // �����ϷŹ���
  TDragDropFilesEx.EnableDragDrop(Self);
  Log('�������ļ��ϷŹ���');

