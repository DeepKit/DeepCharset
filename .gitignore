# Delphi 和 Python 项目中常见的忽略文件类型
# 操作系统生成的文件
.DS_Store  # macOS 系统生成的文件
ehthumbs.db  # Windows 系统中某些应用程序生成的文件

# 临时文件和编辑器备份文件
*.swp  # Vim 编辑器生成的临时文件
*.swo
*.swn
*.ses
*.tmp
*.temp

# IDE 和编辑器配置文件
.idea/  # IntelliJ IDEA 项目配置文件
.vscode/  # Visual Studio Code 工作区设置文件

# 测试报告和临时文件
/tests/output/  # 测试生成的报告文件和临时文件
*.testresults

# 日志文件和缓存文件
*.log
*.cache

