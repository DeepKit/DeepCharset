<svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <defs>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="5"/>
      <feOffset dx="2" dy="2" result="offsetblur"/>
      <feComponentTransfer>
        <feFuncA type="linear" slope="0.3"/>
      </feComponentTransfer>
      <feMerge>
        <feMergeNode/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Document Base -->
  <rect x="106" y="56" width="300" height="400" rx="20" ry="20" fill="white" filter="url(#shadow)"/>
  
  <!-- Document Top Corner Fold -->
  <path d="M366 56 L406 96 L366 96 Z" fill="#e6e6e6"/>
  
  <!-- Code Lines -->
  <rect x="146" y="136" width="220" height="12" rx="2" ry="2" fill="#e6e6e6"/>
  <rect x="146" y="166" width="180" height="12" rx="2" ry="2" fill="#e6e6e6"/>
  <rect x="146" y="196" width="200" height="12" rx="2" ry="2" fill="#e6e6e6"/>
  
  <!-- Encoding Text -->
  <text x="146" y="116" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="#2b78e4">UTF-8</text>
  <text x="250" y="116" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="#666">→</text>
  <text x="280" y="116" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="#2b78e4">ANSI</text>
  
  <!-- More Code Lines -->
  <rect x="146" y="226" width="220" height="12" rx="2" ry="2" fill="#e6e6e6"/>
  <rect x="146" y="256" width="160" height="12" rx="2" ry="2" fill="#e6e6e6"/>
  
  <!-- Transformation Circle -->
  <circle cx="256" cy="320" r="80" fill="#2b78e4" filter="url(#shadow)"/>
  
  <!-- Arrows -->
  <path d="M256 260 L286 300 L226 300 Z" fill="#ffcc00"/>
  <path d="M256 380 L226 340 L286 340 Z" fill="#ffcc00"/>
  
  <!-- Curved Arrows -->
  <path d="M310 290 A60 60 0 0 1 310 350" stroke="#ffffff" stroke-width="10" fill="none" stroke-linecap="round"/>
  <path d="M202 350 A60 60 0 0 1 202 290" stroke="#ffffff" stroke-width="10" fill="none" stroke-linecap="round"/>

  <!-- Arrow tips -->
  <path d="M315 355 L310 340 L325 345 Z" fill="#ffffff"/>
  <path d="M197 285 L202 300 L187 295 Z" fill="#ffffff"/>
</svg>